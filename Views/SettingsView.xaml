<UserControl x:Class="EasyGet.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32" MaxWidth="920" HorizontalAlignment="Center">

            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="系统设置"
                           Style="{StaticResource TextPageTitle}"/>
                <TextBlock Text="管理下载环境、全局偏好及网络连接设置。"
                           Style="{StaticResource TextBodyStrong}"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE756;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="环境检测"
                               Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ToolPanelBorder}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,22">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource BgSurfaceHighestBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE943;" Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeLarge}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="yt-dlp" Style="{StaticResource TextSection}"/>
                                        <TextBlock Text="核心解析引擎" Style="{StaticResource TextBody}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="5" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource ErrorContainerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                                <Setter Property="Text" Value="已安装"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                                        <Setter Property="Text" Value="未安装"/>
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Grid>
                                <TextBlock Style="{StaticResource TextBody}" VerticalAlignment="Center">
                                    <Run Text="当前版本: "/>
                                    <Run Text="{Binding YtDlpVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                                </TextBlock>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource SurfaceButton}"
                                        Padding="10,5"
                                        Command="{Binding UpdateYtDlpCommand}"
                                        IsEnabled="{Binding CanUpdateYtDlp}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE895;" Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="更新"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ToolPanelBorder}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,22">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource BgSurfaceHighestBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8B2;" Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeLarge}"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ffmpeg" Style="{StaticResource TextSection}"/>
                                        <TextBlock Text="多媒体混流工具" Style="{StaticResource TextBody}"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="5" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                                    <Setter Property="Background" Value="{StaticResource ErrorContainerBrush}"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock>
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                                <Setter Property="Text" Value="已安装"/>
                                                <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                                        <Setter Property="Text" Value="未安装"/>
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Grid>
                                <TextBlock Style="{StaticResource TextBody}" VerticalAlignment="Center">
                                    <Run Text="当前版本: "/>
                                    <Run Text="{Binding FfmpegVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                                </TextBlock>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource SurfaceButton}"
                                        Padding="10,5"
                                        Command="{Binding CheckEnvironmentCommand}"
                                        IsEnabled="{Binding CanCheckEnvironment}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="重新检测"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Style="{StaticResource SurfaceButton}"
                            Command="{Binding InstallMissingToolsCommand}"
                            IsEnabled="{Binding CanInstallMissingTools}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="安装缺失组件"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding InstallStatusStage}"
                               Style="{StaticResource TextBodyStrong}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding InstallStatusStage, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding InstallStatusMessage}"
                               Style="{StaticResource TextBody}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding InstallStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding UpdateStatusMessage}"
                               Style="{StaticResource TextBody}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding UpdateStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE896;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="下载设置" Style="{StaticResource TextSection}"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="默认保存目录" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="{Binding DefaultDownloadPath}" Style="{StaticResource TextBody}" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource AccentButton}"
                                    Padding="14,7"
                                    ToolTip="选择默认下载目录"
                                    AutomationProperties.Name="选择默认下载目录"
                                    Command="{Binding BrowseDownloadPathCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="更改目录"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="默认下载格式" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="优先下载最优画质的封装格式" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding FormatOptions}"
                                      SelectedItem="{Binding DefaultFormat}"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="最大下载分辨率" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="针对支持多分辨率的视频网站生效" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding QualityOptions}"
                                      SelectedItem="{Binding DefaultQuality}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="自动按平台归类" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="下载完成后自动将文件存入对应平台子目录" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AutoCategorizeByPlatform}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE790;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="外观设置" Style="{StaticResource TextSection}"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="主题配色" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="更改应用的强调色，定制个性化外观" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding ThemeOptions}"
                                      SelectedValuePath="Name"
                                      SelectedValue="{Binding SelectedThemeColor}">
                                <ComboBox.ItemTemplate>
                                    <DataTemplate>
                                        <TextBlock Text="{Binding DisplayName}"/>
                                    </DataTemplate>
                                </ComboBox.ItemTemplate>
                            </ComboBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE72E;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="代理设置" Style="{StaticResource TextSection}"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用网络代理" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="用于访问受限区域的媒体内容" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding UseProxy}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="代理地址 (http://host:port 或 socks5://host:port)"
                                   Style="{StaticResource TextCaption}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding ProxyAddress, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding UseProxy}"/>
                        <Button Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0"
                                Padding="18,8"
                                Command="{Binding SaveSettingsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" Style="{StaticResource IconGlyph}"
                                           FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="保存配置"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8D7;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="Cookie 设置" Style="{StaticResource TextSection}"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="X(Twitter)、Instagram 等平台的年龄限制/私密视频需要登录 Cookie 才能下载"
                                   Style="{StaticResource TextBodyStrong}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding CookieContent, UpdateSourceTrigger=LostFocus}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="88"
                                 MaxHeight="150"
                                 VerticalScrollBarVisibility="Auto"
                                 FontFamily="{StaticResource FontFamilyMono}"
                                 FontSize="{StaticResource FontSizeCaption}"
                                 VerticalContentAlignment="Top"/>
                        <DockPanel Margin="0,10,0,0">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="10,5"
                                    Command="{Binding ClearCookieCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="清空 Cookie"/>
                                </StackPanel>
                            </Button>
                            <TextBlock Style="{StaticResource TextBody}"
                                       VerticalAlignment="Center"
                                       Text="{Binding CookieContent, Converter={StaticResource CookieStatusConverter}}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,30">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE9D9;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                    <TextBlock Text="性能设置" Style="{StaticResource TextSection}"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="并发分片数" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="yt-dlp 多线程下载分片数" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding ConcurrentFragments, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用 aria2c 外部下载器" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="检测到 aria2c.exe 时使用多连接下载；未安装会自动回退到 yt-dlp 内置下载器"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding UseAria2c}"
                                          VerticalAlignment="Center"
                                          ToolTip="启用 aria2c 外部下载器"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="同时下载任务数" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="批量下载时的并发上限" Style="{StaticResource TextBody}" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,20" HorizontalAlignment="Center">
                <TextBlock Text="EASYGET MEDIA DOWNLOADER ENGINE v2.4.0 (STABLE B642)"
                           Style="{StaticResource TextMono}"
                           FontSize="{StaticResource FontSizeCaption}"
                           TextAlignment="Center"/>
                <TextBlock Text="键盘快捷键: Ctrl+1~4 切换页面 | Esc 取消解析/关闭通知 | Ctrl+V 快速粘贴解析 (输入框未聚焦时)"
                           Style="{StaticResource TextCaption}"
                           Opacity="0.8"
                           HorizontalAlignment="Center"
                           Margin="0,6,0,0"/>
                <TextBlock Text="Designed for High-Performance Desktop Environments"
                           Style="{StaticResource TextCaption}"
                           Opacity="0.55"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

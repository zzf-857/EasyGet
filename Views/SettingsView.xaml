<UserControl x:Class="EasyGet.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:sys="clr-namespace:System;assembly=mscorlib"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Margin="40,32" MaxWidth="800">

            <!-- 页面标题 -->
            <TextBlock Text="设置" FontSize="28" FontWeight="ExtraBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                       Margin="0,0,0,32"/>

            <!-- ===== 环境检测 ===== -->
            <TextBlock Text="环境检测" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Effect="{StaticResource SoftShadow}"
                    Padding="24,20" Margin="0,0,0,36">
                <StackPanel>
                    <!-- yt-dlp -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="yt-dlp" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding YtDlpVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2D4A2D"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                            <Setter Property="Background" Value="#4A2D2D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓ 已安装"/>
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                                <Setter Property="Text" Value="✗ 未安装"/>
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <!-- ffmpeg -->
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="ffmpeg" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock FontSize="12" Margin="0,2,0,0">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding FfmpegVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                            </TextBlock>
                        </StackPanel>
                        <Border Grid.Column="1" CornerRadius="10" Padding="10,4" VerticalAlignment="Center">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="#2D4A2D"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                            <Setter Property="Background" Value="#4A2D2D"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock FontSize="11" FontWeight="Medium">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock">
                                        <Setter Property="Text" Value="✓ 已安装"/>
                                        <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                                <Setter Property="Text" Value="✗ 未安装"/>
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>
                    </Grid>

                    <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                        <Button Style="{StaticResource SurfaceButton}" Content="🔄 重新检测"
                                Command="{Binding CheckEnvironmentCommand}"
                                IsEnabled="{Binding CanCheckEnvironment}"/>
                        <Button Style="{StaticResource SurfaceButton}" Content="⬇ 安装缺失组件"
                                Margin="8,0,0,0"
                                Command="{Binding InstallMissingToolsCommand}"
                                IsEnabled="{Binding CanInstallMissingTools}"/>
                        <Button Style="{StaticResource SurfaceButton}" Content="⬆ 更新 yt-dlp"
                                Margin="8,0,0,0"
                                Command="{Binding UpdateYtDlpCommand}"
                                IsEnabled="{Binding CanUpdateYtDlp}"/>
                    </StackPanel>
                    <StackPanel Margin="0,8,0,0"
                                Visibility="{Binding InstallStatusStage, Converter={StaticResource StringToVisibility}}">
                        <TextBlock Text="{Binding InstallStatusStage}" FontSize="11" FontWeight="SemiBold"
                                   Foreground="{StaticResource AccentBrush}"
                                   Visibility="{Binding InstallStatusStage, Converter={StaticResource StringToVisibility}}"/>
                        <TextBlock Text="{Binding InstallStatusMessage}" FontSize="11"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding InstallStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                    </StackPanel>
                    <TextBlock Text="{Binding UpdateStatusMessage}" FontSize="11"
                               Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0"
                               TextWrapping="Wrap"
                               Visibility="{Binding UpdateStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </Border>

            <!-- ===== 下载设置 ===== -->
            <TextBlock Text="下载设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Effect="{StaticResource SoftShadow}"
                    Padding="24,20" Margin="0,0,0,36">
                <StackPanel>
                    <!-- 默认下载目录 -->
                    <TextBlock Text="默认下载目录" FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                                 Text="{Binding DefaultDownloadPath}" IsReadOnly="True"/>
                        <Button Grid.Column="1" Style="{StaticResource SurfaceButton}"
                                Content="📁" ToolTip="选择默认下载目录"
                                AutomationProperties.Name="选择默认下载目录"
                                Margin="8,0,0,0"
                                Command="{Binding BrowseDownloadPathCommand}"/>
                    </Grid>

                    <!-- 默认格式 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="默认格式" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding DefaultFormat}"/>
                    </Grid>

                    <!-- 默认画质 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="200"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="默认画质" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ComboBox Grid.Column="1" Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding QualityOptions}"
                                  SelectedItem="{Binding DefaultQuality}"/>
                    </Grid>

                    <!-- 自动按平台归类 -->
                    <Grid Margin="0,0,0,4">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="自动按平台归类" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="下载完成后自动将文件存入对应平台子目录（如 哔哩哔哩、YouTube 等）" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding AutoCategorizeByPlatform}"
                                      VerticalAlignment="Center"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- ===== 代理设置 ===== -->
            <TextBlock Text="代理设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Effect="{StaticResource SoftShadow}"
                    Padding="24,20" Margin="0,0,0,36">
                <StackPanel>
                    <Grid Margin="0,0,0,12">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="启用代理" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   VerticalAlignment="Center"/>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding UseProxy}"/>
                    </Grid>
                    <TextBlock Text="代理地址 (http://host:port 或 socks5://host:port)"
                               FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding ProxyAddress, UpdateSourceTrigger=PropertyChanged}"
                             IsEnabled="{Binding UseProxy}"/>
                </StackPanel>
            </Border>

            <!-- ===== Cookie 设置 ===== -->
            <TextBlock Text="Cookie 设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Effect="{StaticResource SoftShadow}"
                    Padding="24,20" Margin="0,0,0,36">
                <StackPanel>
                    <TextBlock Text="X(Twitter)、Instagram 等平台的年龄限制/私密视频需要登录 Cookie 才能下载" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,0,12" TextWrapping="Wrap"/>

                    <!-- 操作步骤提示 -->
                    <Border Background="#11111B" CornerRadius="8" Padding="16,14" Margin="0,0,0,14">
                        <StackPanel>
                            <TextBlock Text="📋 如何获取 Cookie（以 Chrome + X 为例）" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentBrush}" Margin="0,0,0,8"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="① 打开 Chrome，登录 x.com（用你要下载视频的那个账号）"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="② 在 x.com 页面上按 F12 打开开发者工具"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="③ 点顶部的「Network / 网络」标签页"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="④ 按 F5 刷新页面，左侧会出现一堆请求列表"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="⑤ 点击列表中任意一条请求（比如第一个）"/>
                            <TextBlock FontSize="11" Foreground="#CDD6F4" TextWrapping="Wrap" Margin="0,2,0,2"
                                       Text="⑥ 在右侧「Headers / 标头」面板中往下找到「Request Headers / 请求标头」"/>
                            <TextBlock FontSize="11" Foreground="#A6E3A1" TextWrapping="Wrap" Margin="0,4,0,2" FontWeight="SemiBold"
                                       Text="⑦ 找到 cookie: 那一行 → 右键点击值 → 复制值 → 粘贴到下方输入框"/>
                            <TextBlock FontSize="10" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap" Margin="0,6,0,0"
                                       Text="💡 Cookie 通常很长（一整行），形如 ct0=abc123; auth_token=xyz789; guest_id=..."/>
                        </StackPanel>
                    </Border>

                    <!-- Cookie 输入框 -->
                    <TextBox Style="{StaticResource DarkTextBox}"
                             Text="{Binding CookieContent, UpdateSourceTrigger=LostFocus}"
                             AcceptsReturn="True" TextWrapping="Wrap"
                             MinHeight="60" MaxHeight="120"
                             VerticalScrollBarVisibility="Auto"
                             FontSize="11" FontFamily="Consolas, Courier New"
                             VerticalContentAlignment="Top"/>

                    <!-- 状态 + 清空按钮 -->
                    <DockPanel Margin="0,8,0,0">
                        <Button DockPanel.Dock="Right" Style="{StaticResource SurfaceButton}"
                                Content="清空 Cookie" FontSize="11" Padding="10,5"
                                Command="{Binding ClearCookieCommand}"/>
                        <TextBlock FontSize="11" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"
                                   Text="{Binding CookieContent, Converter={StaticResource CookieStatusConverter}}"/>
                    </DockPanel>
                </StackPanel>
            </Border>

            <!-- ===== 性能设置 ===== -->
            <TextBlock Text="性能设置" FontSize="18" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,16"/>
            <Border Background="{StaticResource BgSurfaceBrush}" CornerRadius="12"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                    Effect="{StaticResource SoftShadow}"
                    Padding="24,20" Margin="0,0,0,36">
                <StackPanel>
                    <!-- 并发分片 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="并发分片数" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="yt-dlp 多线程下载分片数" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" TextAlignment="Center"
                                 Text="{Binding ConcurrentFragments, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>

                    <!-- aria2c 外部下载器 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="启用 aria2c 外部下载器" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="检测到 aria2c.exe 时使用多连接下载；未安装会自动回退到 yt-dlp 内置下载器" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap"/>
                        </StackPanel>
                        <ToggleButton Grid.Column="1" Style="{StaticResource ToggleSwitch}"
                                      IsChecked="{Binding UseAria2c}"
                                      VerticalAlignment="Center"
                                      ToolTip="启用 aria2c 外部下载器"/>
                    </Grid>

                    <!-- 同时下载数 -->
                    <Grid Margin="0,0,0,16">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="120"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel>
                            <TextBlock Text="同时下载任务数" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"/>
                            <TextBlock Text="批量下载时的并发上限" FontSize="11" Foreground="{StaticResource TextMutedBrush}"/>
                        </StackPanel>
                        <TextBox Grid.Column="1" Style="{StaticResource DarkTextBox}" TextAlignment="Center"
                                 Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=LostFocus}"/>
                    </Grid>
                </StackPanel>
            </Border>

            <!-- 版本信息 -->
            <StackPanel Margin="0,0,0,32">
                <TextBlock Text="关于 EasyGet" FontSize="14" FontWeight="SemiBold"
                           Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,4"/>
                <TextBlock Text="基于 yt-dlp 的全平台视频下载工具" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}"/>
                <TextBlock Text="版本 1.0.0" FontSize="12"
                           Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0"/>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

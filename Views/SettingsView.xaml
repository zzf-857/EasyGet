<UserControl x:Class="EasyGet.Views.SettingsView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32" MaxWidth="920" HorizontalAlignment="Center">

            <StackPanel Margin="0,0,0,28">
                <TextBlock Text="系统设置"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="36"
                           FontWeight="ExtraBold"
                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"/>
                <TextBlock Text="管理下载环境、全局偏好及网络连接设置。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           Margin="0,8,0,0"/>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}"
                               FontSize="18"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="环境检测"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="18"
                               FontWeight="SemiBold"/>
                </StackPanel>

                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="16"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <Border Grid.Column="0" Style="{StaticResource ToolPanelBorder}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,22">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource BgSurfaceHighestBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE943;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="yt-dlp" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="核心解析引擎" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="5" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A4250"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                                    <Setter Property="Background" Value="#4A1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="已安装"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding YtDlpFound}" Value="False">
                                                        <Setter Property="Text" Value="未安装"/>
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Grid>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                                    <Run Text="当前版本: "/>
                                    <Run Text="{Binding YtDlpVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                                </TextBlock>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource SurfaceButton}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Command="{Binding UpdateYtDlpCommand}"
                                        IsEnabled="{Binding CanUpdateYtDlp}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE895;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="更新"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>

                    <Border Grid.Column="2" Style="{StaticResource ToolPanelBorder}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,22">
                                <StackPanel Orientation="Horizontal">
                                    <Border Width="42" Height="42" CornerRadius="8" Background="{StaticResource BgSurfaceHighestBrush}" Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8B2;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   FontSize="18"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel VerticalAlignment="Center">
                                        <TextBlock Text="ffmpeg" Foreground="{StaticResource TextPrimaryBrush}" FontSize="16" FontWeight="SemiBold"/>
                                        <TextBlock Text="多媒体混流工具" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12"/>
                                    </StackPanel>
                                </StackPanel>
                                <Border HorizontalAlignment="Right" VerticalAlignment="Top" CornerRadius="5" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="#1A4250"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                                    <Setter Property="Background" Value="#4A1E1E"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="10" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text" Value="已安装"/>
                                                <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding FfmpegFound}" Value="False">
                                                        <Setter Property="Text" Value="未安装"/>
                                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>
                            <Grid>
                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" VerticalAlignment="Center">
                                    <Run Text="当前版本: "/>
                                    <Run Text="{Binding FfmpegVersion, Mode=OneWay, FallbackValue='未检测'}"/>
                                </TextBlock>
                                <Button HorizontalAlignment="Right"
                                        Style="{StaticResource SurfaceButton}"
                                        Padding="10,5"
                                        FontSize="12"
                                        Command="{Binding CheckEnvironmentCommand}"
                                        IsEnabled="{Binding CanCheckEnvironment}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="重新检测"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </StackPanel>
                    </Border>
                </Grid>

                <StackPanel Orientation="Horizontal" Margin="0,12,0,0">
                    <Button Style="{StaticResource SurfaceButton}"
                            Command="{Binding InstallMissingToolsCommand}"
                            IsEnabled="{Binding CanInstallMissingTools}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="安装缺失组件"/>
                        </StackPanel>
                    </Button>
                    <TextBlock Text="{Binding InstallStatusStage}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource AccentBrush}"
                               Margin="14,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding InstallStatusStage, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding InstallStatusMessage}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding InstallStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                    <TextBlock Text="{Binding UpdateStatusMessage}"
                               FontSize="12"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="10,0,0,0"
                               VerticalAlignment="Center"
                               Visibility="{Binding UpdateStatusMessage, Converter={StaticResource StringToVisibility}}"/>
                </StackPanel>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="下载设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="默认保存目录" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DefaultDownloadPath}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="1"
                                    Style="{StaticResource AccentButton}"
                                    Padding="14,7"
                                    ToolTip="选择默认下载目录"
                                    AutomationProperties.Name="选择默认下载目录"
                                    Command="{Binding BrowseDownloadPathCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="更改目录"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="默认下载格式" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="优先下载最优画质的封装格式" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding FormatOptions}"
                                      SelectedItem="{Binding DefaultFormat}"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="最大下载分辨率" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="针对支持多分辨率的视频网站生效" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding QualityOptions}"
                                      SelectedItem="{Binding DefaultQuality}"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="自动按平台归类" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="下载完成后自动将文件存入对应平台子目录" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding AutoCategorizeByPlatform}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="代理设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用网络代理" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="用于访问受限区域的媒体内容" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding UseProxy}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                        <TextBlock Text="代理地址 (http://host:port 或 socks5://host:port)"
                                   FontSize="11"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding ProxyAddress, UpdateSourceTrigger=PropertyChanged}"
                                 IsEnabled="{Binding UseProxy}"/>
                        <Button Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Right"
                                Margin="0,14,0,0"
                                Padding="18,8"
                                Command="{Binding SaveSettingsCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="保存配置"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8D7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="Cookie 设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <TextBlock Text="X(Twitter)、Instagram 等平台的年龄限制/私密视频需要登录 Cookie 才能下载"
                                   FontSize="13"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,12"/>
                        <TextBox Style="{StaticResource DarkTextBox}"
                                 Text="{Binding CookieContent, UpdateSourceTrigger=LostFocus}"
                                 AcceptsReturn="True"
                                 TextWrapping="Wrap"
                                 MinHeight="88"
                                 MaxHeight="150"
                                 VerticalScrollBarVisibility="Auto"
                                 FontSize="11"
                                 FontFamily="Consolas, Courier New"
                                 VerticalContentAlignment="Top"/>
                        <DockPanel Margin="0,10,0,0">
                            <Button DockPanel.Dock="Right"
                                    Style="{StaticResource SurfaceButton}"
                                    FontSize="12"
                                    Padding="10,5"
                                    Command="{Binding ClearCookieCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="清空 Cookie"/>
                                </StackPanel>
                            </Button>
                            <TextBlock FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center"
                                       Text="{Binding CookieContent, Converter={StaticResource CookieStatusConverter}}"/>
                        </DockPanel>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,30">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE9D9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,8,0"/>
                    <TextBlock Text="性能设置" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                </StackPanel>
                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="并发分片数" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="yt-dlp 多线程下载分片数" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding ConcurrentFragments, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用 aria2c 外部下载器" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="检测到 aria2c.exe 时使用多连接下载；未安装会自动回退到 yt-dlp 内置下载器"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="12"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding UseAria2c}"
                                          VerticalAlignment="Center"
                                          ToolTip="启用 aria2c 外部下载器"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="同时下载任务数" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="SemiBold"/>
                                <TextBlock Text="批量下载时的并发上限" Foreground="{StaticResource TextSecondaryBrush}" FontSize="12" Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding MaxConcurrentDownloads, UpdateSourceTrigger=LostFocus}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,20" HorizontalAlignment="Center">
                <TextBlock Text="EASYGET MEDIA DOWNLOADER ENGINE v2.4.0 (STABLE B642)"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11"
                           FontFamily="Cascadia Code, Consolas"
                           TextAlignment="Center"/>
                <TextBlock Text="Designed for High-Performance Desktop Environments"
                           Foreground="{StaticResource TextMutedBrush}"
                           Opacity="0.55"
                           FontSize="10"
                           FontStyle="Italic"
                           HorizontalAlignment="Center"
                           Margin="0,4,0,0"/>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</UserControl>

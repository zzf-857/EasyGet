<UserControl x:Class="EasyGet.Views.BatchDownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="40,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- 标题 -->
        <TextBlock Grid.Row="0" Text="批量下载" FontSize="28" FontWeight="ExtraBold"
                   Foreground="{StaticResource TextPrimaryBrush}"
                   FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                   Margin="0,0,0,24"/>

        <!-- URL 文本框 -->
        <Border Grid.Row="1" Background="{StaticResource BgSurfaceBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                Padding="16">
            <StackPanel>
                <DockPanel Margin="0,0,0,8">
                    <TextBlock Text="粘贴视频链接（每行一个）" 
                               FontSize="12" Foreground="{StaticResource TextMutedBrush}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,12,0"
                                   FontSize="12" Foreground="{StaticResource AccentBrush}">
                            <Run Text="{Binding LinkCount, Mode=OneWay}"/> <Run Text="个链接"/>
                        </TextBlock>
                        <Button Style="{StaticResource SurfaceButton}" Content="📋 粘贴"
                                FontSize="11" Padding="10,5"
                                Command="{Binding PasteUrlsCommand}"/>
                    </StackPanel>
                </DockPanel>
                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding UrlsText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True" TextWrapping="Wrap"
                         MinHeight="100" MaxHeight="160"
                         VerticalScrollBarVisibility="Auto"/>
            </StackPanel>
        </Border>

        <!-- 播放列表导入 -->
        <Grid Grid.Row="2" Margin="0,12,0,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                     Text="{Binding PlaylistUrl, UpdateSourceTrigger=PropertyChanged}"
                     FontSize="12"/>
            <Button Grid.Column="1" Style="{StaticResource SurfaceButton}"
                    Content="📂 导入播放列表" Margin="8,0,0,0"
                    FontSize="11" Padding="12,7"
                    Command="{Binding ImportPlaylistCommand}"
                    IsEnabled="{Binding IsImportingPlaylist, Converter={StaticResource InverseBool}}"/>
        </Grid>

        <!-- 选项行 + 开始按钮 -->
        <DockPanel Grid.Row="3" Margin="0,16,0,16">
            <Button DockPanel.Dock="Right" Style="{StaticResource AccentButton}"
                    Content="⬇ 全部开始" Padding="24,10"
                    Command="{Binding StartBatchDownloadCommand}"/>
            <WrapPanel>
                <StackPanel Margin="0,0,16,0">
                    <TextBlock Text="格式" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Width="130"
                              ItemsSource="{Binding FormatOptions}"
                              SelectedItem="{Binding SelectedFormat}"/>
                </StackPanel>
                <StackPanel>
                    <TextBlock Text="画质" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,4"/>
                    <ComboBox Style="{StaticResource DarkComboBox}" Width="130"
                              ItemsSource="{Binding QualityOptions}"
                              SelectedItem="{Binding SelectedQuality}"/>
                </StackPanel>
            </WrapPanel>
        </DockPanel>

        <!-- 下载队列 -->
        <Border Grid.Row="4" Background="{StaticResource BgSurfaceBrush}" CornerRadius="10"
                BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                Padding="16">
            <DockPanel>
                <DockPanel DockPanel.Dock="Top" Margin="0,0,0,12">
                    <TextBlock Text="下载队列" FontSize="16" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <TextBlock VerticalAlignment="Center"
                                   FontSize="12" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,12,0">
                            <Run Text="任务数:"/>
                            <Run Text="{Binding QueueTasks.Count, Mode=OneWay}"/>
                        </TextBlock>
                        <Button Style="{StaticResource SurfaceButton}" Content="✕ 全部取消"
                                FontSize="11" Padding="10,5"
                                Command="{Binding CancelAllCommand}"/>
                    </StackPanel>
                </DockPanel>
                <ListBox ItemsSource="{Binding QueueTasks}"
                         Background="Transparent" BorderThickness="0">
                    <ListBox.ItemTemplate>
                        <DataTemplate>
                            <Border Background="#1A1A1A" CornerRadius="8" Padding="12" Margin="0,0,0,6"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Title, FallbackValue='解析中...'}"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <StackPanel Orientation="Horizontal" Margin="0,4,0,0">
                                            <TextBlock Text="{Binding Status, Converter={StaticResource StatusToText}}"
                                                       Foreground="{Binding Status, Converter={StaticResource StatusToColor}}"
                                                       FontSize="11"/>
                                            <TextBlock Text="{Binding SpeedText, Mode=OneWay}" Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="11" Margin="12,0,0,0"/>
                                        </StackPanel>
                                        <ProgressBar Style="{StaticResource AccentProgressBar}"
                                                     Value="{Binding Progress}" Maximum="100"
                                                     Margin="0,6,0,0"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center" Orientation="Horizontal"
                                                Margin="16,0,0,0">
                                        <TextBlock VerticalAlignment="Center"
                                                   FontSize="16" FontWeight="Bold"
                                                   Foreground="{StaticResource AccentBrush}" Margin="0,0,12,0">
                                            <Run Text="{Binding Progress, StringFormat={}{0:F0}}"/><Run Text="%"/>
                                        </TextBlock>
                                        <Button Style="{StaticResource SurfaceButton}" Content="⏸"
                                                ToolTip="暂停" Padding="8,5" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Style="{StaticResource SurfaceButton}" Content="▶"
                                                ToolTip="恢复" Padding="8,5" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.ResumeTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Style="{StaticResource SurfaceButton}" Content="🔄"
                                                ToolTip="重试" Padding="8,5" FontSize="11" Margin="0,0,4,0"
                                                Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                        <Button Style="{StaticResource SurfaceButton}" Content="✕"
                                                ToolTip="取消任务" Padding="8,5" FontSize="11"
                                                Command="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Id}"/>
                                    </StackPanel>
                                </Grid>
                            </Border>
                        </DataTemplate>
                    </ListBox.ItemTemplate>
                </ListBox>
            </DockPanel>
        </Border>

    </Grid>
</UserControl>

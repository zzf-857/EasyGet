<UserControl x:Class="EasyGet.Views.BatchDownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="Transparent">

    <Grid Margin="32,28,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="批量下载"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="34"
                           FontWeight="ExtraBold"
                           FontFamily="Segoe UI Variable, Microsoft YaHei UI"/>
                <TextBlock Text="输入多个视频链接，我们将自动为您解析并加入下载队列。"
                           Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           Margin="0,8,0,0"/>
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource SurfaceButton}"
                    ToolTip="粘贴多个视频链接"
                    AutomationProperties.Name="粘贴多个视频链接"
                    Command="{Binding PasteUrlsCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="粘贴内容" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorder}" Padding="22,20" Margin="0,0,0,24">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="粘贴视频链接（每行一个）"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               FontSize="12"
                               FontWeight="SemiBold"
                               VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right"
                            Background="#1A4250"
                            CornerRadius="5"
                            Padding="8,2">
                        <TextBlock Foreground="{StaticResource AccentBrush}"
                                   FontSize="11"
                                   FontWeight="Bold">
                            <Run Text="已检测到 "/>
                            <Run Text="{Binding LinkCount, Mode=OneWay}"/>
                            <Run Text=" 个链接"/>
                        </TextBlock>
                    </Border>
                </Grid>

                <TextBox Style="{StaticResource DarkTextBox}"
                         Text="{Binding UrlsText, UpdateSourceTrigger=PropertyChanged}"
                         AcceptsReturn="True"
                         TextWrapping="Wrap"
                         Height="170"
                         VerticalScrollBarVisibility="Auto"
                         FontFamily="Cascadia Code, Consolas, Courier New"
                         FontSize="13"/>

                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="下载格式" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  Width="132"
                                  ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding SelectedFormat}"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="清晰度优先" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  Width="160"
                                  ItemsSource="{Binding QualityOptions}"
                                  SelectedItem="{Binding SelectedQuality}"/>
                    </StackPanel>

                    <Button Grid.Column="3"
                            Style="{StaticResource AccentButton}"
                            Padding="24,12"
                            VerticalAlignment="Bottom"
                            ToolTip="开始批量下载"
                            AutomationProperties.Name="开始批量下载"
                            Command="{Binding StartBatchDownloadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                            <TextBlock Text="开始批量下载" FontSize="14" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>

                <Grid Margin="0,16,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox Grid.Column="0"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding PlaylistUrl, UpdateSourceTrigger=PropertyChanged}"
                             FontSize="12"/>
                    <Button Grid.Column="1"
                            Style="{StaticResource SurfaceButton}"
                            Margin="8,0,0,0"
                            FontSize="12"
                            ToolTip="导入播放列表"
                            AutomationProperties.Name="导入播放列表"
                            Command="{Binding ImportPlaylistCommand}"
                            IsEnabled="{Binding IsImportingPlaylist, Converter={StaticResource InverseBool}}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                            <TextBlock Text="导入播放列表" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
            </StackPanel>
        </Border>

        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="下载队列"
                               FontSize="24"
                               FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BgSurfaceHighBrush}"
                            CornerRadius="10"
                            Padding="8,2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}">
                            <Run Text="{Binding QueueTasks.Count, Mode=OneWay}"/>
                            <Run Text=" 任务中"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="10,5"
                            FontSize="12"
                            ToolTip="暂停全部任务"
                            AutomationProperties.Name="暂停全部任务"
                            Command="{Binding PauseAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="暂停全部" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="10,5"
                            FontSize="12"
                            Margin="8,0,0,0"
                            ToolTip="取消全部任务"
                            AutomationProperties.Name="取消全部任务"
                            Command="{Binding CancelAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="取消全部" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>

            <Border Grid.Row="1"
                    Style="{StaticResource ToolPanelBorder}"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QueueTasks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE896;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="48" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无并行任务" FontSize="15" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="在上方粘贴多个链接即可开始批量下载" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>

                    <ListBox ItemsSource="{Binding QueueTasks}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ToolPanelBorder}"
                                        Padding="12"
                                        BorderThickness="1,1,1,1">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="112"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <Border Grid.Column="0"
                                                Width="96"
                                                Height="62"
                                                CornerRadius="7"
                                                Background="{StaticResource BgSurfaceHighestBrush}"
                                                ClipToBounds="True"
                                                HorizontalAlignment="Left">
                                            <Grid>
                                                <Image Source="{Binding ThumbnailUrl}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                                <Border Background="#66000000">
                                                    <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               Foreground="#99FFFFFF"
                                                               FontSize="24"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Border>

                                        <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                            <DockPanel LastChildFill="True">
                                                <Border DockPanel.Dock="Right"
                                                        Background="#1A4250"
                                                        CornerRadius="4"
                                                        Padding="6,2"
                                                        Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                                    <TextBlock Text="{Binding Platform}"
                                                               FontSize="10"
                                                               FontWeight="Bold"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>
                                                <TextBlock Text="{Binding Title, FallbackValue='解析中...'}"
                                                           Foreground="{StaticResource TextPrimaryBrush}"
                                                           FontSize="13"
                                                           FontWeight="SemiBold"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </DockPanel>
                                            <Grid Margin="0,6,0,4">
                                                <TextBlock Foreground="{StaticResource TextSecondaryBrush}" FontSize="11">
                                                    <Run Text="{Binding Status, Converter={StaticResource StatusToText}}"/>
                                                    <Run Text=" · "/>
                                                    <Run Text="{Binding FileSizeText, Mode=OneWay}"/>
                                                </TextBlock>
                                                <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource AccentBrush}" FontSize="11" FontWeight="Bold">
                                                    <Run Text="{Binding Progress, StringFormat={}{0:F0}}"/>
                                                    <Run Text="% · "/>
                                                    <Run Text="{Binding SpeedText, Mode=OneWay}"/>
                                                </TextBlock>
                                            </Grid>
                                            <ProgressBar Style="{StaticResource AccentProgressBar}"
                                                         Value="{Binding Progress}"
                                                         Maximum="100"
                                                         Height="5"/>
                                            <TextBlock Text="{Binding ErrorMessage}"
                                                       Foreground="{StaticResource ErrorBrush}"
                                                       FontSize="11"
                                                       Margin="0,5,0,0"
                                                       TextTrimming="CharacterEllipsis"
                                                       Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
                                        </StackPanel>

                                        <StackPanel Grid.Column="2"
                                                    Orientation="Horizontal"
                                                    VerticalAlignment="Center"
                                                    Margin="16,0,0,0">
                                            <Button Style="{StaticResource SurfaceButton}"
                                                    ToolTip="暂停"
                                                    AutomationProperties.Name="暂停任务"
                                                    Padding="8,5"
                                                    FontSize="11"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource SurfaceButton}"
                                                    ToolTip="恢复"
                                                    AutomationProperties.Name="恢复任务"
                                                    Padding="8,5"
                                                    FontSize="11"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.ResumeTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource SurfaceButton}"
                                                    ToolTip="重试"
                                                    AutomationProperties.Name="重试任务"
                                                    Padding="8,5"
                                                    FontSize="11"
                                                    Margin="0,0,4,0"
                                                    Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <TextBlock Text="&#xE72C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>
                                            <Button Style="{StaticResource SurfaceButton}"
                                                    ToolTip="取消任务"
                                                    AutomationProperties.Name="取消任务"
                                                    Padding="8,5"
                                                    FontSize="11"
                                                    Command="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding Id}">
                                                <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="12"/>
                                            </Button>
                                        </StackPanel>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>

        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,8,0,0">
            <DockPanel>
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="V1.0.8 STABLE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                    <TextBlock Text="   ACTIVE THREADS: " Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                    <TextBlock Text="{Binding QueueTasks.Count, Mode=OneWay}" Foreground="{StaticResource AccentBrush}" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Ellipse Width="6" Height="6" Fill="{StaticResource AccentBrush}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="SERVER STATUS: ONLINE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10" FontFamily="Cascadia Code, Consolas"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

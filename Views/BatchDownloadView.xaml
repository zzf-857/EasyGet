<UserControl x:Class="EasyGet.Views.BatchDownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True"
             AllowDrop="True"
             DragOver="UserControl_DragOver"
             DragLeave="UserControl_DragLeave"
             Drop="UserControl_Drop">

    <Grid Margin="32,28,32,0">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <!-- Drag & Drop Overlay -->
        <Border x:Name="DragDropOverlay"
                Grid.RowSpan="4"
                Background="{StaticResource ScrimHeavyBrush}"
                BorderBrush="{DynamicResource AccentBrush}"
                BorderThickness="2"
                CornerRadius="16"
                Opacity="0"
                Visibility="Collapsed"
                IsHitTestVisible="False"
                Margin="-8"
                Panel.ZIndex="100">
            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                <TextBlock Text="&#xE78A;" Style="{StaticResource IconGlyph}"
                           FontSize="{StaticResource IconSizeEmptyState}" Foreground="{DynamicResource AccentBrush}" HorizontalAlignment="Center" Margin="0,0,0,16"/>
                <TextBlock Text="拖入链接文本或 .txt 文件以批量导入"
                           Style="{StaticResource TextSection}" HorizontalAlignment="Center"/>
                <TextBlock Text="释放以提取所有视频链接"
                           Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,8,0,0"/>
            </StackPanel>
        </Border>
 
        <Grid Grid.Row="0" Margin="0,0,0,24">
            <StackPanel>
                <TextBlock Text="批量下载"
                           Style="{StaticResource TextPageTitle}"/>
                <TextBlock Text="输入多个视频链接，我们将自动为您解析并加入下载队列。"
                           Style="{StaticResource TextBody}"
                           Margin="0,8,0,0"/>
            </StackPanel>
            <Button HorizontalAlignment="Right"
                    VerticalAlignment="Bottom"
                    Style="{StaticResource SurfaceButton}"
                    ToolTip="粘贴多个视频链接"
                    AutomationProperties.Name="粘贴多个视频链接"
                    Command="{Binding PasteUrlsCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE77F;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="粘贴内容" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>
 
        <Border Grid.Row="1" Style="{StaticResource ToolPanelBorder}" Padding="22,20" Margin="0,0,0,24">
            <StackPanel>
                <Grid Margin="0,0,0,10">
                    <TextBlock Text="粘贴视频链接（每行一个）"
                               Style="{StaticResource TextBodyStrong}"
                               VerticalAlignment="Center"/>
                    <Border HorizontalAlignment="Right"
                            Background="{DynamicResource AccentContainerBrush}"
                            CornerRadius="5"
                            Padding="8,2">
                        <TextBlock Style="{StaticResource TextCaption}"
                                   Foreground="{DynamicResource AccentBrush}">
                            <Run Text="已检测到 "/>
                            <Run Text="{Binding LinkCount, Mode=OneWay}"/>
                            <Run Text=" 个链接"/>
                        </TextBlock>
                    </Border>
                </Grid>
 
                <TextBox Style="{StaticResource DarkTextBox}"
                          Text="{Binding UrlsText, UpdateSourceTrigger=PropertyChanged}"
                          AcceptsReturn="True"
                          TextWrapping="Wrap"
                          Height="170"
                          VerticalScrollBarVisibility="Auto"
                          FontFamily="{StaticResource FontFamilyMono}"
                          FontSize="{StaticResource FontSizeBody}"/>
 
                <Grid Margin="0,18,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
 
                    <StackPanel Grid.Column="0" Margin="0,0,16,0">
                        <TextBlock Text="下载格式" Style="{StaticResource TextCaption}" Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  Width="132"
                                  ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding SelectedFormat}"/>
                    </StackPanel>
 
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="清晰度优先" Style="{StaticResource TextCaption}" Margin="0,0,0,5"/>
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  Width="160"
                                  ItemsSource="{Binding QualityOptions}"
                                  SelectedItem="{Binding SelectedQuality}"/>
                    </StackPanel>
 
                    <Button Grid.Column="3"
                             Style="{StaticResource AccentButton}"
                             Padding="24,12"
                             VerticalAlignment="Bottom"
                             ToolTip="开始批量下载"
                             AutomationProperties.Name="开始批量下载"
                             Command="{Binding StartBatchDownloadCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE945;" Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                             <TextBlock Text="开始批量下载" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </Grid>
 
                <StackPanel Margin="0,16,0,0">
                    <TextBlock Text="播放列表链接" Style="{StaticResource TextCaption}" Margin="0,0,0,5"/>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Grid Grid.Column="0">
                            <TextBox Style="{StaticResource DarkTextBox}"
                                     Text="{Binding PlaylistUrl, UpdateSourceTrigger=PropertyChanged}"
                                     FontSize="{StaticResource FontSizeBody}"/>
                            <TextBlock Text="粘贴播放列表 URL (例如 YouTube, Bilibili 列表)..." 
                                       IsHitTestVisible="False"
                                       Margin="12,8,12,8"
                                       VerticalAlignment="Center">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding PlaylistUrl}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding PlaylistUrl}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Grid.Column="1"
                                Style="{StaticResource SurfaceButton}"
                                Margin="8,0,0,0"
                                FontSize="{StaticResource FontSizeBody}"
                                ToolTip="导入播放列表"
                                AutomationProperties.Name="导入播放列表"
                                Command="{Binding ImportPlaylistCommand}"
                                IsEnabled="{Binding IsImportingPlaylist, Converter={StaticResource InverseBool}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" Style="{StaticResource IconGlyph}"
                                           FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                <TextBlock Text="导入播放列表" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </Grid>
                </StackPanel>
            </StackPanel>
        </Border>
 
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
 
            <DockPanel Grid.Row="0" Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="下载队列"
                               Style="{StaticResource TextCardTitle}"
                               VerticalAlignment="Center"/>
                    <Border Background="{StaticResource BgSurfaceHighBrush}"
                            CornerRadius="10"
                            Padding="8,2"
                            Margin="10,0,0,0"
                            VerticalAlignment="Center">
                        <TextBlock Style="{StaticResource TextBody}">
                            <Run Text="{Binding QueueTasks.Count, Mode=OneWay}"/>
                            <Run Text=" 任务中"/>
                        </TextBlock>
                    </Border>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="10,5"
                            FontSize="{StaticResource FontSizeBody}"
                            ToolTip="暂停全部任务"
                            AutomationProperties.Name="暂停全部任务"
                            Command="{Binding PauseAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE769;" Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="暂停全部" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="10,5"
                            FontSize="{StaticResource FontSizeBody}"
                            Margin="8,0,0,0"
                            ToolTip="取消全部任务"
                            AutomationProperties.Name="取消全部任务"
                            Command="{Binding CancelAllCommand}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                            <TextBlock Text="取消全部" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </DockPanel>
 
            <Border Grid.Row="1"
                    Style="{StaticResource ToolPanelBorder}"
                    Padding="0"
                    Background="Transparent"
                    BorderThickness="0">
                <Grid>
                    <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,60,0,60">
                        <StackPanel.Style>
                            <Style TargetType="StackPanel">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding QueueTasks.Count}" Value="0">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </StackPanel.Style>
                        <TextBlock Text="&#xE896;" Style="{StaticResource IconGlyph}"
                                   FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="暂无并行任务" Style="{StaticResource TextBodyStrong}" HorizontalAlignment="Center" Margin="0,14,0,0"/>
                        <TextBlock Text="在上方粘贴多个链接即可开始批量下载" Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    </StackPanel>
 
                    <ListBox ItemsSource="{Binding QueueTasks}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListBox.ItemContainerStyle>
                            <Style TargetType="ListBoxItem">
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="Margin" Value="0,0,0,10"/>
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="behaviors:Motion.PageEnter" Value="True"/>
                                <Setter Property="Template">
                                    <Setter.Value>
                                        <ControlTemplate TargetType="ListBoxItem">
                                            <ContentPresenter/>
                                        </ControlTemplate>
                                    </Setter.Value>
                                </Setter>
                            </Style>
                        </ListBox.ItemContainerStyle>
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource ToolPanelBorder}"
                                        Padding="0"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="4"/>
                                            <ColumnDefinition Width="*"/>
                                        </Grid.ColumnDefinitions>
 
                                        <!-- 4px left status line -->
                                        <Border Grid.Column="0" Width="4" HorizontalAlignment="Left">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BorderPrimaryBrush}"/>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding Status}" Value="Waiting">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Resolving">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Merging">
                                                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                            <Setter Property="Background" Value="{StaticResource SuccessBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                            <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                            <Setter Property="Background" Value="{StaticResource WarningBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
 
                                        <!-- Card content -->
                                        <Grid Grid.Column="1" Margin="12">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="112"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
 
                                            <Border Grid.Column="0"
                                                    Width="96"
                                                    Height="62"
                                                    CornerRadius="7"
                                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                                    ClipToBounds="True"
                                                    HorizontalAlignment="Left">
                                                <Image Source="{Binding ThumbnailUrl}"
                                                       Stretch="UniformToFill"
                                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                                            </Border>
 
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" MinWidth="0">
                                                <DockPanel LastChildFill="True">
                                                    <Border DockPanel.Dock="Right"
                                                            Background="{DynamicResource AccentContainerBrush}"
                                                            CornerRadius="4"
                                                            Padding="6,2"
                                                            Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                                         <TextBlock Text="{Binding Platform}"
                                                                    Style="{StaticResource TextCaption}"
                                                                    Foreground="{DynamicResource AccentBrush}"/>
                                                    </Border>
                                                    <TextBlock Text="{Binding Title, FallbackValue='解析中...'}"
                                                               Style="{StaticResource TextBodyStrong}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                </DockPanel>
                                                <Grid Margin="0,6,0,4">
                                                    <TextBlock Style="{StaticResource TextCaption}">
                                                        <Run Text="{Binding Status, Converter={StaticResource StatusToText}}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding FileSizeText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock HorizontalAlignment="Right" 
                                                               Style="{StaticResource TextCaption}" 
                                                               FontFamily="{StaticResource FontFamilyMono}"
                                                               Foreground="{DynamicResource AccentBrush}">
                                                        <Run Text="{Binding Progress, StringFormat={}{0:F0}}"/>
                                                        <Run Text="% · "/>
                                                        <Run Text="{Binding SpeedText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                </Grid>
                                                <ProgressBar Style="{StaticResource AccentProgressBar}"
                                                             Value="{Binding Progress}"
                                                             Maximum="100"
                                                             Height="5"/>
                                                <TextBlock Text="{Binding ErrorMessage}"
                                                           Style="{StaticResource TextCaption}"
                                                           Foreground="{StaticResource ErrorBrush}"
                                                           Margin="0,5,0,0"
                                                           TextTrimming="CharacterEllipsis"
                                                           Visibility="{Binding ErrorMessage, Converter={StaticResource StringToVisibility}}"/>
                                            </StackPanel>
 
                                            <StackPanel Grid.Column="2"
                                                        Orientation="Horizontal"
                                                        VerticalAlignment="Center"
                                                        Margin="16,0,0,0">
                                                <Button ToolTip="暂停"
                                                        AutomationProperties.Name="暂停任务"
                                                        Padding="8,5"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Resolving">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Merging">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="&#xE769;" Style="{StaticResource IconGlyph}" FontSize="{StaticResource IconSizeSmall}"/>
                                                </Button>
                                                <Button ToolTip="恢复"
                                                        AutomationProperties.Name="恢复任务"
                                                        Padding="8,5"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.ResumeTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}" FontSize="{StaticResource IconSizeSmall}"/>
                                                </Button>
                                                <Button ToolTip="重试"
                                                        AutomationProperties.Name="重试任务"
                                                        Padding="8,5"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        Margin="0,0,4,0"
                                                        Command="{Binding DataContext.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="&#xE72C;" Style="{StaticResource IconGlyph}" FontSize="{StaticResource IconSizeSmall}"/>
                                                </Button>
                                                <Button ToolTip="取消任务"
                                                        AutomationProperties.Name="取消任务"
                                                        Padding="8,5"
                                                        FontSize="{StaticResource FontSizeCaption}"
                                                        behaviors:Motion.AnimateRemove="True"
                                                        behaviors:Motion.RemoveCommand="{Binding DataContext.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        behaviors:Motion.RemoveParameter="{Binding Id}">
                                                    <Button.Style>
                                                        <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding Status}" Value="Waiting">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Resolving">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Merging">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Completed">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                                <DataTrigger Binding="{Binding Status}" Value="Cancelled">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Button.Style>
                                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}" FontSize="{StaticResource IconSizeSmall}"/>
                                                </Button>
                                            </StackPanel>
                                        </Grid>
                                    </Grid>
                                </Border>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>
                </Grid>
            </Border>
        </Grid>
 
        <Border Grid.Row="3"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,1,0,0"
                Padding="0,12,0,12"
                VerticalAlignment="Center">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}}" 
                               Style="{StaticResource TextBody}"
                               FontWeight="{StaticResource FontWeightSemiBold}"/>
                    <TextBlock Text="  ·  进行中任务: " 
                               Style="{StaticResource TextBody}"/>
                    <TextBlock Text="{Binding ActiveDownloadCount, Mode=OneWay}" 
                               Style="{StaticResource TextBody}"
                               FontWeight="{StaticResource FontWeightSemiBold}"
                               FontFamily="{StaticResource FontFamilyMono}"
                               Foreground="{DynamicResource AccentBrush}"/>
                </StackPanel>
                <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                    <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                    <TextBlock Text="{Binding DataContext.ToolStatusText, RelativeSource={RelativeSource AncestorType=Window}}" 
                               Style="{StaticResource TextBody}"/>
                </StackPanel>
            </DockPanel>
        </Border>
    </Grid>
</UserControl>

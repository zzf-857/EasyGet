<UserControl x:Class="EasyGet.Views.DouyinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True"
             Loaded="DouyinView_Loaded">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32" MaxWidth="980" HorizontalAlignment="Center">

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="抖音工作台"
                               Style="{StaticResource TextPageTitle}"/>
                    <TextBlock Text="面向抖音单作品、主页和合集的第一阶段专项下载入口。"
                               Style="{StaticResource TextBodyStrong}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <UniformGrid Grid.Column="1"
                             Columns="4"
                             VerticalAlignment="Center"
                             Margin="24,0,0,0">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="全部任务" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding DouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="进行中" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding ActiveDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="已完成" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding CompletedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="失败" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding FailedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE896;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="快速下载" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="22,20">
                    <StackPanel>
                        <TextBlock Text="粘贴抖音作品、用户主页、合集或音乐链接"
                                   Style="{StaticResource TextBodyStrong}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource BgPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,0"
                                    Margin="0,0,10,0">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Download.Url, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0,12"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="18,10"
                                    Margin="0,0,8,0"
                                    ToolTip="解析抖音链接"
                                    AutomationProperties.Name="解析抖音链接"
                                    Command="{Binding Download.ParseCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="解析" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource AccentButton}"
                                    Padding="20,10"
                                    ToolTip="开始抖音下载"
                                    AutomationProperties.Name="开始抖音下载"
                                    Command="{Binding Download.StartDownloadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="开始下载" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <Grid Margin="0,14,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="1.1*"/>
                                <ColumnDefinition Width="1.3*"/>
                                <ColumnDefinition Width="1.6*"/>
                            </Grid.ColumnDefinitions>

                            <StackPanel Grid.Column="0" Margin="0,0,18,0">
                                <TextBlock Text="格式 / 画质"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Style="{StaticResource TextBodyStrong}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0">
                                    <Run Text="{Binding Download.SelectedFormat, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding Download.SelectedQuality, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <StackPanel Grid.Column="1" Margin="0,0,18,0">
                                <TextBlock Text="输出目录"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Text="{Binding Download.DownloadDirectory, Mode=OneWay}"
                                           Style="{StaticResource TextBodyStrong}"
                                           TextTrimming="CharacterEllipsis"
                                           Margin="0,4,0,0"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2">
                                <TextBlock Text="抖音运行状态"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"/>
                                <TextBlock Style="{StaticResource TextBodyStrong}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0">
                                    <Run Text="{Binding DouyinQuickDownloadEngineStatusText, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding DouyinQuickDownloadCookieStatusText, Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding DouyinQuickDownloadProxyStatusText, Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE721;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="抖音发现" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="96"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Button Grid.Column="0"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="16,8"
                                    Margin="0,0,10,0"
                                    ToolTip="加载抖音热榜"
                                    AutomationProperties.Name="加载抖音热榜"
                                    Command="{Binding LoadDouyinHotBoardCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE9D9;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="热榜" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding DouyinDiscoveryKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="关键词搜索"
                                     AutomationProperties.Name="关键词搜索"
                                     Padding="10,8"
                                     Margin="0,0,10,0"/>

                            <TextBox Grid.Column="2"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding DouyinDiscoverySearchMax, UpdateSourceTrigger=LostFocus}"
                                     TextAlignment="Center"
                                     ToolTip="搜索结果数量"
                                     AutomationProperties.Name="搜索结果数量"
                                     Padding="10,8"
                                     Margin="0,0,10,0"/>

                            <Button Grid.Column="3"
                                    Style="{StaticResource AccentButton}"
                                    Padding="16,8"
                                    Margin="0,0,10,0"
                                    ToolTip="关键词搜索"
                                    AutomationProperties.Name="关键词搜索"
                                    Command="{Binding SearchDouyinDiscoveryCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="关键词搜索" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="16,8"
                                    Margin="0,0,10,0"
                                    ToolTip="把当前发现结果中可下载的条目全部加入队列"
                                    AutomationProperties.Name="全部加入下载队列"
                                    Command="{Binding AddAllDouyinDiscoveryItemsToQueueCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="全部入队" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <StackPanel Grid.Column="5"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <TextBlock Text="{Binding DouyinDiscoveryResultCount, Mode=OneWay, FallbackValue=0}"
                                           Style="{StaticResource TextBodyStrong}"
                                           Foreground="{DynamicResource AccentBrush}"
                                           FontFamily="{StaticResource FontFamilyMono}"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text=" 条"
                                           Style="{StaticResource TextCaption}"
                                           Margin="4,0,0,0"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0"
                                       Text="{Binding DouyinDiscoveryStatusText, Mode=OneWay}"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center"/>
                            <TextBlock Grid.Column="1"
                                       Text="正在加载"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Visibility="{Binding IsDouyinDiscoveryLoading, Converter={StaticResource BoolToVisibility}}"
                                       VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Text="筛选"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>

                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding DouyinDiscoveryFilterKeyword, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="筛选当前发现结果"
                                     AutomationProperties.Name="筛选当前发现结果"
                                     Padding="10,7"
                                     Margin="0,0,8,0"/>

                            <Button Grid.Column="2"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,6"
                                    Margin="0,0,12,0"
                                    ToolTip="清除发现结果筛选"
                                    AutomationProperties.Name="清除发现结果筛选"
                                    Command="{Binding ClearDouyinDiscoveryFilterCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="清除" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <TextBlock Grid.Column="3"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="显示 "/>
                                <Run Text="{Binding FilteredDouyinDiscoveryResultCount, Mode=OneWay, FallbackValue=0}"/>
                                <Run Text=" / "/>
                                <Run Text="{Binding DouyinDiscoveryResultCount, Mode=OneWay, FallbackValue=0}"/>
                                <Run Text=" 条"/>
                            </TextBlock>
                        </Grid>

                        <Grid Margin="0,0,0,12">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <TextBlock Grid.Column="0"
                                       Style="{StaticResource TextCaption}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       VerticalAlignment="Center">
                                <Run Text="已选择 "/>
                                <Run Text="{Binding SelectedDouyinDiscoveryItemCount, Mode=OneWay, FallbackValue=0}"/>
                                <Run Text=" 条"/>
                            </TextBlock>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    ToolTip="把选中的发现结果加入队列"
                                    AutomationProperties.Name="选中入队"
                                    IsEnabled="{Binding HasSelectedDouyinDiscoveryItems}"
                                    Command="{Binding AddSelectedDouyinDiscoveryItemsToQueueCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="选中入队" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    ToolTip="选择全部发现结果"
                                    AutomationProperties.Name="全选发现结果"
                                    Command="{Binding SelectAllDouyinDiscoveryItemsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73A;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="全选" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="3"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,6"
                                    Margin="0,0,8,0"
                                    ToolTip="只选择有 URL 或作品 ID 的发现结果"
                                    AutomationProperties.Name="选择可下载发现结果"
                                    Command="{Binding SelectDownloadableDouyinDiscoveryItemsCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="选择可下载" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="4"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,6"
                                    ToolTip="清除发现结果选择"
                                    AutomationProperties.Name="清除发现结果选择"
                                    Command="{Binding ClearDouyinDiscoverySelectionCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="清除选择" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>

                        <TextBlock Text="{Binding DouyinDiscoveryErrorMessage, Mode=OneWay}"
                                   Style="{StaticResource TextBodyStrong}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   TextWrapping="Wrap"
                                   Visibility="{Binding HasDouyinDiscoveryError, Converter={StaticResource BoolToVisibility}}"
                                   Margin="0,0,0,12"/>

                        <Grid MinHeight="150">
                            <StackPanel HorizontalAlignment="Center"
                                        VerticalAlignment="Center"
                                        Margin="0,24">
                                <StackPanel.Style>
                                    <Style TargetType="StackPanel">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding HasFilteredDouyinDiscoveryItems}" Value="False">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </StackPanel.Style>
                                <TextBlock Text="&#xE721;"
                                           Style="{StaticResource IconGlyph}"
                                           FontSize="{StaticResource IconSizeEmptyState}"
                                           Foreground="{StaticResource BorderPrimaryBrush}"
                                           HorizontalAlignment="Center"/>
                                <TextBlock HorizontalAlignment="Center"
                                           Margin="0,12,0,0">
                                    <TextBlock.Style>
                                        <Style TargetType="TextBlock" BasedOn="{StaticResource TextBodyStrong}">
                                            <Setter Property="Text" Value="暂无匹配结果"/>
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding HasDouyinDiscoveryItems}" Value="False">
                                                    <Setter Property="Text" Value="暂无发现结果"/>
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </TextBlock.Style>
                                </TextBlock>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding FilteredDouyinDiscoveryItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,8"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ToolPanelBorder}" Padding="12">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <CheckBox Grid.Column="0"
                                                          IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                          ToolTip="选择发现结果"
                                                          AutomationProperties.Name="选择发现结果"
                                                          VerticalAlignment="Top"
                                                          Margin="0,4,12,0"/>

                                                <StackPanel Grid.Column="1">
                                                    <TextBlock Style="{StaticResource TextBodyStrong}"
                                                               TextTrimming="CharacterEllipsis">
                                                        <Run Text="{Binding Word, Mode=OneWay}"/>
                                                        <Run Text="{Binding Description, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Style="{StaticResource TextCaption}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,5,0,0">
                                                        <Run Text="{Binding AuthorNickname, Mode=OneWay}"/>
                                                        <Run Text=" "/>
                                                        <Run Text="{Binding AwemeId, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Text="{Binding Url, Mode=OneWay}"
                                                               Style="{StaticResource TextCaption}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,5,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="2"
                                                            Margin="16,0,0,0"
                                                            VerticalAlignment="Center"
                                                            MinWidth="88">
                                                    <TextBlock Text="{Binding Position, Mode=OneWay, StringFormat=第 {0} 位}"
                                                               Style="{StaticResource TextCaption}"
                                                               HorizontalAlignment="Right"/>
                                                    <TextBlock Text="{Binding HotValue, Mode=OneWay, StringFormat=热度 {0:N0}}"
                                                               Style="{StaticResource TextCaption}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               HorizontalAlignment="Right"
                                                               Margin="0,4,0,0"/>
                                                    <Button Style="{StaticResource SurfaceButton}"
                                                            Command="{Binding DataContext.SearchDouyinDiscoveryItemWordCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="用该热榜词搜索"
                                                            AutomationProperties.Name="用该热榜词搜索"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,10,0,0"
                                                            Padding="10,5">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE721;" Style="{StaticResource IconGlyph}"
                                                                       FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="搜同词" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                    <Button Style="{StaticResource SurfaceButton}"
                                                            Command="{Binding DataContext.AddDouyinDiscoveryItemToQueueCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="加入下载队列"
                                                            AutomationProperties.Name="加入下载队列"
                                                            HorizontalAlignment="Right"
                                                            Margin="0,8,0,0"
                                                            Padding="10,5">
                                                        <StackPanel Orientation="Horizontal">
                                                            <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}"
                                                                       FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                                            <TextBlock Text="加入队列" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                                        </StackPanel>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8FD;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="任务中心" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <UniformGrid Columns="3">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="18,14" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" Style="{StaticResource IconGlyph}"
                                       Foreground="{DynamicResource AccentBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="当前专项任务" Style="{StaticResource TextCaption}"/>
                                <TextBlock Style="{StaticResource TextBodyStrong}">
                                    <Run Text="{Binding ActiveDouyinTaskCount, Mode=OneWay, FallbackValue=0}"/>
                                    <Run Text=" 个正在处理"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="18,14" Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"
                                       Foreground="{StaticResource SuccessBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="完成作品" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding CompletedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                           Style="{StaticResource TextBodyStrong}"
                                           FontFamily="{StaticResource FontFamilyMono}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>

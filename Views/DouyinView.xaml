                                                    Command="{Binding DataContext.SetDouyinArchiveAuthorFilterCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding AuthorName}"
                                                    ToolTip="{Binding AuthorName}"
                                                    AutomationProperties.Name="{Binding AuthorName}"
                                                    Margin="0,0,8,8"
                                                    Padding="10,5">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding AuthorName}" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                                    <TextBlock Text=" · " Style="{StaticResource TextCaption}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center"/>
                                                    <TextBlock Text="{Binding WorkCountText}" Style="{StaticResource TextCaption}" Foreground="{DynamicResource AccentBrush}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                            </Button>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>

                            <ListBox ItemsSource="{Binding DouyinHistoryItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ListBox.ItemsPanel>
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,14,14"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ToolPanelBorder}"
                                                Width="286"
                                                Padding="0"
                                                ClipToBounds="True"
                                                ToolTip="{Binding FilePath}">
                                            <StackPanel>
                                                <Border Height="150"
                                                        CornerRadius="12,12,0,0"
                                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailUrl}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="&#xEC4F;"
                                                                   Style="{StaticResource IconGlyph}"
                                                                   FontSize="{StaticResource IconSizeEmptyState}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   Opacity="0.22"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Background="{StaticResource ScrimHeavyBrush}"
                                                                CornerRadius="3"
                                                                Padding="5,2"
                                                                Margin="0,0,8,8">
                                                            <TextBlock Text="{Binding Quality}" Style="{StaticResource TextCaption}"/>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Margin="14,12,14,14">
                                                    <TextBlock Text="{Binding Title}"
                                                               Style="{StaticResource TextBodyStrong}"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <Grid Margin="0,8,0,0">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Grid.Column="0" Style="{StaticResource TextCaption}">
                                                            <Run Text="{Binding FileSizeText, Mode=OneWay}"/>
                                                            <Run Text=" · "/>
                                                            <Run Text="{Binding DownloadTimeText, Mode=OneWay}"/>
                                                        </TextBlock>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Format}"
                                                                   Style="{StaticResource TextCaption}"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE713;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="专项设置" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用专项引擎" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="抖音链接优先走专项引擎，保留全局下载引擎作为回退。"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="用户作品模式" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="用户主页可用逗号组合，例如 like,mix,music；收藏模式需单独使用。"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Settings.DouyinModeOptions}"
                                      Text="{Binding Settings.DouyinMode, UpdateSourceTrigger=LostFocus}"
                                      IsEditable="True"
                                      IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载数量上限" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="0 表示不限制，主要用于用户主页批量。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinLimit, UpdateSourceTrigger=LostFocus}"
                                     IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="文件名模板" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="控制媒体文件名，必须包含 {id}。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Settings.DouyinFilenameTemplate, UpdateSourceTrigger=LostFocus}"
                                         IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                                <TextBlock Text="{Binding Settings.DouyinFilenameTemplatePreviewText, Mode=OneWay}"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="作品文件夹模板" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="控制每个作品子文件夹，必须包含 {id}。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Settings.DouyinFolderTemplate, UpdateSourceTrigger=LostFocus}"
                                         IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                                <TextBlock Text="{Binding Settings.DouyinFolderTemplatePreviewText, Mode=OneWay}"
                                           Style="{StaticResource TextCaption}"
                                           Foreground="{StaticResource TextMutedBrush}"
                                           TextWrapping="Wrap"
                                           Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>

                        <TextBlock Text="{Binding Settings.DouyinTemplateVariablesText, Mode=OneWay}"
                                   Style="{StaticResource TextCaption}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   TextWrapping="Wrap"
                                   Margin="0,0,0,16"/>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="作者目录命名" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="选择作者层级目录使用昵称、sec_uid 或组合命名。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Settings.DouyinAuthorDirectoryModeOptions}"
                                      SelectedItem="{Binding Settings.DouyinAuthorDirectoryMode, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                      IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="按模式分层目录" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="在作者目录下按 post、like、mix、music 等模式分组。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinGroupByMode}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="开始时间"
                                       Style="{StaticResource TextBodyStrong}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinStartTime, UpdateSourceTrigger=LostFocus}"
                                     IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="结束时间"
                                       Style="{StaticResource TextBodyStrong}"
                                       VerticalAlignment="Center"/>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinEndTime, UpdateSourceTrigger=LostFocus}"
                                     IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="包含置顶作品" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="主页批量下载时同时纳入置顶内容。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadPinned}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用本地去重数据库" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="在下载目录下维护本地记录，减少重复下载。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinEnableDatabase}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="增量下载" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="仅对主页、合集等批量模式生效，依赖本地去重数据库。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding Settings.DouyinIncrementalDownload}"
                                          VerticalAlignment="Center">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleSwitch}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Settings.EnableDouyinSpecialEngine}" Value="True"/>
                                                    <Condition Binding="{Binding Settings.DouyinEnableDatabase}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载封面" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="作为附加资源保存到作品目录。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadCover}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载作者头像" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="作为附加资源保存到作品目录。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadAvatar}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载评论" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="作为附加数据保存到作品目录。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadComments}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="包含二级回复" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="会增加额外请求量，仅在下载评论开启时生效。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          IsChecked="{Binding Settings.DouyinCommentIncludeReplies}"
                                          VerticalAlignment="Center">
                                <ToggleButton.Style>
                                    <Style TargetType="ToggleButton" BasedOn="{StaticResource ToggleSwitch}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Settings.EnableDouyinSpecialEngine}" Value="True"/>
                                                    <Condition Binding="{Binding Settings.DouyinDownloadComments}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ToggleButton.Style>
                            </ToggleButton>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="评论数量上限" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="0 表示不限制。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinMaxComments, UpdateSourceTrigger=LostFocus}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Settings.EnableDouyinSpecialEngine}" Value="True"/>
                                                    <Condition Binding="{Binding Settings.DouyinDownloadComments}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="120"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="评论分页大小" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="1-20，默认 20。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinCommentPageSize, UpdateSourceTrigger=LostFocus}">
                                <TextBox.Style>
                                    <Style TargetType="TextBox" BasedOn="{StaticResource DarkTextBox}">
                                        <Setter Property="IsEnabled" Value="False"/>
                                        <Style.Triggers>
                                            <MultiDataTrigger>
                                                <MultiDataTrigger.Conditions>
                                                    <Condition Binding="{Binding Settings.EnableDouyinSpecialEngine}" Value="True"/>
                                                    <Condition Binding="{Binding Settings.DouyinDownloadComments}" Value="True"/>
                                                </MultiDataTrigger.Conditions>
                                                <Setter Property="IsEnabled" Value="True"/>
                                            </MultiDataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBox.Style>
                            </TextBox>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载音乐" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="作为附加资源保存到作品目录。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadMusic}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="保存原始 JSON" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="用于排查解析结果和后续 manifest 对齐。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadJson}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>

                                                    <Button ToolTip="重试任务"
                                                            AutomationProperties.Name="重试任务"
                                                            Padding="8,5"
                                                            Margin="0,0,4,0"

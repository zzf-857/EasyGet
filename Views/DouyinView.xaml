                                                                                   Visibility="{Binding TagsText, Converter={StaticResource StringToVisibility}}"
                                                                                   Margin="0,4,0,0"/>
                                                                        <TextBlock Text="{Binding FileRoleSummaryText, Mode=OneWay}"
                                                                                   Style="{StaticResource TextCaption}"
                                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                                   TextTrimming="CharacterEllipsis"
                                                                                   ToolTip="{Binding FileNamesText, Mode=OneWay}"
                                                                                   Visibility="{Binding FileRoleSummaryText, Converter={StaticResource StringToVisibility}}"

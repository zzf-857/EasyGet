<UserControl x:Class="EasyGet.Views.DouyinView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="32,28,32,32" MaxWidth="980" HorizontalAlignment="Center">

            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <StackPanel>
                    <TextBlock Text="抖音工作台"
                               Style="{StaticResource TextPageTitle}"/>
                    <TextBlock Text="面向抖音单作品、主页和合集的第一阶段专项下载入口。"
                               Style="{StaticResource TextBodyStrong}"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               Margin="0,8,0,0"/>
                </StackPanel>

                <UniformGrid Grid.Column="1"
                             Columns="4"
                             VerticalAlignment="Center"
                             Margin="24,0,0,0">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="全部任务" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding DouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="进行中" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding ActiveDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                        <StackPanel>
                            <TextBlock Text="已完成" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding CompletedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{StaticResource SuccessBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10">
                        <StackPanel>
                            <TextBlock Text="失败" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding FailedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                       Style="{StaticResource TextCardTitle}"
                                       Foreground="{StaticResource ErrorBrush}"
                                       FontFamily="{StaticResource FontFamilyMono}"/>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </Grid>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE896;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBlock Text="快速下载" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="22,20">
                    <StackPanel>
                        <TextBlock Text="粘贴抖音作品、用户主页、合集或音乐链接"
                                   Style="{StaticResource TextBodyStrong}"
                                   Margin="0,0,0,10"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0"
                                    Background="{StaticResource BgPrimaryBrush}"
                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                    BorderThickness="1"
                                    CornerRadius="10"
                                    Padding="14,0"
                                    Margin="0,0,10,0">
                                <TextBox Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Download.Url, UpdateSourceTrigger=PropertyChanged}"
                                         Background="Transparent"
                                         BorderThickness="0"
                                         Padding="0,12"
                                         VerticalContentAlignment="Center"/>
                            </Border>

                            <Button Grid.Column="1"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="18,10"
                                    Margin="0,0,8,0"
                                    ToolTip="解析抖音链接"
                                    AutomationProperties.Name="解析抖音链接"
                                    Command="{Binding Download.ParseCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE721;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="解析" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>

                            <Button Grid.Column="2"
                                    Style="{StaticResource AccentButton}"
                                    Padding="20,10"
                                    ToolTip="开始抖音下载"
                                    AutomationProperties.Name="开始抖音下载"
                                    Command="{Binding Download.StartDownloadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}"
                                               FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="开始下载" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8FD;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="任务中心" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <UniformGrid Columns="3">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="18,14" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE9D9;" Style="{StaticResource IconGlyph}"
                                       Foreground="{DynamicResource AccentBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="当前专项任务" Style="{StaticResource TextCaption}"/>
                                <TextBlock Style="{StaticResource TextBodyStrong}">
                                    <Run Text="{Binding ActiveDouyinTaskCount, Mode=OneWay, FallbackValue=0}"/>
                                    <Run Text=" 个正在处理"/>
                                </TextBlock>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="18,14" Margin="4,0,4,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"
                                       Foreground="{StaticResource SuccessBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="完成作品" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding CompletedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                           Style="{StaticResource TextBodyStrong}"
                                           FontFamily="{StaticResource FontFamilyMono}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="18,14" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE783;" Style="{StaticResource IconGlyph}"
                                       Foreground="{StaticResource ErrorBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="异常任务" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding FailedDouyinTaskCount, Mode=OneWay, FallbackValue=0}"
                                           Style="{StaticResource TextBodyStrong}"
                                           FontFamily="{StaticResource FontFamilyMono}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="0" Margin="0,14,0,0" MinHeight="260">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,34,0,34">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DouyinTaskCount}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE896;"
                                       Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeEmptyState}"
                                       Foreground="{StaticResource BorderPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="暂无专项任务队列"
                                       Style="{StaticResource TextBodyStrong}"
                                       HorizontalAlignment="Center"
                                       Margin="0,14,0,0"/>
                            <TextBlock Text="抖音下载任务会在这里集中跟踪和操作"
                                       Style="{StaticResource TextBody}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <DockPanel Margin="16">
                            <StackPanel DockPanel.Dock="Top"
                                        Orientation="Horizontal"
                                        Margin="0,0,0,12">
                                <TextBlock Text="专项任务队列" Style="{StaticResource TextBodyStrong}"/>
                                <Border Background="{DynamicResource AccentMutedBrush}"
                                        CornerRadius="4"
                                        Padding="8,2"
                                        Margin="10,0,0,0"
                                        VerticalAlignment="Center">
                                    <TextBlock Style="{StaticResource TextCaption}">
                                        <Run Text="{Binding DouyinTaskCount, Mode=OneWay}"/>
                                        <Run Text=" 个任务"/>
                                    </TextBlock>
                                </Border>
                            </StackPanel>

                            <ListBox ItemsSource="{Binding DouyinTaskItems}"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                                <ListBox.ItemContainerStyle>
                                    <Style TargetType="ListBoxItem">
                                        <Setter Property="Padding" Value="0"/>
                                        <Setter Property="Margin" Value="0,0,0,10"/>
                                        <Setter Property="Template">
                                            <Setter.Value>
                                                <ControlTemplate TargetType="ListBoxItem">
                                                    <ContentPresenter/>
                                                </ControlTemplate>
                                            </Setter.Value>
                                        </Setter>
                                    </Style>
                                </ListBox.ItemContainerStyle>
                                <ListBox.ItemTemplate>
                                    <DataTemplate>
                                        <Border Style="{StaticResource ToolPanelBorder}" Padding="0">
                                            <Grid>
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="4"/>
                                                    <ColumnDefinition Width="96"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <Border Grid.Column="0"
                                                        Background="{DynamicResource AccentBrush}"
                                                        CornerRadius="8,0,0,8"/>

                                                <Border Grid.Column="1"
                                                        Height="76"
                                                        Margin="12,12,0,12"
                                                        CornerRadius="8"
                                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <Image Source="{Binding ThumbnailUrl}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <TextBlock Text="&#xE714;"
                                                                   Style="{StaticResource IconGlyph}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   FontSize="{StaticResource IconSizeLarge}"
                                                                   Opacity="0.28"
                                                                   HorizontalAlignment="Center"
                                                                   VerticalAlignment="Center"/>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Grid.Column="2" Margin="14,12,18,12">
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource TextBodyStrong}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Status}"
                                                                   Style="{StaticResource TextCaption}"
                                                                   Foreground="{DynamicResource AccentBrush}"
                                                                   Margin="12,0,0,0"/>
                                                    </Grid>

                                                    <TextBlock Text="{Binding Url}"
                                                               Style="{StaticResource TextCaption}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,4,0,8"/>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <ProgressBar Grid.Column="0"
                                                                     Style="{StaticResource AccentProgressBar}"
                                                                     Value="{Binding Progress}"
                                                                     Maximum="100"
                                                                     Height="5"
                                                                     VerticalAlignment="Center"/>
                                                        <TextBlock Grid.Column="1"
                                                                   Style="{StaticResource TextCaption}"
                                                                   FontFamily="{StaticResource FontFamilyMono}"
                                                                   Margin="12,0,0,0">
                                                            <Run Text="{Binding Progress, StringFormat={}{0:F0}}"/>
                                                            <Run Text="% · "/>
                                                            <Run Text="{Binding SpeedText, Mode=OneWay}"/>
                                                        </TextBlock>
                                                    </Grid>

                                                    <TextBlock Text="{Binding ErrorMessage}"
                                                               Style="{StaticResource TextCaption}"
                                                               Foreground="{StaticResource ErrorBrush}"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,7,0,0"/>
                                                </StackPanel>

                                                <StackPanel Grid.Column="3"
                                                            Orientation="Horizontal"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,14,0">
                                                    <Button ToolTip="暂停任务"
                                                            AutomationProperties.Name="暂停任务"
                                                            Padding="8,5"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding DataContext.Batch.PauseTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Resolving">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Downloading">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Merging">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE769;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>

                                                    <Button ToolTip="继续任务"
                                                            AutomationProperties.Name="继续任务"
                                                            Padding="8,5"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding DataContext.Batch.ResumeTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Paused">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>

                                                    <Button ToolTip="重试任务"
                                                            AutomationProperties.Name="重试任务"
                                                            Padding="8,5"
                                                            Margin="0,0,4,0"
                                                            Command="{Binding DataContext.Batch.RetryTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <Button.Style>
                                                            <Style TargetType="Button" BasedOn="{StaticResource SurfaceButton}">
                                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding Status}" Value="Failed">
                                                                        <Setter Property="Visibility" Value="Visible"/>
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </Button.Style>
                                                        <TextBlock Text="&#xE72C;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>

                                                    <Button Style="{StaticResource SurfaceButton}"
                                                            ToolTip="取消或移除任务"
                                                            AutomationProperties.Name="取消或移除任务"
                                                            Padding="8,5"
                                                            Command="{Binding DataContext.Batch.CancelTaskCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Id}">
                                                        <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </DataTemplate>
                                </ListBox.ItemTemplate>
                            </ListBox>
                        </DockPanel>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,26">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE8F9;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="作品档案" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="0" MinHeight="260">
                    <Grid>
                        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,42,0,42">
                            <StackPanel.Style>
                                <Style TargetType="StackPanel">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding DouyinHistoryItems.Count}" Value="0">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </StackPanel.Style>
                            <TextBlock Text="&#xE8A5;" Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeEmptyState}"
                                       Foreground="{StaticResource BorderPrimaryBrush}"
                                       HorizontalAlignment="Center"/>
                            <TextBlock Text="暂无抖音作品档案"
                                       Style="{StaticResource TextBodyStrong}"
                                       HorizontalAlignment="Center"
                                       Margin="0,14,0,0"/>
                            <TextBlock Text="完成下载后会在这里形成作品记录"
                                       Style="{StaticResource TextBody}"
                                       HorizontalAlignment="Center"
                                       Margin="0,4,0,0"/>
                        </StackPanel>

                        <ListBox ItemsSource="{Binding DouyinHistoryItems}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="16"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                            <ListBox.ItemsPanel>
                                <ItemsPanelTemplate>
                                    <WrapPanel/>
                                </ItemsPanelTemplate>
                            </ListBox.ItemsPanel>
                            <ListBox.ItemContainerStyle>
                                <Style TargetType="ListBoxItem">
                                    <Setter Property="Padding" Value="0"/>
                                    <Setter Property="Margin" Value="0,0,14,14"/>
                                    <Setter Property="Template">
                                        <Setter.Value>
                                            <ControlTemplate TargetType="ListBoxItem">
                                                <ContentPresenter/>
                                            </ControlTemplate>
                                        </Setter.Value>
                                    </Setter>
                                </Style>
                            </ListBox.ItemContainerStyle>
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Border Style="{StaticResource ToolPanelBorder}"
                                            Width="286"
                                            Padding="0"
                                            ClipToBounds="True"
                                            ToolTip="{Binding FilePath}">
                                        <StackPanel>
                                            <Border Height="150"
                                                    CornerRadius="12,12,0,0"
                                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                                    ClipToBounds="True">
                                                <Grid>
                                                    <Image Source="{Binding ThumbnailUrl}"
                                                           Stretch="UniformToFill"
                                                           RenderOptions.BitmapScalingMode="HighQuality"/>
                                                    <TextBlock Text="&#xEC4F;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeEmptyState}"
                                                               Foreground="{DynamicResource AccentBrush}"
                                                               Opacity="0.22"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <Border HorizontalAlignment="Right"
                                                            VerticalAlignment="Bottom"
                                                            Background="{StaticResource ScrimHeavyBrush}"
                                                            CornerRadius="3"
                                                            Padding="5,2"
                                                            Margin="0,0,8,8">
                                                        <TextBlock Text="{Binding Quality}" Style="{StaticResource TextCaption}"/>
                                                    </Border>
                                                </Grid>
                                            </Border>

                                            <StackPanel Margin="14,12,14,14">
                                                <TextBlock Text="{Binding Title}"
                                                           Style="{StaticResource TextBodyStrong}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <Grid Margin="0,8,0,0">
                                                    <Grid.ColumnDefinitions>
                                                        <ColumnDefinition Width="*"/>
                                                        <ColumnDefinition Width="Auto"/>
                                                    </Grid.ColumnDefinitions>
                                                    <TextBlock Grid.Column="0" Style="{StaticResource TextCaption}">
                                                        <Run Text="{Binding FileSizeText, Mode=OneWay}"/>
                                                        <Run Text=" · "/>
                                                        <Run Text="{Binding DownloadTimeText, Mode=OneWay}"/>
                                                    </TextBlock>
                                                    <TextBlock Grid.Column="1"
                                                               Text="{Binding Format}"
                                                               Style="{StaticResource TextCaption}"
                                                               Foreground="{DynamicResource AccentBrush}"/>
                                                </Grid>
                                            </StackPanel>
                                        </StackPanel>
                                    </Border>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </Grid>
                </Border>
            </StackPanel>

            <StackPanel Margin="0,0,0,12">
                <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                    <TextBlock Text="&#xE713;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeLarge}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,8,0"/>
                    <TextBlock Text="专项设置" Style="{StaticResource TextSection}"/>
                </StackPanel>

                <Border Style="{StaticResource ToolPanelBorder}" Padding="18">
                    <StackPanel>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="启用专项引擎" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="抖音链接优先走专项引擎，保留全局下载引擎作为回退。"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="220"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="用户作品模式" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="用于主页、合集、音乐或收藏类批量下载。"
                                           Style="{StaticResource TextBody}"
                                           TextWrapping="Wrap"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ComboBox Grid.Column="1"
                                      Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding Settings.DouyinModeOptions}"
                                      SelectedItem="{Binding Settings.DouyinMode}"
                                      IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="140"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载数量上限" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="0 表示不限制，主要用于用户主页批量。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     TextAlignment="Center"
                                     Text="{Binding Settings.DouyinLimit, UpdateSourceTrigger=LostFocus}"
                                     IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="260"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="文件名模板" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="控制媒体文件名，必须包含 {id}。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <TextBox Grid.Column="1"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding Settings.DouyinFilenameTemplate, UpdateSourceTrigger=LostFocus}"
                                     IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"/>
                        </Grid>

                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="下载评论" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="作为附加数据保存到作品目录。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadComments}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel>
                                <TextBlock Text="保存原始 JSON" Style="{StaticResource TextBodyStrong}"/>
                                <TextBlock Text="用于排查解析结果和后续 manifest 对齐。"
                                           Style="{StaticResource TextBody}"
                                           Margin="0,4,0,0"/>
                            </StackPanel>
                            <ToggleButton Grid.Column="1"
                                          Style="{StaticResource ToggleSwitch}"
                                          IsChecked="{Binding Settings.DouyinDownloadJson}"
                                          IsEnabled="{Binding Settings.EnableDouyinSpecialEngine}"
                                          VerticalAlignment="Center"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </StackPanel>

        </StackPanel>
    </ScrollViewer>
</UserControl>

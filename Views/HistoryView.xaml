<UserControl x:Class="EasyGet.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True"
             Loaded="HistoryView_Loaded"
             Unloaded="HistoryView_Unloaded">

    <Grid Margin="30,20,30,28">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Page identity and passive status -->
        <Grid Grid.Row="0" Margin="6,0,6,18">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="下载历史" Style="{StaticResource TextPageTitle}"/>
                <TextBlock Style="{StaticResource TextBody}" Margin="1,5,0,0"
                           MaxWidth="850" HorizontalAlignment="Left"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="共计 "/>
                    <Run Text="{Binding TotalHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 个已完成任务 · 当前显示 "/>
                    <Run Text="{Binding VisibleHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 条 · "/>
                    <Run Text="{Binding SelectedFolderTitle, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                <Border Background="{StaticResource BgSurfaceHighBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="12"
                        Padding="13,8"
                        Margin="0,0,8,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{DynamicResource AccentBrush}"
                                 Margin="0,0,8,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StorageStatusText}"
                                   Style="{StaticResource TextCaption}"
                                   FontWeight="{StaticResource FontWeightSemiBold}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " Style="{StaticResource TextCaption}"/>
                        <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}}"
                                   Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>
                <Button Style="{StaticResource ToolbarIconButton}"
                        ToolTip="清空下载历史"
                        AutomationProperties.Name="清空下载历史"
                        Command="{Binding ClearAllCommand}">
                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeBody}"/>
                </Button>
            </StackPanel>
        </Grid>

        <!-- Search and filter toolbar -->
        <Border Grid.Row="1"
                Style="{StaticResource ToolPanelBorder}"
                Padding="9"
                Margin="0,0,0,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="24"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border x:Name="HistorySearchBox"
                        Grid.Column="0"
                        Style="{StaticResource SearchFieldBorder}"
                        MaxWidth="520"
                        Height="40">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="&#xE721;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,0,8,0"/>
                        <TextBox Grid.Column="1"
                                 Style="{StaticResource DarkTextBox}"
                                 Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Padding="0,8"
                                 FontSize="{StaticResource FontSizeBody}"/>
                        <TextBlock Grid.Column="1"
                                   Text="搜索标题、平台、链接或合集名称"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding SearchKeyword}" Value="">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                        <DataTrigger Binding="{Binding SearchKeyword}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                </Border>

                <Border Grid.Column="2"
                        Background="{StaticResource BgSurfaceHighBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Padding="3">
                    <StackPanel Orientation="Horizontal">
                        <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                     IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=全部}"
                                     Command="{Binding SetMediaFilterCommand}"
                                     CommandParameter="全部"
                                     ToolTip="显示全部历史"
                                     AutomationProperties.Name="显示全部历史">
                            <TextBlock Text="全部"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                     IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=视频}"
                                     Command="{Binding SetMediaFilterCommand}"
                                     CommandParameter="视频"
                                     ToolTip="只显示视频历史"
                                     AutomationProperties.Name="只显示视频历史">
                            <TextBlock Text="视频"/>
                        </RadioButton>
                        <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                     IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=音频}"
                                     Command="{Binding SetMediaFilterCommand}"
                                     CommandParameter="音频"
                                     ToolTip="只显示音频历史"
                                     AutomationProperties.Name="只显示音频历史">
                            <TextBlock Text="音频"/>
                        </RadioButton>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>

        <!-- One coherent workspace for both custom and automatic folders -->
        <Border Grid.Row="2"
                Style="{StaticResource ToolPanelBorder}"
                Padding="18,16"
                Margin="0,0,0,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Button Margin="0,0,11,0"
                                Command="{Binding ReturnToHistoryRootCommand}"
                                ToolTip="返回历史首页"
                                AutomationProperties.Name="返回历史首页">
                            <Button.Style>
                                <Style TargetType="Button" BasedOn="{StaticResource ToolbarIconButton}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasActiveLocation}" Value="True">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Button.Style>
                            <TextBlock Text="&#xE72B;" Style="{StaticResource IconGlyph}"/>
                        </Button>
                        <Border Width="36" Height="36"
                                Background="{DynamicResource AccentContainerBrush}"
                                CornerRadius="10"
                                Margin="0,0,11,0">
                            <TextBlock Text="&#xE8B7;"
                                       Style="{StaticResource IconGlyph}"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="整理与批量管理" Style="{StaticResource TextSection}"/>
                            <TextBlock Text="{Binding WorkspaceSummaryText, Mode=OneWay}"
                                       Style="{StaticResource TextCaption}" Margin="0,2,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <ToggleButton x:Name="NewFolderToggle"
                                      Style="{StaticResource ToolbarToggleButton}"
                                      Width="78"
                                      ToolTip="新建整理文件夹"
                                      AutomationProperties.Name="新建整理文件夹"
                                      Checked="NewFolderToggle_Checked"
                                      Unchecked="NewFolderToggle_Unchecked">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}" Margin="0,0,6,0"/>
                                <TextBlock Text="新建" Style="{StaticResource TextBodyStrong}"/>
                            </StackPanel>
                        </ToggleButton>
                        <Button Style="{StaticResource SurfaceButton}"
                                Margin="8,0,0,0"
                                Padding="13,8"
                                IsEnabled="{Binding HasDisplayedHistoryCards}"
                                Command="{Binding SelectAllVisibleCommand}"
                                ToolTip="选择当前目录中的全部历史记录"
                                AutomationProperties.Name="全选当前目录">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73A;" Style="{StaticResource IconGlyph}" Margin="0,0,6,0"/>
                                <TextBlock Text="全选当前"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <Popup x:Name="NewFolderPopup"
                           PlacementTarget="{Binding ElementName=NewFolderToggle}"
                           Placement="Bottom"
                           HorizontalOffset="-224"
                           VerticalOffset="8"
                           AllowsTransparency="True"
                           PopupAnimation="Fade"
                           StaysOpen="False"
                           DataContext="{Binding DataContext, ElementName=NewFolderToggle}"
                           Opened="NewFolderPopup_Opened"
                           Closed="NewFolderPopup_Closed">
                        <Border Style="{StaticResource PopoverBorder}" Width="310">
                            <StackPanel>
                                <TextBlock Text="新建整理文件夹" Style="{StaticResource TextSection}"/>
                                <TextBlock Text="为零散下载创建一个自定义分类"
                                           Style="{StaticResource TextCaption}" Margin="0,4,0,14"/>
                                <Grid>
                                    <TextBox x:Name="NewFolderTextBox"
                                             MaxLength="40"
                                             Style="{StaticResource DarkTextBox}"
                                             Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}"
                                             ToolTip="输入新的整理文件夹名称"
                                             AutomationProperties.Name="新整理文件夹名称"
                                             PreviewKeyDown="NewFolderTextBox_PreviewKeyDown"/>
                                    <TextBlock Text="文件夹名称"
                                               Margin="12,0"
                                               VerticalAlignment="Center"
                                               IsHitTestVisible="False">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding NewFolderName}" Value="">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding NewFolderName}" Value="{x:Null}">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Grid>
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
                                    <Button Style="{StaticResource SurfaceButton}"
                                            Content="取消"
                                            Padding="14,7"
                                            Click="CancelNewFolderButton_Click"/>
                                    <Button Style="{StaticResource AccentButton}"
                                            Content="创建"
                                            Padding="16,7"
                                            Margin="8,0,0,0"
                                            Command="{Binding CreateFolderCommand}"
                                            Click="CreateFolderButton_Click"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Popup>
                </Grid>

                <Border Margin="0,13,0,12"
                        Padding="11,8"
                        Background="{DynamicResource AccentContainerBrush}"
                        CornerRadius="9"
                        Visibility="{Binding HasActiveLocation, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="当前目录" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding SelectedFolderTitle, Mode=OneWay}"
                                   Style="{StaticResource TextBodyStrong}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="8,0,0,0"
                                   MaxWidth="760"
                                   TextTrimming="CharacterEllipsis"/>
                    </StackPanel>
                </Border>

                <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,13,0,13"/>

                <ScrollViewer MaxHeight="238"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                    <StackPanel>
                        <TextBlock Text="我的整理"
                                   Style="{StaticResource TextCaption}"
                                   FontWeight="{StaticResource FontWeightSemiBold}"
                                   Margin="2,0,0,8"
                                   Visibility="{Binding HasHistoryFolders, Converter={StaticResource BoolToVisibility}}"/>

                        <ItemsControl ItemsSource="{Binding HistoryFolders}"
                                      Visibility="{Binding HasHistoryFolders, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,12,12"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="278" Height="94">
                                        <Border x:Name="FolderShadow"
                                                Style="{StaticResource FinderFolderBorder}"
                                                Effect="{StaticResource HoverShadow}"
                                                Opacity="0"/>
                                        <Border x:Name="FolderCard"
                                                AllowDrop="True"
                                                DragOver="HistoryFolder_DragOver"
                                                Drop="HistoryFolder_Drop"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="FolderTranslate" Y="0"/>
                                            </Border.RenderTransform>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource FinderFolderBorder}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="13,11"
                                                        Cursor="Hand"
                                                        HorizontalContentAlignment="Stretch"
                                                        Command="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="打开此整理视图；也可把历史卡片拖到这里">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="42" Height="42"
                                                                CornerRadius="11"
                                                                Background="{DynamicResource AccentContainerBrush}"
                                                                Margin="0,0,11,0">
                                                            <TextBlock Text="{Binding IconGlyph, Mode=OneWay}"
                                                                       Style="{StaticResource IconGlyph}"
                                                                       FontSize="{StaticResource IconSizeLarge}"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Style="{StaticResource TextBodyStrong}"
                                                                       MaxWidth="154"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding Caption, Mode=OneWay}"
                                                                       Style="{StaticResource TextCaption}"
                                                                       Margin="0,3,0,0"/>
                                                        </StackPanel>
                                                        <Border x:Name="FolderCountBadge"
                                                                Grid.Column="2"
                                                                Background="{StaticResource BgSurfaceBrush}"
                                                                CornerRadius="8"
                                                                Padding="7,3"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ItemCount, Mode=OneWay}"
                                                                       Style="{StaticResource TextCaption}"
                                                                       FontFamily="{StaticResource FontFamilyMono}"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>

                                                <StackPanel x:Name="FolderActionPanel"
                                                            Panel.ZIndex="10"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0"
                                                            Visibility="Collapsed">
                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                            Width="30" Height="30"
                                                            Command="{Binding DataContext.BeginRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="重命名文件夹"
                                                            AutomationProperties.Name="重命名文件夹">
                                                        <TextBlock Text="&#xE70F;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                            Width="30" Height="30" Margin="5,0,0,0"
                                                            Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="删除整理文件夹"
                                                            AutomationProperties.Name="删除整理文件夹">
                                                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                                                                   Foreground="{StaticResource ErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>

                                                <Border Panel.ZIndex="20"
                                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                                        BorderBrush="{DynamicResource AccentBrush}"
                                                        BorderThickness="1"
                                                        CornerRadius="12"
                                                        Padding="9">
                                                    <Border.Style>
                                                        <Style TargetType="Border">
                                                            <Setter Property="Visibility" Value="Collapsed"/>
                                                            <Style.Triggers>
                                                                <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                                    <Setter Property="Visibility" Value="Visible"/>
                                                                </DataTrigger>
                                                            </Style.Triggers>
                                                        </Style>
                                                    </Border.Style>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBox Style="{StaticResource DarkTextBox}"
                                                                 MaxLength="40" Padding="9,6"
                                                                 Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                                 IsVisibleChanged="FolderRenameTextBox_IsVisibleChanged"
                                                                 PreviewKeyDown="FolderRenameTextBox_PreviewKeyDown"/>
                                                        <Button Grid.Column="1"
                                                                Style="{StaticResource AccentButton}"
                                                                Width="30" Padding="0" Margin="5,0,0,0"
                                                                Command="{Binding DataContext.SaveRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="保存名称"
                                                                AutomationProperties.Name="保存文件夹名称">
                                                            <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"/>
                                                        </Button>
                                                        <Button Grid.Column="2"
                                                                Style="{StaticResource ToolbarIconButton}"
                                                                Width="30" Height="30" Margin="4,0,0,0"
                                                                Command="{Binding DataContext.CancelRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                CommandParameter="{Binding}"
                                                                ToolTip="取消重命名"
                                                                AutomationProperties.Name="取消重命名">
                                                            <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"/>
                                                        </Button>
                                                    </Grid>
                                                </Border>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="FolderCard" Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="FolderTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="-3"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="FolderShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0.8"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="FolderTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="FolderShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="FolderCountBadge" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="FolderActionPanel" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <StackPanel Margin="2,2,0,8"
                                    Visibility="{Binding HasBatchFolders, Converter={StaticResource BoolToVisibility}}">
                            <TextBlock Text="自动整理的批量文件夹"
                                       Style="{StaticResource TextCaption}"
                                       FontWeight="{StaticResource FontWeightSemiBold}"/>
                            <TextBlock Text="批量视频和合集会按视频列表自动收纳"
                                       Style="{StaticResource TextCaption}" Margin="0,2,0,0"/>
                        </StackPanel>

                        <ItemsControl ItemsSource="{Binding BatchFolderCards}"
                                      Visibility="{Binding HasBatchFolders, Converter={StaticResource BoolToVisibility}}">
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,12,12"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid Width="360" Height="104">
                                        <Border x:Name="BatchShadow"
                                                Style="{StaticResource FinderFolderBorder}"
                                                Effect="{StaticResource HoverShadow}"
                                                Opacity="0"/>
                                        <Border x:Name="BatchFolderCard"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="BatchTranslate" Y="0"/>
                                            </Border.RenderTransform>
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource FinderFolderBorder}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <Grid>
                                                <Button Background="Transparent"
                                                        BorderThickness="0"
                                                        Padding="14,12"
                                                        Cursor="Hand"
                                                        HorizontalContentAlignment="Stretch"
                                                        Command="{Binding DataContext.SelectBatchFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding}"
                                                        ToolTip="查看这个批量文件夹"
                                                        AutomationProperties.Name="打开批量文件夹">
                                                    <Button.Template>
                                                        <ControlTemplate TargetType="Button">
                                                            <Border Background="{TemplateBinding Background}" CornerRadius="12">
                                                                <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                                  HorizontalAlignment="Stretch"
                                                                                  VerticalAlignment="Center"/>
                                                            </Border>
                                                        </ControlTemplate>
                                                    </Button.Template>
                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="Auto"/>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <Border Width="48" Height="48"
                                                                CornerRadius="12"
                                                                Background="{DynamicResource AccentContainerBrush}"
                                                                Margin="0,0,12,0">
                                                            <TextBlock Text="&#xE838;"
                                                                       Style="{StaticResource IconGlyph}"
                                                                       FontSize="{StaticResource IconSizeLarge}"
                                                                       Foreground="{DynamicResource AccentBrush}"/>
                                                        </Border>
                                                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding Name}"
                                                                       Style="{StaticResource TextBodyStrong}"
                                                                       MaxWidth="224"
                                                                       MaxHeight="40"
                                                                       TextWrapping="Wrap"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                            <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                                                       Style="{StaticResource TextCaption}"
                                                                       MaxWidth="224"
                                                                       Margin="0,4,0,0"
                                                                       TextTrimming="CharacterEllipsis"/>
                                                        </StackPanel>
                                                        <Border x:Name="BatchCountBadge"
                                                                Grid.Column="2"
                                                                Background="{StaticResource BgSurfaceBrush}"
                                                                CornerRadius="8"
                                                                Padding="7,4"
                                                                VerticalAlignment="Center">
                                                            <TextBlock Text="{Binding ItemCount, Mode=OneWay}"
                                                                       Style="{StaticResource TextCaption}"
                                                                       FontFamily="{StaticResource FontFamilyMono}"/>
                                                        </Border>
                                                    </Grid>
                                                </Button>

                                                <StackPanel x:Name="BatchActionPanel"
                                                            Panel.ZIndex="10"
                                                            Orientation="Horizontal"
                                                            HorizontalAlignment="Right"
                                                            VerticalAlignment="Center"
                                                            Margin="0,0,10,0"
                                                            Visibility="Collapsed">
                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                            Width="30" Height="30"
                                                            Command="{Binding DataContext.SelectHistoryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="选择整组"
                                                            AutomationProperties.Name="选择整组">
                                                        <TextBlock Text="&#xE73A;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                            Width="30" Height="30" Margin="5,0,0,0"
                                                            Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding Directory}"
                                                            ToolTip="打开本地文件夹"
                                                            AutomationProperties.Name="打开本地文件夹">
                                                        <TextBlock Text="&#xE838;" Style="{StaticResource IconGlyph}"/>
                                                    </Button>
                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                            Width="30" Height="30" Margin="5,0,0,0"
                                                            Command="{Binding DataContext.DeleteBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                            CommandParameter="{Binding}"
                                                            ToolTip="删除整组历史记录"
                                                            AutomationProperties.Name="删除整组历史记录">
                                                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                                                                   Foreground="{StaticResource ErrorBrush}"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="BatchFolderCard" Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="BatchTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="-3"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="BatchShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0.8"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="BatchTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="BatchShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="BatchCountBadge" Property="Visibility" Value="Collapsed"/>
                                            <Setter TargetName="BatchActionPanel" Property="Visibility" Value="Visible"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>

                        <Border Padding="14,12"
                                Background="{StaticResource BgSurfaceHighBrush}"
                                CornerRadius="11">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding HasWorkspaceFolders}" Value="True">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}"
                                           Foreground="{DynamicResource AccentBrush}" Margin="0,0,8,0"/>
                                <TextBlock Text="批量视频会自动生成文件夹，也可以在右上角新建自定义分类"
                                           Style="{StaticResource TextCaption}"/>
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <!-- Media grid and empty states -->
        <Grid x:Name="HistoryContentHost" Grid.Row="3" RenderTransformOrigin="0.5,0.5">
            <Grid.RenderTransform>
                <TranslateTransform x:Name="HistoryContentTranslate" Y="0"/>
            </Grid.RenderTransform>

            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,32,0,84">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VisibleHistoryCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>
                <StackPanel x:Name="PureEmptyPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="68" Height="68" Background="{StaticResource BgSurfaceHighBrush}"
                            CornerRadius="20" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8F9;" Style="{StaticResource IconGlyph}"
                                   FontSize="{StaticResource IconSizePreview}" Foreground="{StaticResource TextMutedBrush}"/>
                    </Border>
                    <TextBlock Text="无下载历史" Style="{StaticResource TextSection}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="完成的下载会整齐地出现在这里" Style="{StaticResource TextBody}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                </StackPanel>

                <StackPanel x:Name="NoMatchPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <Border Width="68" Height="68" Background="{StaticResource BgSurfaceHighBrush}"
                            CornerRadius="20" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE11A;" Style="{StaticResource IconGlyph}"
                                   FontSize="{StaticResource IconSizePreview}" Foreground="{StaticResource TextMutedBrush}"/>
                    </Border>
                    <TextBlock Text="未找到匹配的记录" Style="{StaticResource TextSection}"
                               HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="尝试清除筛选或换一个搜索词" Style="{StaticResource TextBody}"
                               HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    <Button Style="{StaticResource AccentButton}"
                            Content="清除筛选"
                            Command="{Binding ClearFilterAndSearchCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Padding="16,7"
                            ToolTip="清除筛选与搜索"
                            AutomationProperties.Name="清除筛选与搜索"/>
                </StackPanel>
            </Grid>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,34,0,0"
                    Padding="16,12"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="12"
                    Visibility="{Binding ShouldShowFolderOnlyHint, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE838;" Style="{StaticResource IconGlyph}"
                               Foreground="{DynamicResource AccentBrush}" Margin="0,0,9,0"/>
                    <TextBlock Text="批量内容已收纳到上方文件夹，点击即可查看"
                               Style="{StaticResource TextBody}"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="HistoryList"
                     ItemsSource="{Binding HistoryGroups}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     ScrollViewer.PanningMode="VerticalOnly">
                <ListBox.Style>
                    <Style TargetType="ListBox">
                        <Setter Property="Margin" Value="0"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HasSelection}" Value="True">
                                <Setter Property="Margin" Value="0,0,0,78"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </ListBox.Style>
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate><StackPanel/></ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,2"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem"><ContentPresenter/></ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <ItemsControl ItemsSource="{Binding Items}">
                            <ItemsControl.Style>
                                <Style TargetType="ItemsControl">
                                    <Setter Property="Visibility" Value="Visible"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                            <Setter Property="Visibility" Value="Collapsed"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </ItemsControl.Style>
                            <ItemsControl.ItemsPanel>
                                <ItemsPanelTemplate><WrapPanel/></ItemsPanelTemplate>
                            </ItemsControl.ItemsPanel>
                            <ItemsControl.ItemContainerStyle>
                                <Style TargetType="ContentPresenter">
                                    <Setter Property="Margin" Value="0,0,16,18"/>
                                </Style>
                            </ItemsControl.ItemContainerStyle>
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Grid x:Name="HistoryCardRoot" Width="284" RenderTransformOrigin="0.5,0.5">
                                        <Grid.RenderTransform>
                                            <TranslateTransform x:Name="CardTranslate" Y="0"/>
                                        </Grid.RenderTransform>
                                        <Border x:Name="CardShadow"
                                                Style="{StaticResource MediaCardBorder}"
                                                Effect="{StaticResource HoverShadow}"
                                                Opacity="0"/>
                                        <Border x:Name="HistoryCard"
                                                Opacity="{Binding FileExists, Converter={StaticResource FileExistsToOpacity}}"
                                                ToolTip="{Binding FilePath}"
                                                ClipToBounds="True"
                                                Cursor="Hand"
                                                PreviewMouseLeftButtonDown="HistoryCard_PreviewMouseLeftButtonDown"
                                                PreviewMouseMove="HistoryCard_PreviewMouseMove"
                                                PreviewMouseLeftButtonUp="HistoryCard_PreviewMouseLeftButtonUp">
                                            <Border.Style>
                                                <Style TargetType="Border" BasedOn="{StaticResource MediaCardBorder}">
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                            <Setter Property="BorderThickness" Value="2"/>
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <StackPanel>
                                                <Border Height="160"
                                                        CornerRadius="14,14,0,0"
                                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                                        ClipToBounds="True">
                                                    <Grid>
                                                        <TextBlock Text="&#xEC4F;" Style="{StaticResource IconGlyph}"
                                                                   FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource TextMutedBrush}"
                                                                   Opacity="0.35"/>
                                                        <Image Source="{Binding ThumbnailUrl}"
                                                               Stretch="UniformToFill"
                                                               RenderOptions.BitmapScalingMode="HighQuality"/>
                                                        <CheckBox Style="{StaticResource CircularCheckBox}"
                                                                  IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                                  Panel.ZIndex="10"
                                                                  HorizontalAlignment="Left"
                                                                  VerticalAlignment="Top"
                                                                  Margin="10"
                                                                  ToolTip="选择此记录"
                                                                  AutomationProperties.Name="选择历史记录"/>
                                                        <Border HorizontalAlignment="Right"
                                                                VerticalAlignment="Bottom"
                                                                Background="{StaticResource ScrimHeavyBrush}"
                                                                CornerRadius="6"
                                                                Padding="6,3"
                                                                Margin="0,0,9,9">
                                                            <TextBlock Text="{Binding Quality}" Style="{StaticResource TextCaption}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </Border>
                                                        <Border x:Name="HoverOverlay"
                                                                Background="{StaticResource ScrimOverlayBrush}"
                                                                CornerRadius="14,14,0,0"
                                                                Opacity="0"
                                                                IsHitTestVisible="False">
                                                            <Border x:Name="QuickActionPill"
                                                                    HorizontalAlignment="Center"
                                                                    VerticalAlignment="Center"
                                                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                                                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                                                                    BorderThickness="1"
                                                                    CornerRadius="14"
                                                                    Padding="7">
                                                                <StackPanel Orientation="Horizontal">
                                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                                            Width="34" Height="34"
                                                                            ToolTip="打开文件夹"
                                                                            AutomationProperties.Name="打开文件夹"
                                                                            IsEnabled="{Binding FileExists}"
                                                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding AvailableFilePath}">
                                                                        <TextBlock Text="&#xE838;" Style="{StaticResource IconGlyph}"/>
                                                                    </Button>
                                                                    <Button Style="{StaticResource AccentButton}"
                                                                            Width="38" Height="34" Padding="0" Margin="6,0"
                                                                            ToolTip="预览文件"
                                                                            AutomationProperties.Name="预览文件"
                                                                            IsEnabled="{Binding FileExists}"
                                                                            Command="{Binding DataContext.PreviewFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding AvailableFilePath}">
                                                                        <TextBlock Text="&#xE768;" Style="{StaticResource IconGlyph}"/>
                                                                    </Button>
                                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                                            Width="34" Height="34"
                                                                            ToolTip="打开原网页"
                                                                            AutomationProperties.Name="打开原网页"
                                                                            IsEnabled="{Binding Url, Converter={StaticResource HttpUrlToBool}}"
                                                                            Command="{Binding DataContext.OpenSourceUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding Url}">
                                                                        <TextBlock Text="&#xE8A7;" Style="{StaticResource IconGlyph}"/>
                                                                    </Button>
                                                                    <Button Style="{StaticResource ToolbarIconButton}"
                                                                            Width="34" Height="34" Margin="6,0,0,0"
                                                                            ToolTip="删除记录"
                                                                            AutomationProperties.Name="删除记录"
                                                                            Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                                            CommandParameter="{Binding Id}">
                                                                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                                                                                   Foreground="{StaticResource ErrorBrush}"/>
                                                                    </Button>
                                                                </StackPanel>
                                                            </Border>
                                                        </Border>
                                                    </Grid>
                                                </Border>

                                                <StackPanel Margin="13,11,13,13">
                                                    <Grid Margin="0,0,0,8">
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <TextBlock Text="{Binding Title}"
                                                                   Style="{StaticResource TextBodyStrong}"
                                                                   TextTrimming="CharacterEllipsis"/>
                                                        <Border Grid.Column="1"
                                                                Background="{Binding Platform, Converter={StaticResource PlatformToColor}}"
                                                                CornerRadius="6"
                                                                Padding="6,2"
                                                                Margin="8,0,0,0"
                                                                Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                                            <TextBlock Text="{Binding Platform}"
                                                                       Style="{StaticResource TextCaption}"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                                                        </Border>
                                                    </Grid>

                                                    <StackPanel Orientation="Horizontal" Margin="0,0,0,8"
                                                                Visibility="{Binding HasOrganizerFolder, Converter={StaticResource BoolToVisibility}}">
                                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}"
                                                                   FontSize="{StaticResource IconSizeSmall}"
                                                                   Foreground="{DynamicResource AccentBrush}" Margin="0,0,5,0"/>
                                                        <TextBlock Text="{Binding OrganizerFolderName, Mode=OneWay}"
                                                                   Style="{StaticResource TextCaption}"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </StackPanel>

                                                    <Grid>
                                                        <Grid.ColumnDefinitions>
                                                            <ColumnDefinition Width="*"/>
                                                            <ColumnDefinition Width="Auto"/>
                                                        </Grid.ColumnDefinitions>
                                                        <StackPanel>
                                                            <StackPanel Orientation="Horizontal">
                                                                <TextBlock Text="&#xE792;" Style="{StaticResource IconGlyph}"
                                                                           FontSize="{StaticResource IconSizeSmall}"
                                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding FileSizeText, Mode=OneWay}"
                                                                           Style="{StaticResource TextCaption}" Margin="0,0,12,0"/>
                                                                <TextBlock Text="&#xE787;" Style="{StaticResource IconGlyph}"
                                                                           FontSize="{StaticResource IconSizeSmall}"
                                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding DownloadTimeText, Mode=OneWay}"
                                                                           Style="{StaticResource TextCaption}"/>
                                                            </StackPanel>
                                                            <StackPanel Orientation="Horizontal"
                                                                        Margin="0,6,0,0"
                                                                        ToolTip="附属文件摘要"
                                                                        Visibility="{Binding HasAttachmentSummary, Converter={StaticResource BoolToVisibility}}">
                                                                <TextBlock Text="&#xE8A5;" Style="{StaticResource IconGlyph}"
                                                                           FontSize="{StaticResource IconSizeSmall}"
                                                                           Foreground="{StaticResource TextMutedBrush}" Margin="0,0,4,0"/>
                                                                <TextBlock Text="{Binding AttachmentSummaryText, Mode=OneWay}"
                                                                           Style="{StaticResource TextCaption}"/>
                                                            </StackPanel>
                                                        </StackPanel>
                                                        <TextBlock Grid.Column="1"
                                                                   Text="{Binding Format}"
                                                                   Style="{StaticResource TextCaption}"
                                                                   Foreground="{DynamicResource AccentBrush}"/>
                                                    </Grid>
                                                </StackPanel>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="HistoryCard" Property="IsMouseOver" Value="True">
                                            <Trigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="-4"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0.85"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="1"
                                                                         Duration="{StaticResource MotionDurationFast}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.EnterActions>
                                            <Trigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetName="CardTranslate"
                                                                         Storyboard.TargetProperty="Y"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="CardShadow"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                        <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                                         Storyboard.TargetProperty="Opacity"
                                                                         To="0"
                                                                         Duration="{StaticResource MotionDurationMedium}"
                                                                         EasingFunction="{StaticResource MotionEaseOut}"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </Trigger.ExitActions>
                                            <Setter TargetName="HoverOverlay" Property="IsHitTestVisible" Value="True"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>

            <!-- Context appears only when selection exists and never reflows the media grid -->
            <Border Panel.ZIndex="60"
                    Style="{StaticResource FloatingActionBar}"
                    HorizontalAlignment="Center"
                    VerticalAlignment="Bottom"
                    Margin="0,0,0,16"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="28" Height="28" Background="{DynamicResource AccentBrush}"
                            CornerRadius="9" Margin="0,0,9,0">
                        <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                    </Border>
                    <TextBlock Text="{Binding SelectionSummaryText, Mode=OneWay}"
                               Style="{StaticResource TextBodyStrong}" VerticalAlignment="Center"/>
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="9,5" Margin="9,0,0,0"
                            Command="{Binding SelectAllVisibleCommand}" Content="全选"/>
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="9,5" Margin="6,0,0,0"
                            Command="{Binding ClearSelectionCommand}" Content="取消"/>

                    <Border Width="1" Height="24" Background="{StaticResource BorderPrimaryBrush}"
                            Margin="12,0"/>

                    <Grid Width="174">
                        <ComboBox Style="{StaticResource DarkComboBox}"
                                  ItemsSource="{Binding HistoryFolders}"
                                  DisplayMemberPath="Name"
                                  SelectedItem="{Binding BulkTargetFolder}"
                                  ToolTip="选择目标整理文件夹"/>
                        <TextBlock Text="选择目标文件夹"
                                   Margin="12,0"
                                   VerticalAlignment="Center"
                                   IsHitTestVisible="False">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding BulkTargetFolder}" Value="{x:Null}">
                                            <Setter Property="Visibility" Value="Visible"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                    </Grid>
                    <Button Style="{StaticResource SurfaceButton}"
                            Padding="10,6" Margin="7,0,0,0"
                            Command="{Binding MoveSelectedToFolderCommand}"
                            ToolTip="移动到选择的整理文件夹">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE8DE;" Style="{StaticResource IconGlyph}" Margin="0,0,5,0"/>
                            <TextBlock Text="移动"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Margin="7,0,0,0"
                            Command="{Binding RemoveSelectedFromFolderCommand}"
                            ToolTip="移回历史首页"
                            AutomationProperties.Name="移回历史首页">
                        <TextBlock Text="&#xE8DA;" Style="{StaticResource IconGlyph}"/>
                    </Button>
                    <Button Style="{StaticResource ToolbarIconButton}"
                            Margin="7,0,0,0"
                            Command="{Binding DeleteSelectedCommand}"
                            ToolTip="仅删除选中历史记录，不删除本地文件"
                            AutomationProperties.Name="删除选中历史记录">
                        <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                                   Foreground="{StaticResource ErrorBrush}"/>
                    </Button>
                </StackPanel>
            </Border>

            <Border Panel.ZIndex="70"
                    Background="{StaticResource ScrimHeavyBrush}"
                    CornerRadius="14"
                    Visibility="{Binding IsLoadingHistory, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="180" Height="5" IsIndeterminate="True"
                                 Style="{StaticResource AccentProgressBar}"/>
                    <TextBlock Text="正在整理下载历史…"
                               Style="{StaticResource TextBodyStrong}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</UserControl>

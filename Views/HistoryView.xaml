<UserControl x:Class="EasyGet.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True"
             Loaded="HistoryView_Loaded">

    <Grid Margin="32,20,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="32"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="HistorySearchBox"
                    Grid.Column="0"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="12,0"
                    MinWidth="620"
                    MaxWidth="620"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="14"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,8"
                             FontSize="13"/>
                </Grid>
            </Border>
            <Button Grid.Column="1"
                    Style="{StaticResource SurfaceButton}"
                    Margin="8,0,0,0"
                    ToolTip="清空下载历史"
                    AutomationProperties.Name="清空下载历史"
                    Command="{Binding ClearAllCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="清空记录" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="38,0,0,28">
            <StackPanel>
                <TextBlock Text="下载历史"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           FontSize="28"
                           FontWeight="SemiBold"/>
                <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                           FontSize="14"
                           Margin="0,4,0,0">
                    <Run Text="共计 "/>
                    <Run Text="{Binding TotalHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 个已完成任务"/>
                </TextBlock>
            </StackPanel>



            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=全部}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="全部"
                                 ToolTip="显示全部历史"
                                 AutomationProperties.Name="显示全部历史">
                        <TextBlock Text="全部"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=视频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="视频"
                                 ToolTip="只显示视频历史"
                                 AutomationProperties.Name="只显示视频历史">
                        <TextBlock Text="视频"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=音频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="音频"
                                 ToolTip="只显示音频历史"
                                 AutomationProperties.Name="只显示音频历史">
                        <TextBlock Text="音频"/>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,80">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HistoryItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- 纯空态：无任何下载历史记录 -->
                <StackPanel x:Name="PureEmptyPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE8F9;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="56" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="无下载历史" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="快去粘贴链接下载你喜欢的视频吧" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 无匹配态：有筛选或搜索但无匹配结果 -->
                <StackPanel x:Name="NoMatchPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE11A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                               FontSize="56" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="未找到匹配的记录" FontSize="16" Foreground="{StaticResource TextSecondaryBrush}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="尝试清除筛选或搜索词以显示全部历史" FontSize="12" Foreground="{StaticResource TextMutedBrush}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Button Style="{StaticResource AccentButton}"
                            Content="清除筛选"
                            Command="{Binding ClearFilterAndSearchCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Padding="16,6"
                            ToolTip="清除筛选与搜索"
                            AutomationProperties.Name="清除筛选与搜索"/>
                </StackPanel>
            </Grid>

            <ListBox ItemsSource="{Binding HistoryItems}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <WrapPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,22,22"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <Border x:Name="HistoryCard"
                                Style="{StaticResource ToolPanelBorder}"
                                Width="286"
                                Padding="0"
                                Opacity="{Binding FileExists, Converter={StaticResource FileExistsToOpacity}}"
                                ToolTip="{Binding FilePath}"
                                ClipToBounds="True">
                            <StackPanel>
                                <Border Height="162"
                                        CornerRadius="12,12,0,0"
                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image x:Name="ThumbnailImage"
                                               Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Effect>
                                                <BlurEffect x:Name="ThumbnailBlur" Radius="0"/>
                                            </Image.Effect>
                                        </Image>
                                        <TextBlock Text="&#xEC4F;"
                                                   FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontSize="44"
                                                   Opacity="0.22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="{StaticResource ScrimHeavyBrush}"
                                                CornerRadius="3"
                                                Padding="5,2"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{Binding Quality}" Foreground="{StaticResource ScrimLightBrush}" FontSize="10" FontWeight="Bold"/>
                                        </Border>
                                        <Border x:Name="HoverOverlay"
                                                Background="{StaticResource ScrimOverlayBrush}"
                                                CornerRadius="12,12,0,0"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="HoverOverlayTranslate" Y="6"/>
                                            </Border.RenderTransform>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="打开文件夹"
                                                        AutomationProperties.Name="打开文件夹"
                                                        IsEnabled="{Binding FileExists}"
                                                        Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding FilePath}">
                                                    <TextBlock Text="&#xE838;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource AccentButton}"
                                                        Width="42"
                                                        Height="42"
                                                        Padding="0"
                                                        Margin="10,0"
                                                        ToolTip="预览文件"
                                                        AutomationProperties.Name="预览文件"
                                                        IsEnabled="{Binding FileExists}"
                                                        Command="{Binding DataContext.PreviewFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding FilePath}">
                                                    <TextBlock Text="&#xE768;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="17"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        Margin="0,0,10,0"
                                                        ToolTip="打开原网页"
                                                        AutomationProperties.Name="打开原网页"
                                                        IsEnabled="{Binding Url, Converter={StaticResource HttpUrlToBool}}"
                                                        Command="{Binding DataContext.OpenSourceUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Url}">
                                                    <TextBlock Text="&#xE8A7;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="删除记录"
                                                        AutomationProperties.Name="删除记录"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <TextBlock Text="&#xE74D;"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="15"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="14,12,14,14">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   FontSize="13"
                                                   FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextPrimaryBrush}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1"
                                                Background="{Binding Platform, Converter={StaticResource PlatformToColor}}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                            <TextBlock Text="{Binding Platform}" FontSize="9"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontWeight="Bold"/>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0" Orientation="Horizontal">
                                            <TextBlock Text="&#xE792;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding FileSizeText, Mode=OneWay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       Margin="0,0,12,0"/>
                                            <TextBlock Text="&#xE787;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                            <TextBlock Text="{Binding DownloadTimeText, Mode=OneWay}"
                                                       FontSize="11"
                                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Format}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   FontWeight="Bold"/>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="HistoryCard" Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             From="6"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="7"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="6"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverOverlay" Property="IsHitTestVisible" Value="True"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

        <Border Grid.Row="3"
                HorizontalAlignment="Left"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1"
                CornerRadius="16"
                Padding="14,6">
            <StackPanel Orientation="Horizontal">
                <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                <TextBlock Text="{Binding StorageStatusText}" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10"/>
                <TextBlock Text="  ·  " Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
                <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}}" Foreground="{StaticResource TextMutedBrush}" FontSize="10"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>

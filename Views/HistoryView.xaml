<UserControl x:Class="EasyGet.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             Background="Transparent"
             behaviors:Motion.PageEnter="True"
             Loaded="HistoryView_Loaded">

    <Grid Margin="32,20,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="HistorySearchBox"
                    Grid.Column="0"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="12,0"
                    MinWidth="620"
                    MaxWidth="620"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeBody}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,8"
                             FontSize="{StaticResource FontSizeBodyStrong}"/>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Background="{StaticResource BgSurfaceHighBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    ClipToBounds="True">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="18,8,18,11">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StorageStatusText}" 
                                   Style="{StaticResource TextBody}"
                                   FontWeight="{StaticResource FontWeightSemiBold}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " 
                                   Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ProgressBar VerticalAlignment="Bottom"
                                 Height="3"
                                 Background="Transparent"
                                 Value="{Binding StorageFreePercentage, FallbackValue=0}"
                                 Maximum="100"
                                 BorderThickness="0"
                                 Opacity="0.55"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Margin="18,0,18,6"
                                 Validation.ErrorTemplate="{x:Null}"/>
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Style="{StaticResource SurfaceButton}"
                    VerticalAlignment="Center"
                    ToolTip="清空下载历史"
                    AutomationProperties.Name="清空下载历史"
                    Command="{Binding ClearAllCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="清空记录" Style="{StaticResource TextBodyStrong}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="38,0,0,28">
            <StackPanel>
                <TextBlock Text="下载历史"
                           Style="{StaticResource TextPageTitle}"/>
                <TextBlock Style="{StaticResource TextBodyStrong}"
                           Margin="0,4,0,0">
                    <Run Text="共计 "/>
                    <Run Text="{Binding TotalHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 个已完成任务"/>
                </TextBlock>
            </StackPanel>



            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=全部}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="全部"
                                 ToolTip="显示全部历史"
                                 AutomationProperties.Name="显示全部历史">
                        <TextBlock Text="全部"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=视频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="视频"
                                 ToolTip="只显示视频历史"
                                 AutomationProperties.Name="只显示视频历史">
                        <TextBlock Text="视频"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=音频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="音频"
                                 ToolTip="只显示音频历史"
                                 AutomationProperties.Name="只显示音频历史">
                        <TextBlock Text="音频"/>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <Grid Grid.Row="2">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,80">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding HistoryItems.Count}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- 纯空态：无任何下载历史记录 -->
                <StackPanel x:Name="PureEmptyPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE8F9;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="无下载历史" Style="{StaticResource TextSection}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="快去粘贴链接下载你喜欢的视频吧" Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 无匹配态：有筛选或搜索但无匹配结果 -->
                <StackPanel x:Name="NoMatchPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE11A;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="未找到匹配的记录" Style="{StaticResource TextSection}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="尝试清除筛选或搜索词以显示全部历史" Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Button Style="{StaticResource AccentButton}"
                            Content="清除筛选"
                            Command="{Binding ClearFilterAndSearchCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Padding="16,6"
                            ToolTip="清除筛选与搜索"
                            AutomationProperties.Name="清除筛选与搜索"/>
                </StackPanel>
            </Grid>

            <ListBox ItemsSource="{Binding HistoryGroups}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,22"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border Style="{StaticResource ToolPanelBorder}"
                                    Padding="10"
                                    Margin="0,0,0,12"
                                    Visibility="{Binding IsBatch, Converter={StaticResource BoolToVisibility}}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource SurfaceButton}"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.ToggleHistoryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="展开或收起这个批次"
                                            AutomationProperties.Name="展开或收起批次">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="&#xE8B7;"
                                                       Style="{StaticResource IconGlyph}"
                                                       FontSize="{StaticResource IconSizeLarge}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Margin="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource TextBodyStrong}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ExpandGlyph, Mode=OneWay}"
                                                       Style="{StaticResource TextBodyStrong}"
                                                       FontSize="{StaticResource IconSizeBody}"
                                                       Margin="14,0,4,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource SurfaceButton}"
                                            Width="40"
                                            Height="40"
                                            Padding="0"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Directory}"
                                            ToolTip="打开批次文件夹"
                                            AutomationProperties.Name="打开批次文件夹">
                                        <TextBlock Text="&#xE838;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeBody}"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SurfaceButton}"
                                            Width="40"
                                            Height="40"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            Command="{Binding DataContext.DeleteBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="删除整组历史记录"
                                            AutomationProperties.Name="删除整组历史记录">
                                        <TextBlock Text="&#xE74D;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeBody}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Margin" Value="0,0,22,0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                        <Border x:Name="HistoryCard"
                                Style="{StaticResource ToolPanelBorder}"
                                Width="286"
                                Padding="0"
                                Opacity="{Binding FileExists, Converter={StaticResource FileExistsToOpacity}}"
                                ToolTip="{Binding FilePath}"
                                ClipToBounds="True">
                            <StackPanel>
                                <Border Height="162"
                                        CornerRadius="12,12,0,0"
                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image x:Name="ThumbnailImage"
                                               Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Effect>
                                                <BlurEffect x:Name="ThumbnailBlur" Radius="0"/>
                                            </Image.Effect>
                                        </Image>
                                        <TextBlock Text="&#xEC4F;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeEmptyState}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Opacity="0.22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="{StaticResource ScrimHeavyBrush}"
                                                CornerRadius="3"
                                                Padding="5,2"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{Binding Quality}" Style="{StaticResource TextCaption}"/>
                                        </Border>
                                        <Border x:Name="HoverOverlay"
                                                Background="{StaticResource ScrimOverlayBrush}"
                                                CornerRadius="12,12,0,0"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="HoverOverlayTranslate" Y="6"/>
                                            </Border.RenderTransform>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="打开文件夹"
                                                        AutomationProperties.Name="打开文件夹"
                                                         IsEnabled="{Binding FileExists}"
                                                         Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding AvailableFilePath}">
                                                    <TextBlock Text="&#xE838;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource AccentButton}"
                                                        Width="42"
                                                        Height="42"
                                                        Padding="0"
                                                        Margin="10,0"
                                                        ToolTip="预览文件"
                                                        AutomationProperties.Name="预览文件"
                                                         IsEnabled="{Binding FileExists}"
                                                         Command="{Binding DataContext.PreviewFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding AvailableFilePath}">
                                                    <TextBlock Text="&#xE768;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeLarge}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        Margin="0,0,10,0"
                                                        ToolTip="打开原网页"
                                                        AutomationProperties.Name="打开原网页"
                                                        IsEnabled="{Binding Url, Converter={StaticResource HttpUrlToBool}}"
                                                        Command="{Binding DataContext.OpenSourceUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Url}">
                                                    <TextBlock Text="&#xE8A7;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="删除记录"
                                                        AutomationProperties.Name="删除记录"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <TextBlock Text="&#xE74D;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="14,12,14,14">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   Style="{StaticResource TextBodyStrong}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1"
                                                Background="{Binding Platform, Converter={StaticResource PlatformToColor}}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                            <TextBlock Text="{Binding Platform}" Style="{StaticResource TextCaption}"/>
                                        </Border>
                                    </Grid>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE792;" Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding FileSizeText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Text="&#xE787;" Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DownloadTimeText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,6,0,0"
                                                        ToolTip="附属文件摘要"
                                                        Visibility="{Binding HasAttachmentSummary, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE8A5;"
                                                           Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding AttachmentSummaryText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Format}"
                                                   Style="{StaticResource TextCaption}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="HistoryCard" Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             From="6"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="7"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="6"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverOverlay" Property="IsHitTestVisible" Value="True"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
        </Grid>

    </Grid>
</UserControl>

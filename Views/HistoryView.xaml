<UserControl x:Class="EasyGet.Views.HistoryView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
              Background="Transparent"
              behaviors:Motion.PageEnter="True"
              Loaded="HistoryView_Loaded"
              Unloaded="HistoryView_Unloaded">

    <Grid Margin="32,20,32,32">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,24">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Border x:Name="HistorySearchBox"
                    Grid.Column="0"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="20"
                    Padding="12,0"
                    MinWidth="620"
                    MaxWidth="620"
                    HorizontalAlignment="Left">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <TextBlock Grid.Column="0"
                               Text="&#xE721;"
                               Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeBody}"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,8,0"
                               VerticalAlignment="Center"/>
                    <TextBox Grid.Column="1"
                             Style="{StaticResource DarkTextBox}"
                             Text="{Binding SearchKeyword, UpdateSourceTrigger=PropertyChanged}"
                             Background="Transparent"
                             BorderThickness="0"
                             Padding="0,8"
                             FontSize="{StaticResource FontSizeBodyStrong}"/>
                    <TextBlock Grid.Column="1"
                               Text="搜索标题、平台、链接或合集名称"
                               Foreground="{StaticResource TextMutedBrush}"
                               Margin="0,0,0,0"
                               VerticalAlignment="Center"
                               IsHitTestVisible="False">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                <Setter Property="Visibility" Value="Collapsed"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding SearchKeyword}" Value="">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                    <DataTrigger Binding="{Binding SearchKeyword}" Value="{x:Null}">
                                        <Setter Property="Visibility" Value="Visible"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                </Grid>
            </Border>

            <Border Grid.Column="1"
                    HorizontalAlignment="Right"
                    VerticalAlignment="Center"
                    Margin="0,0,16,0"
                    Background="{StaticResource BgSurfaceHighBrush}"
                    BorderBrush="{StaticResource BorderPrimaryBrush}"
                    BorderThickness="1"
                    CornerRadius="18"
                    ClipToBounds="True">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="18,8,18,11">
                        <Ellipse Width="8" Height="8" Fill="{DynamicResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding StorageStatusText}" 
                                   Style="{StaticResource TextBody}"
                                   FontWeight="{StaticResource FontWeightSemiBold}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="  ·  " 
                                   Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"/>
                        <TextBlock Text="{Binding DataContext.AppVersion, RelativeSource={RelativeSource AncestorType=Window}}" 
                                   Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                    <ProgressBar VerticalAlignment="Bottom"
                                 Height="3"
                                 Background="Transparent"
                                 Value="{Binding StorageFreePercentage, FallbackValue=0}"
                                 Maximum="100"
                                 BorderThickness="0"
                                 Opacity="0.55"
                                 Foreground="{DynamicResource AccentBrush}"
                                 Margin="18,0,18,6"
                                 Validation.ErrorTemplate="{x:Null}"/>
                </Grid>
            </Border>

            <Button Grid.Column="2"
                    Style="{StaticResource SurfaceButton}"
                    VerticalAlignment="Center"
                    ToolTip="清空下载历史"
                    AutomationProperties.Name="清空下载历史"
                    Command="{Binding ClearAllCommand}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE74D;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                    <TextBlock Text="清空记录" Style="{StaticResource TextBodyStrong}" VerticalAlignment="Center"/>
                </StackPanel>
            </Button>
        </Grid>

        <Grid Grid.Row="1" Margin="38,0,0,28">
            <StackPanel>
                <TextBlock Text="下载历史"
                           Style="{StaticResource TextPageTitle}"/>
                <TextBlock Style="{StaticResource TextBodyStrong}"
                           Margin="0,4,0,0"
                           MaxWidth="900"
                           HorizontalAlignment="Left"
                           TextTrimming="CharacterEllipsis">
                    <Run Text="共计 "/>
                    <Run Text="{Binding TotalHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 个已完成任务 · 当前目录 "/>
                    <Run Text="{Binding VisibleHistoryCount, Mode=OneWay}"/>
                    <Run Text=" 条 · "/>
                    <Run Text="{Binding SelectedFolderTitle, Mode=OneWay}"/>
                </TextBlock>
            </StackPanel>



            <Border HorizontalAlignment="Right"
                    VerticalAlignment="Top"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="9"
                    Padding="4">
                <StackPanel Orientation="Horizontal">
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=全部}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="全部"
                                 ToolTip="显示全部历史"
                                 AutomationProperties.Name="显示全部历史">
                        <TextBlock Text="全部"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=视频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="视频"
                                 ToolTip="只显示视频历史"
                                 AutomationProperties.Name="只显示视频历史">
                        <TextBlock Text="视频"/>
                    </RadioButton>
                    <RadioButton Style="{StaticResource HistoryFilterRadioButton}"
                                 Margin="4,0,0,0"
                                 IsChecked="{Binding SelectedMediaFilter, Converter={StaticResource EqualsToBoolConverter}, ConverterParameter=音频}"
                                 Command="{Binding SetMediaFilterCommand}"
                                 CommandParameter="音频"
                                 ToolTip="只显示音频历史"
                                 AutomationProperties.Name="只显示音频历史">
                        <TextBlock Text="音频"/>
                    </RadioButton>
                </StackPanel>
            </Border>
        </Grid>

        <Border Grid.Row="2"
                Style="{StaticResource ToolPanelBorder}"
                Padding="18,16"
                Margin="0,0,0,16">
            <StackPanel>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="38" Height="38"
                                Background="{DynamicResource AccentContainerBrush}"
                                CornerRadius="10"
                                Margin="0,0,12,0">
                            <TextBlock Text="&#xE8B7;"
                                       Style="{StaticResource IconGlyph}"
                                       FontSize="{StaticResource IconSizeLarge}"
                                       Foreground="{DynamicResource AccentBrush}"/>
                        </Border>
                        <StackPanel>
                            <TextBlock Text="整理与批量管理" Style="{StaticResource TextCardTitle}"/>
                            <TextBlock Text="{Binding WorkspaceSummaryText, Mode=OneWay}"
                                       Style="{StaticResource TextCaption}"
                                       Margin="0,3,0,0"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="220">
                            <TextBox MaxLength="40"
                                     Style="{StaticResource DarkTextBox}"
                                     Text="{Binding NewFolderName, UpdateSourceTrigger=PropertyChanged}"
                                     ToolTip="输入新的整理文件夹名称"
                                     AutomationProperties.Name="新整理文件夹名称">
                                <TextBox.InputBindings>
                                    <KeyBinding Key="Enter" Command="{Binding CreateFolderCommand}"/>
                                </TextBox.InputBindings>
                            </TextBox>
                            <TextBlock Text="输入文件夹名称"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextBody}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding NewFolderName}" Value="">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding NewFolderName}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Style="{StaticResource AccentButton}"
                                Margin="8,0,0,0"
                                Padding="14,8"
                                Command="{Binding CreateFolderCommand}"
                                ToolTip="创建整理文件夹"
                                AutomationProperties.Name="创建整理文件夹">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" Style="{StaticResource IconGlyph}" Margin="0,0,6,0"/>
                                <TextBlock Text="新建"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SurfaceButton}"
                                Margin="8,0,0,0"
                                Padding="14,8"
                                IsEnabled="{Binding HasDisplayedHistoryCards}"
                                Command="{Binding SelectAllVisibleCommand}"
                                ToolTip="选择当前目录中的全部历史记录"
                                AutomationProperties.Name="全选当前目录">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE73A;" Style="{StaticResource IconGlyph}" Margin="0,0,6,0"/>
                                <TextBlock Text="全选当前"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <Border Height="1"
                        Background="{StaticResource BorderSubtleBrush}"
                        Margin="0,14,0,14"/>

                <Border Margin="0,0,0,14"
                        Padding="12,10"
                        Background="{DynamicResource AccentContainerBrush}"
                        BorderBrush="{DynamicResource AccentBrush}"
                        BorderThickness="1"
                        CornerRadius="10"
                        Visibility="{Binding HasActiveLocation, Converter={StaticResource BoolToVisibility}}">
                    <Grid>
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="&#xE72B;"
                                       Style="{StaticResource IconGlyph}"
                                       Foreground="{DynamicResource AccentBrush}"
                                       Margin="0,0,8,0"/>
                            <TextBlock Text="当前目录：" Style="{StaticResource TextCaption}"/>
                            <TextBlock Text="{Binding SelectedFolderTitle, Mode=OneWay}"
                                       Style="{StaticResource TextBodyStrong}"
                                       Margin="4,0,0,0"
                                       MaxWidth="660"
                                       TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                        <Button Style="{StaticResource SurfaceButton}"
                                HorizontalAlignment="Right"
                                Padding="12,6"
                                Command="{Binding ReturnToHistoryRootCommand}"
                                Content="返回历史首页"
                                AutomationProperties.Name="返回历史首页"/>
                    </Grid>
                </Border>

                <ScrollViewer MaxHeight="286"
                              VerticalScrollBarVisibility="Auto"
                              HorizontalScrollBarVisibility="Disabled"
                              CanContentScroll="False"
                              PanningMode="VerticalOnly">
                <StackPanel>
                <StackPanel Margin="0,0,0,8"
                            Visibility="{Binding HasHistoryFolders, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="我的整理"
                               Style="{StaticResource TextBodyStrong}"
                               Margin="2,0,0,9"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding HistoryFolders}"
                              Visibility="{Binding HasHistoryFolders, Converter={StaticResource BoolToVisibility}}"
                              HorizontalContentAlignment="Stretch">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,10,10"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="FolderCard"
                                    Width="268"
                                    Height="92"
                                    AllowDrop="True"
                                    DragOver="HistoryFolder_DragOver"
                                    Drop="HistoryFolder_Drop">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgSurfaceHighBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="11"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgSurfaceHighestBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="12,10"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.SelectFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="打开此整理视图；也可把历史卡片拖到这里">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="10">
                                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                             <Border Width="40" Height="40"
                                                    CornerRadius="9"
                                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                                    Margin="0,0,10,0">
                                                <TextBlock Text="{Binding IconGlyph, Mode=OneWay}"
                                                           Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                 <TextBlock Text="{Binding Name}"
                                                            Style="{StaticResource TextBodyStrong}"
                                                            MaxWidth="148"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding Caption, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           Margin="0,2,0,0"/>
                                            </StackPanel>
                                            <Border x:Name="FolderCountBadge"
                                                    Grid.Column="2"
                                                    Background="{StaticResource BgSurfaceBrush}"
                                                    CornerRadius="8"
                                                    Padding="7,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ItemCount, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           FontFamily="{StaticResource FontFamilyMono}"/>
                                            </Border>
                                        </Grid>
                                    </Button>

                                    <StackPanel x:Name="FolderActionPanel"
                                                Panel.ZIndex="10"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0"
                                                Visibility="Collapsed">
                                        <Button Style="{StaticResource SurfaceButton}"
                                                Width="30" Height="30" Padding="0"
                                                Command="{Binding DataContext.BeginRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="重命名文件夹">
                                            <TextBlock Text="&#xE70F;" Style="{StaticResource IconGlyph}"/>
                                        </Button>
                                        <Button Style="{StaticResource SurfaceButton}"
                                                Width="30" Height="30" Padding="0" Margin="5,0,0,0"
                                                Command="{Binding DataContext.DeleteFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="删除整理文件夹">
                                            <TextBlock Text="&#xE74D;"
                                                       Style="{StaticResource IconGlyph}"
                                                       Foreground="{StaticResource ErrorBrush}"/>
                                        </Button>
                                    </StackPanel>

                                    <Border Panel.ZIndex="20"
                                            Background="{StaticResource BgSurfaceHighestBrush}"
                                            BorderBrush="{DynamicResource AccentBrush}"
                                            BorderThickness="1"
                                            CornerRadius="10"
                                            Padding="9">
                                        <Border.Style>
                                            <Style TargetType="Border">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsRenaming}" Value="True">
                                                        <Setter Property="Visibility" Value="Visible"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Border.Style>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBox Style="{StaticResource DarkTextBox}"
                                                     MaxLength="40"
                                                     Padding="9,6"
                                                     Text="{Binding EditName, UpdateSourceTrigger=PropertyChanged}"
                                                     IsVisibleChanged="FolderRenameTextBox_IsVisibleChanged"
                                                     PreviewKeyDown="FolderRenameTextBox_PreviewKeyDown"/>
                                            <Button Grid.Column="1"
                                                    Style="{StaticResource AccentButton}"
                                                    Width="30" Padding="0" Margin="5,0,0,0"
                                                    Command="{Binding DataContext.SaveRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="保存名称">
                                                <TextBlock Text="&#xE73E;" Style="{StaticResource IconGlyph}"/>
                                            </Button>
                                            <Button Grid.Column="2"
                                                    Style="{StaticResource SurfaceButton}"
                                                    Width="30" Padding="0" Margin="4,0,0,0"
                                                    Command="{Binding DataContext.CancelRenameFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                    CommandParameter="{Binding}"
                                                    ToolTip="取消重命名">
                                                <TextBlock Text="&#xE711;" Style="{StaticResource IconGlyph}"/>
                                            </Button>
                                        </Grid>
                                    </Border>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="FolderCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="FolderCountBadge" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="FolderActionPanel" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <StackPanel Margin="0,8,0,8"
                            Visibility="{Binding HasBatchFolders, Converter={StaticResource BoolToVisibility}}">
                    <TextBlock Text="自动整理的批量文件夹"
                               Style="{StaticResource TextBodyStrong}"
                               Margin="2,0,0,2"/>
                    <TextBlock Text="批量视频和合集会自动归入这里，点击文件夹查看内容"
                               Style="{StaticResource TextCaption}"
                               Margin="2,0,0,0"/>
                </StackPanel>

                <ItemsControl ItemsSource="{Binding BatchFolderCards}"
                              Visibility="{Binding HasBatchFolders, Converter={StaticResource BoolToVisibility}}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                    <ItemsControl.ItemContainerStyle>
                        <Style TargetType="ContentPresenter">
                            <Setter Property="Margin" Value="0,0,12,12"/>
                        </Style>
                    </ItemsControl.ItemContainerStyle>
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border x:Name="BatchFolderCard"
                                    Width="600"
                                    Height="124">
                                <Border.Style>
                                    <Style TargetType="Border">
                                        <Setter Property="Background" Value="{StaticResource BgSurfaceHighBrush}"/>
                                        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                                        <Setter Property="BorderThickness" Value="1"/>
                                        <Setter Property="CornerRadius" Value="12"/>
                                        <Style.Triggers>
                                            <Trigger Property="IsMouseOver" Value="True">
                                                <Setter Property="Background" Value="{StaticResource BgSurfaceHighestBrush}"/>
                                                <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
                                            </Trigger>
                                            <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                                <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                                <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                                <Setter Property="BorderThickness" Value="2"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>

                                <Grid>
                                    <Button Background="Transparent"
                                            BorderThickness="0"
                                            Padding="14,12"
                                            Cursor="Hand"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.SelectBatchFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="查看这个批量文件夹"
                                            AutomationProperties.Name="打开批量文件夹">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}" CornerRadius="11">
                                                    <ContentPresenter Margin="{TemplateBinding Padding}"
                                                                      HorizontalAlignment="{TemplateBinding HorizontalContentAlignment}"
                                                                      VerticalAlignment="Center"/>
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <Border Width="52" Height="52"
                                                    CornerRadius="12"
                                                    Background="{DynamicResource AccentContainerBrush}"
                                                    Margin="0,0,12,0">
                                                <TextBlock Text="&#xE838;"
                                                           Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeLarge}"
                                                           Foreground="{DynamicResource AccentBrush}"/>
                                            </Border>
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource TextBodyStrong}"
                                                           MaxWidth="440"
                                                           MaxHeight="42"
                                                           TextWrapping="Wrap"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           MaxWidth="440"
                                                           Margin="0,4,0,0"
                                                           TextTrimming="CharacterEllipsis"/>
                                            </StackPanel>
                                            <Border x:Name="BatchCountBadge"
                                                    Grid.Column="2"
                                                    Background="{StaticResource BgSurfaceBrush}"
                                                    CornerRadius="9"
                                                    Padding="8,5"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding ItemCount, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           FontFamily="{StaticResource FontFamilyMono}"/>
                                            </Border>
                                        </Grid>
                                    </Button>

                                    <StackPanel x:Name="BatchActionPanel"
                                                Panel.ZIndex="10"
                                                Orientation="Horizontal"
                                                HorizontalAlignment="Right"
                                                VerticalAlignment="Center"
                                                Margin="0,0,10,0"
                                                Visibility="Collapsed">
                                        <Button Style="{StaticResource SurfaceButton}"
                                                Width="32" Height="32" Padding="0"
                                                Command="{Binding DataContext.SelectHistoryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="选择整组">
                                            <TextBlock Text="&#xE73A;" Style="{StaticResource IconGlyph}"/>
                                        </Button>
                                        <Button Style="{StaticResource SurfaceButton}"
                                                Width="32" Height="32" Padding="0" Margin="5,0,0,0"
                                                Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding Directory}"
                                                ToolTip="打开本地文件夹">
                                            <TextBlock Text="&#xE838;" Style="{StaticResource IconGlyph}"/>
                                        </Button>
                                        <Button Style="{StaticResource SurfaceButton}"
                                                Width="32" Height="32" Padding="0" Margin="5,0,0,0"
                                                Command="{Binding DataContext.DeleteBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                CommandParameter="{Binding}"
                                                ToolTip="删除整组历史记录">
                                            <TextBlock Text="&#xE74D;"
                                                       Style="{StaticResource IconGlyph}"
                                                       Foreground="{StaticResource ErrorBrush}"/>
                                        </Button>
                                    </StackPanel>
                                </Grid>
                            </Border>
                            <DataTemplate.Triggers>
                                <Trigger SourceName="BatchFolderCard" Property="IsMouseOver" Value="True">
                                    <Setter TargetName="BatchCountBadge" Property="Visibility" Value="Collapsed"/>
                                    <Setter TargetName="BatchActionPanel" Property="Visibility" Value="Visible"/>
                                </Trigger>
                            </DataTemplate.Triggers>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>

                <Border Padding="14,13"
                        Background="{StaticResource BgSurfaceHighBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1"
                        CornerRadius="10">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Visibility" Value="Visible"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding HasWorkspaceFolders}" Value="True">
                                    <Setter Property="Visibility" Value="Collapsed"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                        <TextBlock Text="&#xE8B7;"
                                   Style="{StaticResource IconGlyph}"
                                   Foreground="{DynamicResource AccentBrush}"
                                   Margin="0,0,9,0"/>
                        <TextBlock Text="批量视频会自动生成文件夹，也可以在右上角创建自定义整理文件夹"
                                   Style="{StaticResource TextCaption}"/>
                    </StackPanel>
                </Border>
                </StackPanel>
                </ScrollViewer>
            </StackPanel>
        </Border>

        <Grid Grid.Row="3"
              Margin="0,0,0,14"
              Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
            <Border Padding="12,8"
                    Background="{DynamicResource AccentContainerBrush}"
                    BorderBrush="{DynamicResource AccentBrush}"
                    Visibility="{Binding HasSelection, Converter={StaticResource BoolToVisibility}}">
                <Border.Style>
                    <Style TargetType="Border" BasedOn="{StaticResource ToolPanelBorder}"/>
                </Border.Style>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="30" Height="30"
                                Background="{DynamicResource AccentBrush}"
                                CornerRadius="8"
                                Margin="0,0,9,0">
                            <TextBlock Text="&#xE73E;"
                                       Style="{StaticResource IconGlyph}"
                                       Foreground="{StaticResource BgPrimaryBrush}"/>
                        </Border>
                        <TextBlock Text="{Binding SelectionSummaryText, Mode=OneWay}"
                                   Style="{StaticResource TextBodyStrong}"
                                   VerticalAlignment="Center"/>
                        <Button Style="{StaticResource SurfaceButton}"
                                Padding="9,5" Margin="10,0,0,0"
                                Command="{Binding SelectAllVisibleCommand}"
                                Content="全选"/>
                        <Button Style="{StaticResource SurfaceButton}"
                                Padding="9,5" Margin="6,0,0,0"
                                Command="{Binding ClearSelectionCommand}"
                                Content="取消"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Grid Width="165">
                            <ComboBox Style="{StaticResource DarkComboBox}"
                                      ItemsSource="{Binding HistoryFolders}"
                                      DisplayMemberPath="Name"
                                      SelectedItem="{Binding BulkTargetFolder}"
                                      ToolTip="选择目标整理文件夹"/>
                            <TextBlock Text="选择目标文件夹"
                                       Margin="12,0"
                                       VerticalAlignment="Center"
                                       IsHitTestVisible="False">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextCaption}">
                                        <Setter Property="Visibility" Value="Collapsed"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BulkTargetFolder}" Value="{x:Null}">
                                                <Setter Property="Visibility" Value="Visible"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Grid>
                        <Button Style="{StaticResource SurfaceButton}"
                                Padding="10,6" Margin="6,0,0,0"
                                Command="{Binding MoveSelectedToFolderCommand}"
                                ToolTip="移动到选择的整理文件夹">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8DE;" Style="{StaticResource IconGlyph}" Margin="0,0,5,0"/>
                                <TextBlock Text="移动"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SurfaceButton}"
                                Padding="10,6" Margin="6,0,0,0"
                                Command="{Binding RemoveSelectedFromFolderCommand}"
                                ToolTip="移回历史首页">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8DA;" Style="{StaticResource IconGlyph}" Margin="0,0,5,0"/>
                                <TextBlock Text="移回首页"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SurfaceButton}"
                                Padding="10,6" Margin="6,0,0,0"
                                Command="{Binding DeleteSelectedCommand}"
                                ToolTip="仅删除选中历史记录，不删除本地文件">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;"
                                           Style="{StaticResource IconGlyph}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           Margin="0,0,5,0"/>
                                <TextBlock Text="删除"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <Grid Grid.Row="4">
            <Grid HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40,0,80">
                <Grid.Style>
                    <Style TargetType="Grid">
                        <Setter Property="Visibility" Value="Collapsed"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding VisibleHistoryCount}" Value="0">
                                <Setter Property="Visibility" Value="Visible"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Grid.Style>

                <!-- 纯空态：无任何下载历史记录 -->
                <StackPanel x:Name="PureEmptyPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="False">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE8F9;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="无下载历史" Style="{StaticResource TextSection}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="快去粘贴链接下载你喜欢的视频吧" Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                </StackPanel>

                <!-- 无匹配态：有筛选或搜索但无匹配结果 -->
                <StackPanel x:Name="NoMatchPanel">
                    <StackPanel.Style>
                        <Style TargetType="StackPanel">
                            <Setter Property="Visibility" Value="Collapsed"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsSearchOrFilterActive}" Value="True">
                                    <Setter Property="Visibility" Value="Visible"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </StackPanel.Style>
                    <TextBlock Text="&#xE11A;" Style="{StaticResource IconGlyph}"
                               FontSize="{StaticResource IconSizeEmptyState}" Foreground="{StaticResource BorderPrimaryBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="未找到匹配的记录" Style="{StaticResource TextSection}" HorizontalAlignment="Center" Margin="0,16,0,0"/>
                    <TextBlock Text="尝试清除筛选或搜索词以显示全部历史" Style="{StaticResource TextBody}" HorizontalAlignment="Center" Margin="0,4,0,0"/>
                    <Button Style="{StaticResource AccentButton}"
                            Content="清除筛选"
                            Command="{Binding ClearFilterAndSearchCommand}"
                            HorizontalAlignment="Center"
                            Margin="0,16,0,0"
                            Padding="16,6"
                            ToolTip="清除筛选与搜索"
                            AutomationProperties.Name="清除筛选与搜索"/>
                </StackPanel>
            </Grid>

            <Border HorizontalAlignment="Center"
                    VerticalAlignment="Top"
                    Margin="0,42,0,0"
                    Padding="18,14"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1"
                    CornerRadius="10"
                    Visibility="{Binding ShouldShowFolderOnlyHint, Converter={StaticResource BoolToVisibility}}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="&#xE838;"
                               Style="{StaticResource IconGlyph}"
                               Foreground="{DynamicResource AccentBrush}"
                               Margin="0,0,9,0"/>
                    <TextBlock Text="批量内容已收纳到上方文件夹，点击文件夹即可查看"
                               Style="{StaticResource TextBody}"/>
                </StackPanel>
            </Border>

            <ListBox x:Name="HistoryList"
                     ItemsSource="{Binding HistoryGroups}"
                     Background="Transparent"
                     BorderThickness="0"
                     ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                     ScrollViewer.VerticalScrollBarVisibility="Auto"
                     ScrollViewer.CanContentScroll="False"
                     ScrollViewer.IsDeferredScrollingEnabled="False"
                     ScrollViewer.PanningMode="VerticalOnly">
                <ListBox.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel/>
                    </ItemsPanelTemplate>
                </ListBox.ItemsPanel>
                <ListBox.ItemContainerStyle>
                    <Style TargetType="ListBoxItem">
                        <Setter Property="Padding" Value="0"/>
                        <Setter Property="Margin" Value="0,0,0,22"/>
                        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="ListBoxItem">
                                    <ContentPresenter/>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                    </Style>
                </ListBox.ItemContainerStyle>
                <ListBox.ItemTemplate>
                    <DataTemplate>
                        <StackPanel>
                            <Border Style="{StaticResource ToolPanelBorder}"
                                    Padding="10"
                                    Margin="0,0,0,12"
                                    Visibility="Collapsed">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>

                                    <Button Grid.Column="0"
                                            Style="{StaticResource SurfaceButton}"
                                            Padding="10,8"
                                            HorizontalContentAlignment="Stretch"
                                            Command="{Binding DataContext.ToggleHistoryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="展开或收起这个批次"
                                            AutomationProperties.Name="展开或收起批次">
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Grid.Column="0"
                                                       Text="&#xE8B7;"
                                                       Style="{StaticResource IconGlyph}"
                                                       FontSize="{StaticResource IconSizeLarge}"
                                                       Foreground="{DynamicResource AccentBrush}"
                                                       Margin="0,0,12,0"
                                                       VerticalAlignment="Center"/>
                                            <StackPanel Grid.Column="1">
                                                <TextBlock Text="{Binding Name}"
                                                           Style="{StaticResource TextBodyStrong}"
                                                           TextTrimming="CharacterEllipsis"/>
                                                <TextBlock Text="{Binding SummaryText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           Margin="0,3,0,0"/>
                                            </StackPanel>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ExpandGlyph, Mode=OneWay}"
                                                       Style="{StaticResource TextBodyStrong}"
                                                       FontSize="{StaticResource IconSizeBody}"
                                                       Margin="14,0,4,0"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Button>

                                    <Button Grid.Column="1"
                                            Style="{StaticResource SurfaceButton}"
                                            Height="40"
                                            Padding="10,0"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.SelectHistoryGroupCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="选择或取消选择整组记录"
                                            AutomationProperties.Name="选择整组历史记录">
                                        <TextBlock Text="选择整组" Style="{StaticResource TextCaption}"/>
                                    </Button>
                                    <Button Grid.Column="2"
                                            Style="{StaticResource SurfaceButton}"
                                            Width="40"
                                            Height="40"
                                            Padding="0"
                                            Margin="10,0,0,0"
                                            Command="{Binding DataContext.OpenDirectoryCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding Directory}"
                                            ToolTip="打开批次文件夹"
                                            AutomationProperties.Name="打开批次文件夹">
                                        <TextBlock Text="&#xE838;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeBody}"/>
                                    </Button>
                                    <Button Grid.Column="3"
                                            Style="{StaticResource SurfaceButton}"
                                            Width="40"
                                            Height="40"
                                            Padding="0"
                                            Margin="8,0,0,0"
                                            Command="{Binding DataContext.DeleteBatchCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                            CommandParameter="{Binding}"
                                            ToolTip="删除整组历史记录"
                                            AutomationProperties.Name="删除整组历史记录">
                                        <TextBlock Text="&#xE74D;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeBody}"/>
                                    </Button>
                                </Grid>
                            </Border>

                            <ItemsControl ItemsSource="{Binding Items}">
                                <ItemsControl.Style>
                                    <Style TargetType="ItemsControl">
                                        <Setter Property="Visibility" Value="Visible"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsExpanded}" Value="False">
                                                <Setter Property="Visibility" Value="Collapsed"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ItemsControl.Style>
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemContainerStyle>
                                    <Style TargetType="ContentPresenter">
                                        <Setter Property="Margin" Value="0,0,22,0"/>
                                    </Style>
                                </ItemsControl.ItemContainerStyle>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                        <Border x:Name="HistoryCard"
                                Width="286"
                                Padding="0"
                                Opacity="{Binding FileExists, Converter={StaticResource FileExistsToOpacity}}"
                                ToolTip="{Binding FilePath}"
                                ClipToBounds="True"
                                Cursor="Hand"
                                PreviewMouseLeftButtonDown="HistoryCard_PreviewMouseLeftButtonDown"
                                PreviewMouseMove="HistoryCard_PreviewMouseMove">
                            <Border.Style>
                                <Style TargetType="Border" BasedOn="{StaticResource ToolPanelBorder}">
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsSelected}" Value="True">
                                            <Setter Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                                            <Setter Property="BorderThickness" Value="2"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <StackPanel>
                                <Border Height="162"
                                        CornerRadius="12,12,0,0"
                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                        ClipToBounds="True">
                                    <Grid>
                                        <Image x:Name="ThumbnailImage"
                                               Source="{Binding ThumbnailUrl}"
                                               Stretch="UniformToFill"
                                               RenderOptions.BitmapScalingMode="HighQuality">
                                            <Image.Effect>
                                                <BlurEffect x:Name="ThumbnailBlur" Radius="0"/>
                                            </Image.Effect>
                                        </Image>
                                        <TextBlock Text="&#xEC4F;"
                                                   Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeEmptyState}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Opacity="0.22"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                        <CheckBox IsChecked="{Binding IsSelected, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                                                  Panel.ZIndex="10"
                                                  HorizontalAlignment="Left"
                                                  VerticalAlignment="Top"
                                                  Margin="10"
                                                  Padding="5"
                                                  ToolTip="选择此记录"
                                                  AutomationProperties.Name="选择历史记录"/>
                                        <Border HorizontalAlignment="Right"
                                                VerticalAlignment="Bottom"
                                                Background="{StaticResource ScrimHeavyBrush}"
                                                CornerRadius="3"
                                                Padding="5,2"
                                                Margin="0,0,8,8">
                                            <TextBlock Text="{Binding Quality}" Style="{StaticResource TextCaption}"/>
                                        </Border>
                                        <Border x:Name="HoverOverlay"
                                                Background="{StaticResource ScrimOverlayBrush}"
                                                CornerRadius="12,12,0,0"
                                                Opacity="0"
                                                IsHitTestVisible="False"
                                                RenderTransformOrigin="0.5,0.5">
                                            <Border.RenderTransform>
                                                <TranslateTransform x:Name="HoverOverlayTranslate" Y="6"/>
                                            </Border.RenderTransform>
                                            <StackPanel Orientation="Horizontal"
                                                        HorizontalAlignment="Center"
                                                        VerticalAlignment="Center">
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="打开文件夹"
                                                        AutomationProperties.Name="打开文件夹"
                                                         IsEnabled="{Binding FileExists}"
                                                         Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding AvailableFilePath}">
                                                    <TextBlock Text="&#xE838;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource AccentButton}"
                                                        Width="42"
                                                        Height="42"
                                                        Padding="0"
                                                        Margin="10,0"
                                                        ToolTip="预览文件"
                                                        AutomationProperties.Name="预览文件"
                                                         IsEnabled="{Binding FileExists}"
                                                         Command="{Binding DataContext.PreviewFileCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                         CommandParameter="{Binding AvailableFilePath}">
                                                    <TextBlock Text="&#xE768;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeLarge}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        Margin="0,0,10,0"
                                                        ToolTip="打开原网页"
                                                        AutomationProperties.Name="打开原网页"
                                                        IsEnabled="{Binding Url, Converter={StaticResource HttpUrlToBool}}"
                                                        Command="{Binding DataContext.OpenSourceUrlCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Url}">
                                                    <TextBlock Text="&#xE8A7;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                                <Button Style="{StaticResource SurfaceButton}"
                                                        Width="36"
                                                        Height="36"
                                                        Padding="0"
                                                        ToolTip="删除记录"
                                                        AutomationProperties.Name="删除记录"
                                                        Command="{Binding DataContext.DeleteItemCommand, RelativeSource={RelativeSource AncestorType=UserControl}}"
                                                        CommandParameter="{Binding Id}">
                                                    <TextBlock Text="&#xE74D;"
                                                               Style="{StaticResource IconGlyph}"
                                                               FontSize="{StaticResource IconSizeBody}"
                                                               VerticalAlignment="Center"/>
                                                </Button>
                                            </StackPanel>
                                        </Border>
                                    </Grid>
                                </Border>

                                <StackPanel Margin="14,12,14,14">
                                    <Grid Margin="0,0,0,8">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0"
                                                   Text="{Binding Title}"
                                                   Style="{StaticResource TextBodyStrong}"
                                                   TextTrimming="CharacterEllipsis"/>
                                        <Border Grid.Column="1"
                                                Background="{Binding Platform, Converter={StaticResource PlatformToColor}}"
                                                CornerRadius="4"
                                                Padding="6,2"
                                                Margin="8,0,0,0"
                                                Visibility="{Binding Platform, Converter={StaticResource StringToVisibility}, FallbackValue=Collapsed}">
                                            <TextBlock Text="{Binding Platform}" Style="{StaticResource TextCaption}"/>
                                        </Border>
                                    </Grid>

                                    <StackPanel Orientation="Horizontal"
                                                Margin="0,0,0,8"
                                                Visibility="{Binding HasOrganizerFolder, Converter={StaticResource BoolToVisibility}}">
                                        <TextBlock Text="&#xE8B7;" Style="{StaticResource IconGlyph}"
                                                   FontSize="{StaticResource IconSizeSmall}"
                                                   Foreground="{DynamicResource AccentBrush}"
                                                   Margin="0,0,5,0"/>
                                        <TextBlock Text="{Binding OrganizerFolderName, Mode=OneWay}"
                                                   Style="{StaticResource TextCaption}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </StackPanel>

                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <StackPanel Grid.Column="0">
                                            <StackPanel Orientation="Horizontal">
                                                <TextBlock Text="&#xE792;" Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding FileSizeText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"
                                                           Margin="0,0,12,0"/>
                                                <TextBlock Text="&#xE787;" Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding DownloadTimeText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"/>
                                            </StackPanel>
                                            <StackPanel Orientation="Horizontal"
                                                        Margin="0,6,0,0"
                                                        ToolTip="附属文件摘要"
                                                        Visibility="{Binding HasAttachmentSummary, Converter={StaticResource BoolToVisibility}}">
                                                <TextBlock Text="&#xE8A5;"
                                                           Style="{StaticResource IconGlyph}"
                                                           FontSize="{StaticResource IconSizeBody}"
                                                           Foreground="{StaticResource TextSecondaryBrush}"
                                                           Margin="0,0,4,0"/>
                                                <TextBlock Text="{Binding AttachmentSummaryText, Mode=OneWay}"
                                                           Style="{StaticResource TextCaption}"/>
                                            </StackPanel>
                                        </StackPanel>
                                        <TextBlock Grid.Column="1"
                                                   Text="{Binding Format}"
                                                   Style="{StaticResource TextCaption}"
                                                   Foreground="{DynamicResource AccentBrush}"/>
                                    </Grid>

                                </StackPanel>
                            </StackPanel>
                        </Border>
                        <DataTemplate.Triggers>
                            <Trigger SourceName="HistoryCard" Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             From="0"
                                                             To="1"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             From="6"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="7"
                                                             Duration="{StaticResource MotionDurationFast}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                             Storyboard.TargetProperty="Opacity"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="HoverOverlayTranslate"
                                                             Storyboard.TargetProperty="Y"
                                                             To="6"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                            <DoubleAnimation Storyboard.TargetName="ThumbnailBlur"
                                                             Storyboard.TargetProperty="Radius"
                                                             To="0"
                                                             Duration="{StaticResource MotionDurationMedium}"
                                                             EasingFunction="{StaticResource MotionEaseOut}"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                                <Setter TargetName="HoverOverlay" Property="Opacity" Value="1"/>
                                <Setter TargetName="HoverOverlay" Property="IsHitTestVisible" Value="True"/>
                            </Trigger>
                        </DataTemplate.Triggers>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </DataTemplate>
                </ListBox.ItemTemplate>
            </ListBox>
            <Border Panel.ZIndex="50"
                    Background="{StaticResource ScrimHeavyBrush}"
                    CornerRadius="12"
                    Visibility="{Binding IsLoadingHistory, Converter={StaticResource BoolToVisibility}}">
                <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                    <ProgressBar Width="180" Height="5" IsIndeterminate="True"
                                 Style="{StaticResource AccentProgressBar}"/>
                    <TextBlock Text="正在整理下载历史…"
                               Style="{StaticResource TextBodyStrong}"
                               HorizontalAlignment="Center"
                               Margin="0,12,0,0"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</UserControl>

<Window x:Class="EasyGet.Views.ConfirmationDialog"
        x:Name="Root"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="{Binding DialogTitle, ElementName=Root}"
        Width="560"
        SizeToContent="Height"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="NoResize"
        ShowInTaskbar="False"
        WindowStartupLocation="CenterOwner"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True">
    <Grid Margin="24">
        <Border Background="{StaticResource BgSurfaceHighBrush}"
                CornerRadius="16"
                Effect="{StaticResource PopupShadow}"/>

        <Border Background="{StaticResource BgSurfaceHighBrush}"
                BorderBrush="{StaticResource BorderPrimaryBrush}"
                BorderThickness="1"
                CornerRadius="16"
                ClipToBounds="True">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="4"/>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <Border Grid.Row="0">
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsDestructive, ElementName=Root}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                </Border>

                <Grid Grid.Row="1" Margin="24,22,24,20">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Grid Grid.Row="0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <Border Width="44" Height="44" CornerRadius="12" Margin="0,0,14,0">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="Background" Value="{DynamicResource AccentContainerBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsDestructive, ElementName=Root}" Value="True">
                                            <Setter Property="Background" Value="{StaticResource ErrorContainerBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <TextBlock Text="&#xE7BA;"
                                       FontSize="{StaticResource IconSizePreview}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource IconGlyph}">
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDestructive, ElementName=Root}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                            </TextBlock>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="请确认操作"
                                       Style="{StaticResource TextCaption}"
                                       TextOptions.TextFormattingMode="Display"/>
                            <TextBlock Text="{Binding DialogTitle, ElementName=Root}"
                                       Style="{StaticResource TextSection}"
                                       Margin="0,3,0,0"
                                       TextWrapping="Wrap"/>
                        </StackPanel>

                        <Button Grid.Column="2"
                                Style="{StaticResource SurfaceButton}"
                                Width="32" Height="32" Padding="0"
                                VerticalAlignment="Top"
                                Click="CancelButton_Click"
                                ToolTip="关闭"
                                AutomationProperties.Name="关闭确认弹窗">
                            <TextBlock Text="&#xE8BB;" Style="{StaticResource IconGlyph}"/>
                        </Button>
                    </Grid>

                    <Border Grid.Row="1"
                            Margin="0,16,0,0"
                            Padding="14,12"
                            Background="{StaticResource BgSurfaceBrush}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="10">
                        <TextBlock Text="{Binding DialogMessage, ElementName=Root}"
                                   Style="{StaticResource TextBody}"
                                   FontSize="{StaticResource FontSizeBodyStrong}"
                                   LineHeight="22"
                                   TextWrapping="Wrap"/>
                    </Border>
                </Grid>

                <Border Grid.Row="2"
                        Background="{StaticResource BgSurfaceBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="0,1,0,0"
                        Padding="24,14">
                    <Grid>
                        <TextBlock Text="Esc 取消 · Enter 确认"
                                   Style="{StaticResource TextCaption}"
                                   VerticalAlignment="Center"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SurfaceButton}"
                                    MinWidth="88"
                                    Margin="0,0,8,0"
                                    Content="取消"
                                    IsCancel="True"
                                    Click="CancelButton_Click"/>
                            <Button MinWidth="104"
                                    Content="{Binding ConfirmText, ElementName=Root}"
                                    IsDefault="True"
                                    Click="ConfirmButton_Click">
                                <Button.Style>
                                    <Style TargetType="Button" BasedOn="{StaticResource AccentButton}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsDestructive, ElementName=Root}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource ErrorBrush}"/>
                                                <Setter Property="Foreground" Value="{StaticResource BgPrimaryBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Button.Style>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>
        </Border>
    </Grid>
</Window>

<UserControl x:Class="EasyGet.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <StackPanel Margin="40,32">

            <!-- 页面标题 -->
            <TextBlock Text="视频下载" FontSize="28" FontWeight="ExtraBold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                       Margin="0,0,0,24"/>

            <!-- URL 输入行 -->
            <TextBlock Text="视频链接" FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                         FontSize="14"/>
                <Button Grid.Column="1" Style="{StaticResource SurfaceButton}"
                        Margin="8,0,0,0"
                        ToolTip="粘贴视频链接"
                        AutomationProperties.Name="粘贴视频链接"
                        Command="{Binding PasteUrlCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="粘贴" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button Grid.Column="2" Style="{StaticResource AccentButton}"
                        Margin="8,0,0,0"
                        ToolTip="开始下载"
                        AutomationProperties.Name="开始下载"
                        Command="{Binding StartDownloadCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE118;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="下载" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 选项卡片区 -->
            <Border Style="{StaticResource ToolPanelBorder}"
                    Padding="20,16,4,8" Margin="0,20,0,0">
                <WrapPanel Orientation="Horizontal">
                    <!-- 格式 -->
                    <StackPanel Margin="0,0,24,8">
                        <TextBlock Text="格式" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DarkComboBox}" Width="150"
                                  ItemsSource="{Binding FormatOptions}"
                                  SelectedItem="{Binding SelectedFormat}"/>
                    </StackPanel>
                    <!-- 画质 -->
                    <StackPanel Margin="0,0,24,8">
                        <TextBlock Text="画质" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DarkComboBox}" Width="150"
                                  ItemsSource="{Binding QualityOptions}"
                                  SelectedItem="{Binding SelectedQuality}"/>
                    </StackPanel>
                    <!-- 字幕 -->
                    <StackPanel Margin="0,0,24,8">
                        <TextBlock Text="字幕" FontSize="11" Foreground="{StaticResource TextMutedBrush}" Margin="0,0,0,6"/>
                        <ComboBox Style="{StaticResource DarkComboBox}" Width="150"
                                  ItemsSource="{Binding SubtitleOptions}"
                                  SelectedItem="{Binding SelectedSubtitle}"/>
                    </StackPanel>
                </WrapPanel>
            </Border>

            <!-- 下载目录 -->
            <TextBlock Text="下载目录" FontSize="12" FontWeight="Medium"
                       Foreground="{StaticResource TextMutedBrush}" Margin="0,12,0,8"/>
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBox Grid.Column="0" Style="{StaticResource DarkTextBox}"
                         Text="{Binding DownloadDirectory, UpdateSourceTrigger=PropertyChanged}"
                         IsReadOnly="True"/>
                <Button Grid.Column="1" Style="{StaticResource SurfaceButton}"
                        Margin="8,0,0,0"
                        ToolTip="选择下载目录"
                        AutomationProperties.Name="选择下载目录"
                        Command="{Binding BrowseDirectoryCommand}">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                   FontSize="13" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock Text="浏览" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- 下载进度区域 (悬浮卡片感) -->
            <Border Style="{StaticResource ToolPanelBorder}"
                    Padding="24,20" Margin="0,28,0,0"
                    Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}">
                <StackPanel>
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="Auto"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>

                        <!-- 缩略图 -->
                        <Border Grid.Column="0" Width="106" Height="60" CornerRadius="8"
                                Background="#11111B" Margin="0,0,18,0" ClipToBounds="True">
                            <Image Source="{Binding CurrentTask.ThumbnailUrl, FallbackValue={x:Null}}"
                                   Stretch="UniformToFill" RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>

                        <StackPanel Grid.Column="1" VerticalAlignment="Center">
                            <TextBlock Text="{Binding CurrentTask.Title, FallbackValue='准备中...'}"
                                       FontSize="15" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       TextTrimming="CharacterEllipsis" Margin="0,0,0,6"/>
                            <TextBlock FontSize="12" Foreground="{StaticResource TextMutedBrush}">
                                <Run Text="{Binding CurrentTask.Platform, FallbackValue='', Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding CurrentTask.DurationText, FallbackValue='', Mode=OneWay}"/>
                                <Run Text=" · "/>
                                <Run Text="{Binding CurrentTask.SpeedText, FallbackValue='--', Mode=OneWay}"/>
                                <Run Text=" · 剩余 "/>
                                <Run Text="{Binding CurrentTask.EtaText, FallbackValue='--:--', Mode=OneWay}"/>
                            </TextBlock>
                        </StackPanel>
                        <TextBlock Grid.Column="2" VerticalAlignment="Center"
                                   FontSize="20" FontWeight="Bold" Foreground="{StaticResource AccentBrush}">
                            <Run Text="{Binding CurrentTask.Progress, StringFormat={}{0:F1}, FallbackValue='0'}"/>
                            <Run Text="%"/>
                        </TextBlock>
                    </Grid>
                    <ProgressBar Style="{StaticResource AccentProgressBar}"
                                 Value="{Binding CurrentTask.Progress}" Maximum="100"
                                 Margin="0,12,0,0"/>
                    <Button Style="{StaticResource SurfaceButton}" Content="取消下载"
                            HorizontalAlignment="Right" Margin="0,12,0,0"
                            ToolTip="取消当前下载"
                            AutomationProperties.Name="取消当前下载"
                            Command="{Binding CancelDownloadCommand}"/>
                </StackPanel>
            </Border>

            <!-- 日志区域 -->
            <Grid Margin="0,24,0,0">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="360"/>
                </Grid.RowDefinitions>
                <DockPanel Grid.Row="0" Margin="0,0,0,8">
                    <TextBlock Text="下载日志" FontSize="14" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                    <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource SurfaceButton}"
                                FontSize="11" Padding="10,5" Margin="0,0,6,0"
                                ToolTip="复制下载日志"
                                AutomationProperties.Name="复制下载日志"
                                Command="{Binding CopyLogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="复制日志" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SurfaceButton}"
                                Content="清空" FontSize="11" Padding="10,5"
                                ToolTip="清空下载日志"
                                AutomationProperties.Name="清空下载日志"
                                Command="{Binding ClearLogCommand}"/>
                    </StackPanel>
                </DockPanel>
                <Border Grid.Row="1" Style="{StaticResource ToolPanelBorder}"
                        Background="#11111B"
                        Padding="12,8">
                    <TextBox x:Name="LogTextBox"
                             Text="{Binding LogText, Mode=OneWay}"
                             IsReadOnly="True"
                             AcceptsReturn="True"
                             TextWrapping="NoWrap"
                             Background="Transparent"
                             BorderThickness="0"
                             Foreground="#A8B0BD"
                             CaretBrush="{StaticResource TextPrimaryBrush}"
                             SelectionBrush="{StaticResource AccentBrush}"
                             FontFamily="Cascadia Code, Consolas, Courier New"
                             FontSize="11"
                             Padding="0"
                             Cursor="IBeam"
                             VerticalScrollBarVisibility="Auto"
                             HorizontalScrollBarVisibility="Auto"/>
                </Border>
            </Grid>

        </StackPanel>
    </ScrollViewer>
</UserControl>

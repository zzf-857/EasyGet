<UserControl x:Class="EasyGet.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             behaviors:Motion.PageEnter="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,28,32,32">
            <StackPanel MaxWidth="900" HorizontalAlignment="Center">

                <Border Style="{StaticResource ToolPanelBorder}" Padding="32,28" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="粘贴视频链接"
                                       Style="{StaticResource TextPageTitle}"/>
                            <TextBlock Text="支持 YouTube, Bilibili, Twitter, TikTok 等平台"
                                       Style="{StaticResource TextBodyStrong}"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <!-- 剪贴板智能检测提示条 -->
                        <Border Background="{StaticResource AccentContainerBrush}"
                                BorderBrush="{StaticResource AccentBrush}"
                                BorderThickness="1"
                                CornerRadius="8"
                                Padding="16,10"
                                Margin="0,0,0,16"
                                Visibility="{Binding ShowClipboardPrompt, Converter={StaticResource BoolToVisibility}}">
                            <Border.InputBindings>
                                <MouseBinding MouseAction="LeftClick" Command="{Binding UseClipboardPromptCommand}"/>
                            </Border.InputBindings>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource IconGlyph}" Grid.Column="0" Text="&#xE77F;"
                                           FontSize="{StaticResource IconSizeBody}" Foreground="{StaticResource AccentBrush}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" VerticalAlignment="Center" Style="{StaticResource TextBody}" TextTrimming="CharacterEllipsis">
                                    <Run Text="检测到剪贴板链接: " Foreground="{StaticResource TextSecondaryBrush}"/>
                                    <Run Text="{Binding ClipboardPromptUrl}" Foreground="{StaticResource AccentBrush}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                                    <Run Text="，点击直接解析" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </TextBlock>
                                <Button Grid.Column="2" Style="{StaticResource SurfaceButton}" Padding="6,3" FontSize="{StaticResource FontSizeCaption}"
                                        Content="忽略"
                                        Command="{Binding DismissClipboardPromptCommand}"/>
                            </Grid>
                        </Border>

                        <Border Background="{StaticResource BgPrimaryBrush}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="0"
                                Margin="0,0,0,18">
                            <Border.Style>
                                <Style TargetType="Border">
                                    <Setter Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding UrlError, Converter={StaticResource StringToVisibility}}" Value="Visible">
                                            <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Border.Style>
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Style="{StaticResource IconGlyph}" Grid.Column="0"
                                           Text="&#xE71B;"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="{StaticResource IconSizeBody}"
                                           Margin="18,0,12,0"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         Padding="0,16"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="2"
                                        Style="{StaticResource SurfaceButton}"
                                        Margin="8,8,8,8"
                                        ToolTip="粘贴视频链接"
                                        AutomationProperties.Name="粘贴视频链接"
                                        Command="{Binding PasteUrlCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE77F;"
                                                   FontSize="{StaticResource IconSizeBody}" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="粘贴" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <TextBlock Text="{Binding UrlError}"
                                   Style="{StaticResource TextBody}"
                                   Foreground="{StaticResource ErrorBrush}"
                                   Margin="4,-12,0,14"
                                   Visibility="{Binding UrlError, Converter={StaticResource StringToVisibility}}"/>

                        <Border Style="{StaticResource ToolPanelBorder}"
                                Padding="18,16"
                                Margin="0,0,0,18"
                                Visibility="{Binding IsParsing, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <ProgressBar Width="96"
                                             Height="6"
                                             Margin="0,0,16,0"
                                             IsIndeterminate="True"
                                             VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="正在解析视频信息"
                                               Style="{StaticResource TextBodyStrong}"/>
                                    <TextBlock Text="正在获取封面、标题、时长和预估大小"
                                               Style="{StaticResource TextBody}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ToolPanelBorder}"
                                Padding="18,16"
                                Margin="0,0,0,18"
                                Tag="{Binding PreviewInfo}"
                                Visibility="{Binding IsReady, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel>
                                <TextBlock Text="视频预览"
                                           Style="{StaticResource TextCaption}"
                                           Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="168"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Width="152"
                                            Height="86"
                                            CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighestBrush}"
                                            ClipToBounds="True"
                                            HorizontalAlignment="Left">
                                        <Grid>
                                            <Image Source="{Binding PreviewThumbnailUrl}"
                                                   Stretch="UniformToFill"
                                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                                            <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8B2;"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       FontSize="{StaticResource FontSizePageTitle}"
                                                       Opacity="0.35"
                                                       HorizontalAlignment="Center"
                                                       VerticalAlignment="Center"/>
                                        </Grid>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <DockPanel LastChildFill="True">
                                            <Border DockPanel.Dock="Right"
                                                    Background="{Binding PreviewPlatform, Converter={StaticResource PlatformToColor}}"
                                                    CornerRadius="4"
                                                    Padding="7,2"
                                                    Margin="12,0,0,0"
                                                    Visibility="{Binding PreviewPlatform, Converter={StaticResource StringToVisibility}}">
                                                <TextBlock Text="{Binding PreviewPlatform}"
                                                           Style="{StaticResource TextCaption}"/>
                                            </Border>
                                            <TextBlock Text="{Binding PreviewTitle}"
                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                       FontSize="{StaticResource FontSizeBodyStrong}"
                                                       FontWeight="{StaticResource FontWeightSemiBold}"
                                                       TextWrapping="Wrap"
                                                       TextTrimming="CharacterEllipsis"
                                                       MaxHeight="44"/>
                                        </DockPanel>
                                        <TextBlock Foreground="{StaticResource TextSecondaryBrush}"
                                                   FontSize="{StaticResource FontSizeBody}"
                                                   Margin="0,8,0,0">
                                            <Run Text="{Binding PreviewDurationText, Mode=OneWay}"/>
                                            <Run Text=" · "/>
                                            <Run Text="{Binding PreviewFileSizeText, Mode=OneWay}"/>
                                        </TextBlock>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <Border Style="{StaticResource ToolPanelBorder}"
                                Background="{StaticResource ErrorContainerBrush}"
                                BorderBrush="{StaticResource ErrorBrush}"
                                Padding="18,16"
                                Margin="0,0,0,18"
                                Visibility="{Binding IsFailed, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE783;"
                                           Foreground="{StaticResource ErrorBrush}"
                                           FontSize="{StaticResource FontSizeSection}"
                                           Margin="0,0,12,0"
                                           VerticalAlignment="Center"/>
                                <StackPanel>
                                    <TextBlock Text="解析失败"
                                               Style="{StaticResource TextBodyStrong}"/>
                                    <TextBlock Text="{Binding ParseErrorMessage}"
                                               Style="{StaticResource TextBody}"
                                               Margin="0,4,0,0"/>
                                </StackPanel>
                            </StackPanel>
                        </Border>

                        <UniformGrid Columns="3"
                                     Margin="0,0,0,24"
                                     Visibility="{Binding IsReady, Converter={StaticResource BoolToVisibility}}">
                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8B2;"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="视频格式" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                                        <TextBlock Text="{Binding SelectedFormat}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="92"
                                              ItemsSource="{Binding FormatOptions}"
                                              SelectedItem="{Binding SelectedFormat}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="4,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE7F4;"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="首选画质" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                                        <TextBlock Text="{Binding SelectedQuality}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="120"
                                              ItemsSource="{Binding QualityOptions}"
                                              SelectedItem="{Binding SelectedQuality}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="8,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8A7;"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="字幕" Foreground="{StaticResource TextMutedBrush}" FontSize="{StaticResource FontSizeCaption}"/>
                                        <TextBlock Text="{Binding SelectedSubtitle}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="{StaticResource FontWeightSemiBold}"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="104"
                                              ItemsSource="{Binding SubtitleOptions}"
                                              SelectedItem="{Binding SelectedSubtitle}"/>
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <Button Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Center"
                                MinWidth="260"
                                Padding="28,12"
                                Margin="0,0,0,0"
                                ToolTip="解析视频信息"
                                AutomationProperties.Name="解析视频"
                                Command="{Binding ParseCommand}"
                                IsEnabled="{Binding IsParsing, Converter={StaticResource InverseBool}}"
                                Visibility="{Binding IsParseActionVisible, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE721;"
                                           FontSize="{StaticResource IconSizeBody}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="解析视频" Style="{StaticResource TextSection}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <Button Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Center"
                                MinWidth="260"
                                Padding="28,12"
                                ToolTip="开始下载"
                                AutomationProperties.Name="开始下载"
                                Command="{Binding StartDownloadCommand}"
                                Visibility="{Binding IsReady, Converter={StaticResource BoolToVisibility}}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE768;"
                                           FontSize="{StaticResource IconSizeBody}" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="开始下载" Style="{StaticResource TextSection}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Padding="22,18"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsProgressCardVisible, Converter={StaticResource BoolToVisibility}}">
                    <Border.Style>
                        <Style TargetType="Border" BasedOn="{StaticResource ToolPanelBorder}">
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding IsTaskFailed}" Value="True">
                                    <Setter Property="Background" Value="{StaticResource ErrorContainerBrush}"/>
                                    <Setter Property="BorderBrush" Value="{StaticResource ErrorBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="112" Height="66" CornerRadius="8"
                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                    Margin="0,0,16,0"
                                    ClipToBounds="True">
                                <Image Source="{Binding CurrentTask.ThumbnailUrl, FallbackValue={x:Null}}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentTask.Title, FallbackValue='准备中...'}"
                                           Style="{StaticResource TextBodyStrong}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock Style="{StaticResource TextMono}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding IsDownloadActive, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="{Binding CurrentTask.Platform, FallbackValue='', Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding CurrentTask.DurationText, FallbackValue='', Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding CurrentTask.SpeedText, FallbackValue='--', Mode=OneWay}"/>
                                    <Run Text=" · 剩余 "/>
                                    <Run Text="{Binding CurrentTask.EtaText, FallbackValue='--:--', Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Style="{StaticResource TextBody}"
                                           Foreground="{StaticResource SuccessBrush}"
                                           Margin="0,6,0,0"
                                           Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}">
                                    <Run Text="已保存到 "/>
                                    <Run Text="{Binding CurrentOutputLocationText, Mode=OneWay}"/>
                                </TextBlock>
                                <TextBlock Text="{Binding CurrentErrorMessage}"
                                           Style="{StaticResource TextBody}"
                                           Foreground="{StaticResource ErrorBrush}"
                                           Margin="0,6,0,0"
                                           TextTrimming="CharacterEllipsis"
                                           Visibility="{Binding IsTaskFailed, Converter={StaticResource BoolToVisibility}}"/>
                            </StackPanel>

                            <StackPanel Grid.Column="2"
                                        Orientation="Horizontal"
                                        VerticalAlignment="Center">
                                <Button Style="{StaticResource SurfaceButton}"
                                        Padding="12,7"
                                        ToolTip="取消当前下载"
                                        AutomationProperties.Name="取消当前下载"
                                        Command="{Binding CancelDownloadCommand}"
                                        Visibility="{Binding IsDownloadActive, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE711;"
                                                   FontSize="{StaticResource FontSizeBody}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="取消" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SurfaceButton}"
                                        Padding="12,7"
                                        Margin="0,0,8,0"
                                        ToolTip="打开文件夹"
                                        AutomationProperties.Name="打开文件夹"
                                        Command="{Binding OpenCurrentFolderCommand}"
                                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE838;"
                                                   FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="打开文件夹" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource AccentButton}"
                                        Padding="12,7"
                                        ToolTip="播放"
                                        AutomationProperties.Name="播放已下载文件"
                                        Command="{Binding PlayCurrentFileCommand}"
                                        Visibility="{Binding IsCompleted, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE768;"
                                                   FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="播放" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                                <Button Style="{StaticResource SurfaceButton}"
                                        Padding="12,7"
                                        ToolTip="重试下载"
                                        AutomationProperties.Name="重试当前下载"
                                        Command="{Binding RetryCurrentDownloadCommand}"
                                        Visibility="{Binding IsTaskFailed, Converter={StaticResource BoolToVisibility}}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE72C;"
                                                   FontSize="{StaticResource IconSizeSmall}" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="重试" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </StackPanel>
                        </Grid>
                        <Grid Margin="0,14,0,0">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto"/>
                                <RowDefinition Height="Auto"/>
                            </Grid.RowDefinitions>
                            <TextBlock Grid.Row="0"
                                       HorizontalAlignment="Right"
                                       FontFamily="{StaticResource FontFamilyMono}">
                                <TextBlock.Style>
                                    <Style TargetType="TextBlock" BasedOn="{StaticResource TextCardTitle}">
                                        <Setter Property="Foreground" Value="{StaticResource AccentBrush}"/>
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTaskFailed}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </TextBlock.Style>
                                <Run Text="{Binding CurrentTask.Progress, StringFormat={}{0:F1}, FallbackValue='0'}"/>
                                <Run Text="%"/>
                            </TextBlock>
                            <ProgressBar Grid.Row="1"
                                         Value="{Binding CurrentTask.Progress, FallbackValue=0, TargetNullValue=0}"
                                         Maximum="100"
                                         Height="6"
                                         VerticalAlignment="Center"
                                         Margin="0,8,0,0"
                                         Validation.ErrorTemplate="{x:Null}">
                                <ProgressBar.Style>
                                    <Style TargetType="ProgressBar" BasedOn="{StaticResource AccentProgressBar}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding IsCompleted}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding IsTaskFailed}" Value="True">
                                                <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </ProgressBar.Style>
                            </ProgressBar>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <Expander Grid.Column="0" Grid.Row="0" Grid.ColumnSpan="2"
                              x:Name="LogExpander"
                              IsExpanded="{Binding IsLogExpanded, Mode=TwoWay}"
                              Background="Transparent"
                              BorderThickness="0">
                        <Expander.Header>
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE756;"
                                           Foreground="{StaticResource AccentBrush}"
                                           FontSize="{StaticResource IconSizeBody}"
                                           Margin="0,0,8,0"
                                           VerticalAlignment="Center"/>
                                <TextBlock Text="详细日志"
                                           Style="{StaticResource TextSection}"
                                           VerticalAlignment="Center"/>
                            </StackPanel>
                        </Expander.Header>

                        <Border Style="{StaticResource ToolPanelBorder}"
                                Background="{StaticResource BgConsoleBrush}"
                                Padding="14,10"
                                Height="300"
                                Margin="0,8,0,0">
                            <TextBox x:Name="LogTextBox"
                                     Text="{Binding LogText, Mode=OneWay}"
                                     IsReadOnly="True"
                                     AcceptsReturn="True"
                                     TextWrapping="NoWrap"
                                     Background="Transparent"
                                     BorderThickness="0"
                                     Foreground="{StaticResource TextSecondaryBrush}"
                                     CaretBrush="{StaticResource TextPrimaryBrush}"
                                     SelectionBrush="{StaticResource AccentBrush}"
                                     FontFamily="{StaticResource FontFamilyMono}"
                                     FontSize="{StaticResource FontSizeBody}"
                                     Padding="0"
                                     Cursor="IBeam"
                                     VerticalScrollBarVisibility="Auto"
                                     HorizontalScrollBarVisibility="Auto"/>
                        </Border>
                    </Expander>

                    <StackPanel Grid.Column="1" Grid.Row="0"
                                Orientation="Horizontal"
                                VerticalAlignment="Top"
                                Margin="0,6,10,0">
                        <Button Style="{StaticResource SurfaceButton}"
                                FontSize="{StaticResource FontSizeCaption}"
                                Padding="10,5"
                                Margin="0,0,6,0"
                                ToolTip="复制下载日志"
                                AutomationProperties.Name="复制下载日志"
                                Command="{Binding CopyLogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8C8;"
                                           FontSize="{StaticResource FontSizeCaption}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="复制日志" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SurfaceButton}"
                                FontSize="{StaticResource FontSizeCaption}"
                                Padding="10,5"
                                ToolTip="清空下载日志"
                                AutomationProperties.Name="清空下载日志"
                                Command="{Binding ClearLogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE74D;"
                                           FontSize="{StaticResource FontSizeCaption}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                <TextBlock Text="清空日志" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <UniformGrid Columns="3">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconGlyph}" Text="&#xEC4A;"
                                       Foreground="{StaticResource AccentBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="并发分片" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding ConcurrentFragmentsText}" Style="{StaticResource TextBodyStrong}"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="4,0,4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Style="{StaticResource IconGlyph}" Grid.Column="0" Text="&#xE838;"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="保存目录" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding DownloadDirectory}" Style="{StaticResource TextBodyStrong}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="8,5"
                                    Margin="10,0,0,0"
                                    ToolTip="选择下载目录"
                                    AutomationProperties.Name="选择下载目录"
                                    Command="{Binding BrowseDirectoryCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE8B7;"
                                               FontSize="{StaticResource IconSizeSmall}" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="更改" Style="{StaticResource TextCaption}" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Style="{StaticResource IconGlyph}" Text="&#xE72E;"
                                       Foreground="{StaticResource WarningBrush}" FontSize="{StaticResource IconSizeLarge}" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="代理状态" Style="{StaticResource TextCaption}"/>
                                <TextBlock Text="{Binding ProxyStatusText}" Style="{StaticResource TextBodyStrong}" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

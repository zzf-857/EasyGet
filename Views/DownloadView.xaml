<UserControl x:Class="EasyGet.Views.DownloadView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:behaviors="clr-namespace:EasyGet.Behaviors"
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
             mc:Ignorable="d"
             Background="Transparent"
             behaviors:Motion.PageEnter="True">

    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
        <Grid Margin="32,28,32,32">
            <StackPanel MaxWidth="900" HorizontalAlignment="Center">

                <Border Style="{StaticResource ToolPanelBorder}" Padding="32,28" Margin="0,0,0,16">
                    <StackPanel>
                        <StackPanel Margin="0,0,0,20">
                            <TextBlock Text="粘贴视频链接"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="24"
                                       FontWeight="SemiBold"/>
                            <TextBlock Text="支持 YouTube, Bilibili, Twitter, TikTok 等平台"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       FontSize="13"
                                       Margin="0,6,0,0"/>
                        </StackPanel>

                        <Border Background="{StaticResource BgPrimaryBrush}"
                                BorderBrush="{StaticResource BorderPrimaryBrush}"
                                BorderThickness="2"
                                CornerRadius="12"
                                Padding="0"
                                Margin="0,0,0,18">
                            <Grid>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="Auto"/>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0"
                                           Text="&#xE71B;"
                                           FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           Foreground="{StaticResource TextSecondaryBrush}"
                                           FontSize="16"
                                           Margin="18,0,12,0"
                                           VerticalAlignment="Center"/>
                                <TextBox Grid.Column="1"
                                         Style="{StaticResource DarkTextBox}"
                                         Text="{Binding Url, UpdateSourceTrigger=PropertyChanged}"
                                         BorderThickness="0"
                                         Background="Transparent"
                                         FontSize="14"
                                         Padding="0,16"
                                         VerticalContentAlignment="Center"/>
                                <Button Grid.Column="2"
                                        Style="{StaticResource SurfaceButton}"
                                        Margin="8,8,8,8"
                                        ToolTip="粘贴视频链接"
                                        AutomationProperties.Name="粘贴视频链接"
                                        Command="{Binding PasteUrlCommand}">
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="&#xE77F;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   FontSize="14" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                        <TextBlock Text="粘贴" VerticalAlignment="Center"/>
                                    </StackPanel>
                                </Button>
                            </Grid>
                        </Border>

                        <UniformGrid Columns="3" Margin="0,0,0,24">
                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="0,0,8,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8B2;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource AccentBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="视频格式" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                        <TextBlock Text="MP4 Video" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="92"
                                              ItemsSource="{Binding FormatOptions}"
                                              SelectedItem="{Binding SelectedFormat}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="4,0,4,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xE7F4;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource WarningBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="首选画质" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                        <TextBlock Text="最高可用画质" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="120"
                                              ItemsSource="{Binding QualityOptions}"
                                              SelectedItem="{Binding SelectedQuality}"/>
                                </Grid>
                            </Border>

                            <Border Style="{StaticResource ToolPanelBorder}" Padding="14,10" Margin="8,0,0,0">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <Border Width="40" Height="40" CornerRadius="8"
                                            Background="{StaticResource BgSurfaceHighBrush}"
                                            Margin="0,0,12,0">
                                        <TextBlock Text="&#xE8A7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   HorizontalAlignment="Center"
                                                   VerticalAlignment="Center"/>
                                    </Border>
                                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                        <TextBlock Text="字幕" Foreground="{StaticResource TextMutedBrush}" FontSize="11"/>
                                        <TextBlock Text="可选字幕" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                                    </StackPanel>
                                    <ComboBox Grid.Column="2"
                                              Style="{StaticResource DarkComboBox}"
                                              Width="104"
                                              ItemsSource="{Binding SubtitleOptions}"
                                              SelectedItem="{Binding SelectedSubtitle}"/>
                                </Grid>
                            </Border>
                        </UniformGrid>

                        <Button Style="{StaticResource AccentButton}"
                                HorizontalAlignment="Center"
                                MinWidth="260"
                                Padding="28,12"
                                ToolTip="开始下载"
                                AutomationProperties.Name="开始下载"
                                Command="{Binding StartDownloadCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                                <TextBlock Text="开始下载" FontSize="16" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>

                <Border Style="{StaticResource ToolPanelBorder}"
                        Padding="22,18"
                        Margin="0,0,0,16"
                        Visibility="{Binding IsDownloading, Converter={StaticResource BoolToVisibility}}">
                    <StackPanel>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>

                            <Border Grid.Column="0" Width="112" Height="66" CornerRadius="8"
                                    Background="{StaticResource BgSurfaceHighestBrush}"
                                    Margin="0,0,16,0"
                                    ClipToBounds="True">
                                <Image Source="{Binding CurrentTask.ThumbnailUrl, FallbackValue={x:Null}}"
                                       Stretch="UniformToFill"
                                       RenderOptions.BitmapScalingMode="HighQuality"/>
                            </Border>

                            <StackPanel Grid.Column="1" VerticalAlignment="Center">
                                <TextBlock Text="{Binding CurrentTask.Title, FallbackValue='准备中...'}"
                                           FontSize="14"
                                           FontWeight="SemiBold"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           TextTrimming="CharacterEllipsis"/>
                                <TextBlock FontSize="12" Foreground="{StaticResource TextSecondaryBrush}" Margin="0,6,0,0">
                                    <Run Text="{Binding CurrentTask.Platform, FallbackValue='', Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding CurrentTask.DurationText, FallbackValue='', Mode=OneWay}"/>
                                    <Run Text=" · "/>
                                    <Run Text="{Binding CurrentTask.SpeedText, FallbackValue='--', Mode=OneWay}"/>
                                    <Run Text=" · 剩余 "/>
                                    <Run Text="{Binding CurrentTask.EtaText, FallbackValue='--:--', Mode=OneWay}"/>
                                </TextBlock>
                            </StackPanel>

                            <Button Grid.Column="2"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="12,7"
                                    ToolTip="取消当前下载"
                                    AutomationProperties.Name="取消当前下载"
                                    Command="{Binding CancelDownloadCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE711;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="12" Margin="0,0,6,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="取消" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                        <Grid Margin="0,14,0,0">
                            <ProgressBar Style="{StaticResource AccentProgressBar}"
                                         Value="{Binding CurrentTask.Progress}"
                                         Maximum="100"/>
                            <TextBlock HorizontalAlignment="Right"
                                       Margin="0,10,0,0"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontWeight="SemiBold">
                                <Run Text="{Binding CurrentTask.Progress, StringFormat={}{0:F1}, FallbackValue='0'}"/>
                                <Run Text="%"/>
                            </TextBlock>
                        </Grid>
                    </StackPanel>
                </Border>

                <Grid Margin="0,0,0,16">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="300"/>
                    </Grid.RowDefinitions>
                    <DockPanel Grid.Row="0" Margin="0,0,0,8">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE756;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource AccentBrush}"
                                       FontSize="16"
                                       Margin="0,0,8,0"
                                       VerticalAlignment="Center"/>
                            <TextBlock Text="下载日志"
                                       FontSize="16"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       VerticalAlignment="Center"/>
                        </StackPanel>
                        <StackPanel DockPanel.Dock="Right" Orientation="Horizontal" HorizontalAlignment="Right">
                            <Button Style="{StaticResource SurfaceButton}"
                                    FontSize="11"
                                    Padding="10,5"
                                    Margin="0,0,6,0"
                                    ToolTip="复制下载日志"
                                    AutomationProperties.Name="复制下载日志"
                                    Command="{Binding CopyLogCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8C8;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="复制日志" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                            <Button Style="{StaticResource SurfaceButton}"
                                    FontSize="11"
                                    Padding="10,5"
                                    ToolTip="清空下载日志"
                                    AutomationProperties.Name="清空下载日志"
                                    Command="{Binding ClearLogCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="清空日志" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>
                    </DockPanel>

                    <Border Grid.Row="1"
                            Style="{StaticResource ToolPanelBorder}"
                            Background="{StaticResource BgConsoleBrush}"
                            Padding="14,10">
                        <TextBox x:Name="LogTextBox"
                                 Text="{Binding LogText, Mode=OneWay}"
                                 IsReadOnly="True"
                                 AcceptsReturn="True"
                                 TextWrapping="NoWrap"
                                 Background="Transparent"
                                 BorderThickness="0"
                                 Foreground="{StaticResource TextSecondaryBrush}"
                                 CaretBrush="{StaticResource TextPrimaryBrush}"
                                 SelectionBrush="{StaticResource AccentBrush}"
                                 FontFamily="Cascadia Code, Consolas, Courier New"
                                 FontSize="12"
                                 Padding="0"
                                 Cursor="IBeam"
                                 VerticalScrollBarVisibility="Auto"
                                 HorizontalScrollBarVisibility="Auto"/>
                    </Border>
                </Grid>

                <UniformGrid Columns="3">
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xEC4A;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource AccentBrush}" FontSize="18" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="并发分片" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ConcurrentFragmentsText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="4,0,4,0">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="&#xE838;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource TextSecondaryBrush}" FontSize="18" Margin="0,0,12,0"/>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="保存目录" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding DownloadDirectory}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                            <Button Grid.Column="2"
                                    Style="{StaticResource SurfaceButton}"
                                    Padding="8,5"
                                    Margin="10,0,0,0"
                                    ToolTip="选择下载目录"
                                    AutomationProperties.Name="选择下载目录"
                                    Command="{Binding BrowseDirectoryCommand}">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="&#xE8B7;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                               FontSize="11" Margin="0,0,5,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="更改" FontSize="11" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>
                    <Border Style="{StaticResource ToolPanelBorder}" Padding="16,13" Margin="8,0,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="&#xE72E;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                       Foreground="{StaticResource WarningBrush}" FontSize="18" Margin="0,0,12,0"/>
                            <StackPanel>
                                <TextBlock Text="代理状态" Foreground="{StaticResource TextMutedBrush}" FontSize="10" FontWeight="SemiBold"/>
                                <TextBlock Text="{Binding ProxyStatusText}" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" TextTrimming="CharacterEllipsis"/>
                            </StackPanel>
                        </StackPanel>
                    </Border>
                </UniformGrid>
            </StackPanel>
        </Grid>
    </ScrollViewer>
</UserControl>

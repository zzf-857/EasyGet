<Window x:Class="EasyGet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyGet.ViewModels"
        xmlns:views="clr-namespace:EasyGet.Views"
        Title="EasyGet"
        Width="1280" Height="800"
        MinWidth="960" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        Background="{StaticResource BgPrimaryBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <!-- DataTemplate 映射 ViewModel → View -->
    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DownloadViewModel}">
            <views:DownloadView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BatchDownloadViewModel}">
            <views:BatchDownloadView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- ========== 左侧导航栏 ========== -->
        <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}">
            <DockPanel LastChildFill="True">

                <!-- Logo 区域 -->
                <StackPanel DockPanel.Dock="Top" Margin="20,24,20,32" Orientation="Horizontal">
                    <TextBlock Text="⬇" FontSize="24" Foreground="{StaticResource AccentBrush}" 
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock Text="EasyGet" FontSize="22" FontWeight="ExtraBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="Segoe UI Variable, Microsoft YaHei UI"
                               VerticalAlignment="Center"/>
                </StackPanel>

                <!-- 底部状态（必须在导航菜单之前声明，确保 DockPanel 为其预留空间） -->
                <StackPanel DockPanel.Dock="Bottom" Margin="20,0,20,20">
                    <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,12"/>
                    <TextBlock Text="{Binding StatusMessage}"
                               Foreground="{StaticResource TextMutedBrush}"
                               FontSize="11" TextTrimming="CharacterEllipsis"/>
                    <TextBlock Text="v1.0.0" Foreground="{StaticResource TextMutedBrush}"
                               FontSize="10" Margin="0,4,0,0" Opacity="0.5"/>
                </StackPanel>

                <!-- 导航菜单（LastChildFill 填充剩余空间） -->
                <StackPanel Margin="12,0">
                    <RadioButton Style="{StaticResource NavRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="download"
                                 IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0, Mode=OneWay}">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📥" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="视频下载" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="batch"
                                 IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1, Mode=OneWay}"
                                 Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📋" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="批量下载" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="history"
                                 IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2, Mode=OneWay}"
                                 Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="📜" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="历史记录" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                    <RadioButton Style="{StaticResource NavRadioButton}"
                                 Command="{Binding NavigateCommand}" CommandParameter="settings"
                                 IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3, Mode=OneWay}"
                                 Margin="0,4,0,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="⚙" FontSize="16" Margin="0,0,10,0" VerticalAlignment="Center"/>
                            <TextBlock Text="设置" VerticalAlignment="Center"/>
                        </StackPanel>
                    </RadioButton>
                </StackPanel>

            </DockPanel>
        </Border>

        <!-- ========== 右侧内容区 ========== -->
        <Grid Grid.Column="1">
            <ContentControl Content="{Binding CurrentPage}" Margin="0"/>

            <!-- Toast 通知 -->
            <Border HorizontalAlignment="Right" VerticalAlignment="Bottom"
                    Margin="24" CornerRadius="10" Padding="20,14"
                    Visibility="{Binding ShowNotification, Converter={StaticResource BoolToVisibility}}"
                    Cursor="Hand" Effect="{StaticResource PopupShadow}">
                <Border.Style>
                    <Style TargetType="Border">
                        <Setter Property="Background" Value="#2D4A2D"/>
                        <Style.Triggers>
                            <DataTrigger Binding="{Binding IsNotificationSuccess}" Value="False">
                                <Setter Property="Background" Value="#4A2D2D"/>
                            </DataTrigger>
                        </Style.Triggers>
                    </Style>
                </Border.Style>
                <Border.InputBindings>
                    <MouseBinding MouseAction="LeftClick" Command="{Binding DismissNotificationCommand}"/>
                </Border.InputBindings>
                <StackPanel Orientation="Horizontal" MaxWidth="400">
                    <TextBlock VerticalAlignment="Center" Margin="0,0,12,0" FontSize="16">
                        <TextBlock.Style>
                            <Style TargetType="TextBlock">
                                <Setter Property="Text" Value="✓"/>
                                <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsNotificationSuccess}" Value="False">
                                        <Setter Property="Text" Value="✗"/>
                                        <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </TextBlock.Style>
                    </TextBlock>
                    <TextBlock Text="{Binding NotificationMessage}"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontSize="14" TextTrimming="CharacterEllipsis"
                               VerticalAlignment="Center" TextWrapping="Wrap"/>
                </StackPanel>
            </Border>
        </Grid>

    </Grid>
</Window>

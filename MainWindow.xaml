<Window x:Class="EasyGet.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:EasyGet.ViewModels"
        xmlns:views="clr-namespace:EasyGet.Views"
        xmlns:shell="clr-namespace:System.Windows.Shell;assembly=PresentationFramework"
        Title="EasyGet"
        Width="1280" Height="800"
        MinWidth="1040" MinHeight="640"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None"
        ResizeMode="CanResize"
        Background="{StaticResource BgPrimaryBrush}"
        UseLayoutRounding="True"
        SnapsToDevicePixels="True"
        TextOptions.TextFormattingMode="Display"
        TextOptions.TextRenderingMode="ClearType">

    <shell:WindowChrome.WindowChrome>
        <shell:WindowChrome CaptionHeight="0"
                            ResizeBorderThickness="6"
                            CornerRadius="0"
                            GlassFrameThickness="0"
                            UseAeroCaptionButtons="False"/>
    </shell:WindowChrome.WindowChrome>

        <Window.TaskbarItemInfo>
        <TaskbarItemInfo ProgressState="{Binding TaskbarState}" ProgressValue="{Binding TaskbarValue}"/>
    </Window.TaskbarItemInfo>

    <Window.Resources>
        <DataTemplate DataType="{x:Type vm:DownloadViewModel}">
            <views:DownloadView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:BatchDownloadViewModel}">
            <views:BatchDownloadView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:HistoryViewModel}">
            <views:HistoryView/>
        </DataTemplate>
        <DataTemplate DataType="{x:Type vm:SettingsViewModel}">
            <views:SettingsView/>
        </DataTemplate>
    </Window.Resources>

    <Grid Background="{StaticResource BgPrimaryBrush}">
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <!-- Stitch-style brand sidebar -->
        <Border Grid.Column="0"
                Background="{StaticResource BgSidebarBrush}"
                BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="0,0,1,0">
            <DockPanel LastChildFill="False" Margin="14,16">
                <StackPanel DockPanel.Dock="Top">
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,30">
                        <Border x:Name="SidebarLogoMark"
                                Width="40" Height="40"
                                Background="{StaticResource AccentBrush}"
                                CornerRadius="9"
                                Effect="{StaticResource SoftShadow}"
                                ToolTip="EasyGet"
                                AutomationProperties.Name="EasyGet">
                            <Image Source="/Assets/app.png"
                                   Width="34"
                                   Height="34"
                                   Stretch="Uniform"
                                   HorizontalAlignment="Center"
                                   VerticalAlignment="Center"
                                   SnapsToDevicePixels="True"
                                   RenderOptions.BitmapScalingMode="HighQuality"/>
                        </Border>
                        <StackPanel Margin="12,1,0,0" VerticalAlignment="Center">
                            <TextBlock Text="EasyGet"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="18"
                                       FontWeight="SemiBold"
                                       FontFamily="Segoe UI Variable, Microsoft YaHei UI"/>
                            <TextBlock Text="{Binding AppVersion}"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       FontSize="10"
                                       FontWeight="SemiBold"/>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel>
                        <RadioButton Style="{StaticResource NavRadioButton}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="download"
                                     ToolTip="单个下载"
                                     AutomationProperties.Name="单个下载"
                                     IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=0, Mode=OneWay}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE118;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="18" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="单个下载" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavRadioButton}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="batch"
                                     ToolTip="批量下载"
                                     AutomationProperties.Name="批量下载"
                                     IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=1, Mode=OneWay}"
                                     Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE8FD;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="18" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="批量下载" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavRadioButton}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="history"
                                     ToolTip="下载历史"
                                     AutomationProperties.Name="下载历史"
                                     IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=2, Mode=OneWay}"
                                     Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE81C;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="18" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="下载历史" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                        <RadioButton Style="{StaticResource NavRadioButton}"
                                     Command="{Binding NavigateCommand}"
                                     CommandParameter="settings"
                                     ToolTip="设置"
                                     AutomationProperties.Name="设置"
                                     IsChecked="{Binding SelectedNavIndex, Converter={StaticResource IntToBoolConverter}, ConverterParameter=3, Mode=OneWay}"
                                     Margin="0,8,0,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="18" Width="24" VerticalAlignment="Center"/>
                                <TextBlock Text="设置" Margin="12,0,0,0" VerticalAlignment="Center"/>
                            </StackPanel>
                        </RadioButton>
                    </StackPanel>
                </StackPanel>

            </DockPanel>
        </Border>

        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="48"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>

            <!-- Custom top app bar -->
            <Border Grid.Row="0"
                    Background="{StaticResource BgPrimaryBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="0,0,0,1"
                    MouseLeftButtonDown="TopBar_MouseLeftButtonDown">
                <Grid>
                    <ContentControl Content="{Binding CurrentPageTitle}"
                                    VerticalAlignment="Center"
                                    Margin="20,0,0,0">
                        <ContentControl.ContentTemplate>
                            <DataTemplate>
                                <TextBlock Text="{Binding}"
                                           Foreground="{StaticResource TextPrimaryBrush}"
                                           FontSize="16"
                                           FontWeight="SemiBold"/>
                            </DataTemplate>
                        </ContentControl.ContentTemplate>
                    </ContentControl>

                    <StackPanel Orientation="Horizontal"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Stretch">
                        <Button Style="{StaticResource WindowControlButton}"
                                ToolTip="最小化"
                                AutomationProperties.Name="最小化"
                                Click="MinimizeButton_Click">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                        </Button>
                        <Button Style="{StaticResource WindowControlButton}"
                                ToolTip="最大化/还原"
                                AutomationProperties.Name="最大化或还原"
                                Click="MaximizeButton_Click">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}"
                                ToolTip="关闭"
                                AutomationProperties.Name="关闭"
                                Click="CloseButton_Click">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <Grid Grid.Row="1" Background="{StaticResource BgPrimaryBrush}">
                <ContentControl Content="{Binding CurrentPage}"/>

                <Border x:Name="NotificationToast"
                        HorizontalAlignment="Right" VerticalAlignment="Bottom"
                        Margin="24" CornerRadius="10" Padding="20,14"
                        Cursor="Hand" Effect="{StaticResource PopupShadow}">
                    <Border.RenderTransform>
                        <TranslateTransform Y="12"/>
                    </Border.RenderTransform>
                    <Border.Style>
                        <Style TargetType="Border">
                            <Setter Property="Background" Value="{StaticResource SuccessContainerBrush}"/>
                            <Setter Property="Opacity" Value="0"/>
                            <Setter Property="IsHitTestVisible" Value="False"/>
                            <Style.Triggers>
                                <DataTrigger Binding="{Binding ShowNotification}" Value="True">
                                    <DataTrigger.EnterActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="1"
                                                                 Duration="{StaticResource MotionDurationFast}"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="0"
                                                                 Duration="{StaticResource MotionDurationFast}"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.EnterActions>
                                    <DataTrigger.ExitActions>
                                        <BeginStoryboard>
                                            <Storyboard>
                                                <DoubleAnimation Storyboard.TargetProperty="Opacity"
                                                                 To="0"
                                                                 Duration="{StaticResource MotionDurationMedium}"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                                <DoubleAnimation Storyboard.TargetProperty="(UIElement.RenderTransform).(TranslateTransform.Y)"
                                                                 To="12"
                                                                 Duration="{StaticResource MotionDurationMedium}"
                                                                 EasingFunction="{StaticResource MotionEaseOut}"/>
                                            </Storyboard>
                                        </BeginStoryboard>
                                    </DataTrigger.ExitActions>
                                    <Setter Property="Opacity" Value="1"/>
                                    <Setter Property="IsHitTestVisible" Value="True"/>
                                </DataTrigger>
                                <DataTrigger Binding="{Binding IsNotificationSuccess}" Value="False">
                                    <Setter Property="Background" Value="{StaticResource ErrorContainerBrush}"/>
                                </DataTrigger>
                            </Style.Triggers>
                        </Style>
                    </Border.Style>
                    <Border.InputBindings>
                        <MouseBinding MouseAction="LeftClick" Command="{Binding DismissNotificationCommand}"/>
                    </Border.InputBindings>
                    <StackPanel Orientation="Horizontal" MaxWidth="400">
                        <TextBlock VerticalAlignment="Center" Margin="0,0,12,0" FontSize="16">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Text" Value="✓"/>
                                    <Setter Property="Foreground" Value="{StaticResource SuccessBrush}"/>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding IsNotificationSuccess}" Value="False">
                                            <Setter Property="Text" Value="✗"/>
                                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                        </TextBlock>
                        <TextBlock Text="{Binding NotificationMessage}"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontSize="14" TextTrimming="CharacterEllipsis"
                                   VerticalAlignment="Center" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>
            </Grid>
        </Grid>
    </Grid>
</Window>

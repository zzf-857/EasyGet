<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
                    xmlns:sys="clr-namespace:System;assembly=mscorlib"
                    xmlns:behaviors="clr-namespace:EasyGet.Behaviors">

    <!-- ========== Apple-inspired dark semantic color system ========== -->
    <Color x:Key="BgPrimary">#0D0D0F</Color>
    <Color x:Key="BgSidebar">#171719</Color>
    <Color x:Key="BgSurface">#1C1C1E</Color>
    <Color x:Key="BgSurfaceHigh">#242426</Color>
    <Color x:Key="BgSurfaceHighest">#2C2C2E</Color>
    <Color x:Key="BgHover">#343438</Color>
    <Color x:Key="TextPrimary">#F5F5F7</Color>
    <Color x:Key="TextSecondary">#C7C7CC</Color>
    <Color x:Key="TextMuted">#8E8E93</Color>
    <Color x:Key="BorderPrimary">#3A3A3C</Color>
    <Color x:Key="BorderSubtle">#2A2A2D</Color>
    <Color x:Key="Accent">#0A84FF</Color>
    <Color x:Key="Success">#30D158</Color>
    <Color x:Key="Error">#FF6961</Color>
    <Color x:Key="Warning">#FFD60A</Color>
    <Color x:Key="AccentContainer">#112A43</Color>
    <Color x:Key="SuccessContainer">#153A22</Color>
    <Color x:Key="ErrorContainer">#421E1E</Color>
    <Color x:Key="Scrim">#52000000</Color>
    <Color x:Key="ScrimLight">#8AFFFFFF</Color>
    <Color x:Key="ScrimHeavy">#B3000000</Color>
    <Color x:Key="ScrimOverlay">#B8171719</Color>
    <Color x:Key="BgConsole">#09090A</Color>
    <Color x:Key="WindowCloseHover">#492020</Color>
    <Color x:Key="WindowClosePressed">#602727</Color>
    <Color x:Key="AccentGradientStart">#0A84FF</Color>
    <Color x:Key="AccentGradientEnd">#64D2FF</Color>
    <Color x:Key="ToggleTrack">#3A3A3C</Color>
    <Color x:Key="ToggleThumb">#F2F2F7</Color>

    <SolidColorBrush x:Key="BgPrimaryBrush" Color="{StaticResource BgPrimary}"/>
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebar}"/>
    <SolidColorBrush x:Key="BgSurfaceBrush" Color="{StaticResource BgSurface}"/>
    <SolidColorBrush x:Key="BgSurfaceHighBrush" Color="{StaticResource BgSurfaceHigh}"/>
    <SolidColorBrush x:Key="BgSurfaceHighestBrush" Color="{StaticResource BgSurfaceHighest}"/>
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHover}"/>
    <SolidColorBrush x:Key="TextPrimaryBrush" Color="{StaticResource TextPrimary}"/>
    <SolidColorBrush x:Key="TextSecondaryBrush" Color="{StaticResource TextSecondary}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMuted}"/>
    <SolidColorBrush x:Key="BorderPrimaryBrush" Color="{StaticResource BorderPrimary}"/>
    <SolidColorBrush x:Key="BorderSubtleBrush" Color="{StaticResource BorderSubtle}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{DynamicResource Accent}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource Success}"/>
    <SolidColorBrush x:Key="ErrorBrush" Color="{StaticResource Error}"/>
    <SolidColorBrush x:Key="WarningBrush" Color="{StaticResource Warning}"/>
    <SolidColorBrush x:Key="AccentContainerBrush" Color="{DynamicResource AccentContainer}"/>
    <SolidColorBrush x:Key="SuccessContainerBrush" Color="{StaticResource SuccessContainer}"/>
    <SolidColorBrush x:Key="ErrorContainerBrush" Color="{StaticResource ErrorContainer}"/>
    <SolidColorBrush x:Key="ScrimBrush" Color="{StaticResource Scrim}"/>
    <SolidColorBrush x:Key="ScrimLightBrush" Color="{StaticResource ScrimLight}"/>
    <SolidColorBrush x:Key="ScrimHeavyBrush" Color="{StaticResource ScrimHeavy}"/>
    <SolidColorBrush x:Key="ScrimOverlayBrush" Color="{StaticResource ScrimOverlay}"/>
    <SolidColorBrush x:Key="BgConsoleBrush" Color="{StaticResource BgConsole}"/>
    <SolidColorBrush x:Key="WindowCloseHoverBrush" Color="{StaticResource WindowCloseHover}"/>
    <SolidColorBrush x:Key="WindowClosePressedBrush" Color="{StaticResource WindowClosePressed}"/>
    <SolidColorBrush x:Key="ToggleTrackBrush" Color="{StaticResource ToggleTrack}"/>
    <SolidColorBrush x:Key="ToggleThumbBrush" Color="{StaticResource ToggleThumb}"/>
    <SolidColorBrush x:Key="TransparentBrush" Color="Transparent"/>

    <!-- ========== 排版系统 Tokens (Typography Tokens) ========== -->
    <sys:Double x:Key="FontSizeCaption">11</sys:Double>
    <sys:Double x:Key="FontSizeBody">12</sys:Double>
    <sys:Double x:Key="FontSizeBodyStrong">14</sys:Double>
    <sys:Double x:Key="FontSizeSection">16</sys:Double>
    <sys:Double x:Key="FontSizeCardTitle">20</sys:Double>
    <sys:Double x:Key="FontSizePageTitle">28</sys:Double>

    <sys:Double x:Key="IconSizeSmall">12</sys:Double>
    <sys:Double x:Key="IconSizeBody">16</sys:Double>
    <sys:Double x:Key="IconSizeLarge">18</sys:Double>
    <sys:Double x:Key="IconSizePreview">28</sys:Double>
    <sys:Double x:Key="IconSizeEmptyState">48</sys:Double>

    <FontWeight x:Key="FontWeightNormal">Normal</FontWeight>
    <FontWeight x:Key="FontWeightSemiBold">SemiBold</FontWeight>

    <FontFamily x:Key="FontFamilyUI">Segoe UI Variable Text, Segoe UI, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="FontFamilyMono">Cascadia Code, Consolas, Microsoft YaHei UI</FontFamily>
    <FontFamily x:Key="FontFamilyIcon">Segoe Fluent Icons, Segoe MDL2 Assets</FontFamily>

    <!-- ========== 隐式排版样式 ========== -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
    </Style>
    <Style TargetType="{x:Type Control}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
    </Style>

    <!-- ========== ToolTip 与 ContextMenu 隐式样式 (R3 模糊治理) ========== -->
    <Style TargetType="{x:Type ToolTip}">
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="8,5"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToolTip}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter TextOptions.TextFormattingMode="Display"
                                          UseLayoutRounding="True"/>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ContextMenu}">
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ContextMenu}">
                    <Border Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="6"
                            Padding="2"
                            TextOptions.TextFormattingMode="Display"
                            UseLayoutRounding="True">
                        <ItemsPresenter />
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 命名文本样式套件 ========== -->
    <Style x:Key="TextPageTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizePageTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="TextCardTitle" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCardTitle}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="TextSection" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeSection}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="TextBodyStrong" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
    </Style>
    <Style x:Key="TextBody" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>
    <Style x:Key="TextCaption" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeCaption}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}"/>
    </Style>
    <Style x:Key="TextMono" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyMono}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBody}"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
    </Style>

    <!-- ========== 图标样式 ========== -->
    <Style x:Key="IconGlyph" TargetType="{x:Type TextBlock}">
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyIcon}"/>
        <Setter Property="FontSize" Value="{StaticResource IconSizeBody}"/>
        <Setter Property="TextAlignment" Value="Center"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- ========== Motion system: short, spatial and interruptible ========== -->
    <Duration x:Key="MotionDurationFast">0:0:0.14</Duration>
    <Duration x:Key="MotionDurationMedium">0:0:0.24</Duration>
    <CubicEase x:Key="MotionEaseOut" EasingMode="EaseOut"/>

    <!-- ========== Soft elevation shadows ========== -->
    <DropShadowEffect x:Key="SoftShadow" BlurRadius="18" ShadowDepth="3" Direction="270" Color="Black" Opacity="0.22"/>
    <DropShadowEffect x:Key="HoverShadow" BlurRadius="24" ShadowDepth="7" Direction="270" Color="Black" Opacity="0.34"/>
    <DropShadowEffect x:Key="PopupShadow" BlurRadius="32" ShadowDepth="10" Direction="270" Color="Black" Opacity="0.48"/>

    <!-- ========== 工具面板样式 ========== -->
    <Style x:Key="ToolPanelBorder" TargetType="Border">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="14"/>
        <Setter Property="Padding" Value="22,18"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="RenderTransformOrigin" Value="0.5,0.5"/>
        <Setter Property="RenderTransform">
            <Setter.Value>
                <TranslateTransform Y="0"/>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== TextBox 样式 ========== -->
    <Style x:Key="DarkTextBox" TargetType="TextBox">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="CaretBrush" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Padding" Value="12,8"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="TextBox">
                    <Grid>
                        <!-- Focus Ring Border (Fluent like) -->
                        <Border x:Name="FocusRing"
                                BorderBrush="{DynamicResource AccentBrush}"
                                BorderThickness="2"
                                CornerRadius="9"
                                Opacity="0"
                                Margin="-1"
                                SnapsToDevicePixels="True"/>
                        <Border x:Name="BgBorder"
                                Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8"
                                SnapsToDevicePixels="True">
                            <ScrollViewer x:Name="PART_ContentHost" Margin="0"/>
                        </Border>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <!-- Focus 触发 -->
                        <Trigger Property="IsFocused" Value="True">
                            <Setter TargetName="FocusRing" Property="Opacity" Value="0.5"/>
                            <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <!-- Hover 触发 (直接改变画刷即可) -->
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="BgBorder" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter TargetName="FocusRing" Property="Opacity" Value="0"/>
                            <Setter TargetName="BgBorder" Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== Button 样式 ========== -->
    <Style x:Key="AccentButton" TargetType="Button">
        <Setter Property="Background" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Padding" Value="18,9"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            CornerRadius="10"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="HoverOverlay" Background="White" Opacity="0" CornerRadius="10" IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <!-- Hover 动画 -->
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.12"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="{StaticResource MotionDurationMedium}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="0.97"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="0.97"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <!-- 按下状态 -->
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverOverlay" Property="Background" Value="Black"/>
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.15"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="SurfaceButton" TargetType="Button">
        <Setter Property="Background" Value="{StaticResource BgSurfaceHighBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Padding" Value="14,9"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"
                            TextElement.Foreground="{TemplateBinding Foreground}"
                            BorderBrush="{StaticResource BorderSubtleBrush}"
                            BorderThickness="1"
                            CornerRadius="10"
                            RenderTransformOrigin="0.5,0.5"
                            SnapsToDevicePixels="True">
                        <Border.RenderTransform>
                            <ScaleTransform x:Name="ButtonScale" ScaleX="1" ScaleY="1"/>
                        </Border.RenderTransform>
                        <Grid>
                            <Border x:Name="HoverOverlay" Background="White" Opacity="0" CornerRadius="10" IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.06"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="{StaticResource MotionDurationMedium}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseDown">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="0.97"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="0.97"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="PreviewMouseUp">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ButtonScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="HoverOverlay" Property="Background" Value="Black"/>
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0.15"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                            <Setter TargetName="HoverOverlay" Property="Opacity" Value="0"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowControlButton" TargetType="Button">
        <Setter Property="Width" Value="40"/>
        <Setter Property="Height" Value="46"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontSize" Value="{StaticResource IconSizeSmall}"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Width="28"
                            Height="28"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid>
                            <Border x:Name="HoverOverlay" Background="White" CornerRadius="8" Opacity="0" IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.05"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BgSurfaceHighBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource BgSurfaceHighestBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style x:Key="WindowCloseButton" TargetType="Button" BasedOn="{StaticResource WindowControlButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Width="28"
                            Height="28"
                            CornerRadius="8"
                            Background="{TemplateBinding Background}"
                            HorizontalAlignment="Center"
                            VerticalAlignment="Center">
                        <Grid>
                            <Border x:Name="HoverOverlay" Background="{StaticResource ErrorBrush}" CornerRadius="8" Opacity="0" IsHitTestVisible="False"/>
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <EventTrigger RoutedEvent="MouseEnter">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0.12"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <EventTrigger RoutedEvent="MouseLeave">
                            <BeginStoryboard>
                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="HoverOverlay"
                                                     Storyboard.TargetProperty="Opacity"
                                                     To="0"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                </Storyboard>
                            </BeginStoryboard>
                        </EventTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource WindowCloseHoverBrush}"/>
                            <Setter Property="Foreground" Value="{StaticResource ErrorBrush}"/>
                        </Trigger>
                        <Trigger Property="IsPressed" Value="True">
                            <Setter TargetName="border" Property="Background" Value="{StaticResource WindowClosePressedBrush}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== ComboBox 内部 ToggleButton ========== -->
    <ControlTemplate x:Key="DarkComboBoxToggleButton" TargetType="ToggleButton">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition/>
                <ColumnDefinition Width="28"/>
            </Grid.ColumnDefinitions>
            <Border x:Name="Border" Grid.ColumnSpan="2"
                    Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}"
                    BorderThickness="1" CornerRadius="8"/>
            <Path x:Name="Arrow" Grid.Column="1"
                  Fill="{StaticResource TextMutedBrush}"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  RenderTransformOrigin="0.5,0.5"
                  Data="M 0 0 L 4 4 L 8 0 Z">
                <Path.RenderTransform>
                    <RotateTransform Angle="0"/>
                </Path.RenderTransform>
            </Path>
        </Grid>
        <ControlTemplate.Triggers>
            <Trigger Property="IsMouseOver" Value="True">
                <Setter TargetName="Border" Property="BorderBrush" Value="{DynamicResource AccentBrush}"/>
            </Trigger>
            <Trigger Property="IsChecked" Value="True">
                <Setter TargetName="Arrow" Property="RenderTransform">
                    <Setter.Value>
                        <RotateTransform Angle="180"/>
                    </Setter.Value>
                </Setter>
            </Trigger>
        </ControlTemplate.Triggers>
    </ControlTemplate>

    <!-- ========== ComboBox 样式 ========== -->
    <Style x:Key="DarkComboBox" TargetType="ComboBox">
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
        <Setter Property="BorderBrush" Value="{StaticResource BorderSubtleBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Padding" Value="10,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="behaviors:PopupPlacement.Placement" Value="Bottom"/>
        <Setter Property="behaviors:PopupPlacement.VerticalOffset" Value="0"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ScrollViewer.VerticalScrollBarVisibility" Value="Auto"/>
        <Setter Property="ItemContainerStyle">
            <Setter.Value>
                <Style TargetType="ComboBoxItem">
                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}"/>
                    <Setter Property="Background" Value="Transparent"/>
                    <Setter Property="Padding" Value="10,6"/>
                    <Setter Property="Cursor" Value="Hand"/>
                    <Setter Property="Template">
                        <Setter.Value>
                            <ControlTemplate TargetType="ComboBoxItem">
                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                        Padding="{TemplateBinding Padding}" CornerRadius="4">
                                    <ContentPresenter/>
                                </Border>
                                <ControlTemplate.Triggers>
                                    <Trigger Property="IsHighlighted" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                    </Trigger>
                                    <Trigger Property="IsSelected" Value="True">
                                        <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}"/>
                                        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                    </Trigger>
                                </ControlTemplate.Triggers>
                            </ControlTemplate>
                        </Setter.Value>
                    </Setter>
                </Style>
            </Setter.Value>
        </Setter>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ComboBox">
                    <Grid>
                        <ToggleButton Template="{StaticResource DarkComboBoxToggleButton}"
                                      Focusable="False"
                                      IsChecked="{Binding IsDropDownOpen, Mode=TwoWay, RelativeSource={RelativeSource TemplatedParent}}"
                                      ClickMode="Press"/>
                        <ContentPresenter x:Name="ContentSite"
                                          IsHitTestVisible="False"
                                          Content="{TemplateBinding SelectionBoxItem}"
                                          ContentTemplate="{TemplateBinding SelectionBoxItemTemplate}"
                                          ContentStringFormat="{TemplateBinding SelectionBoxItemStringFormat}"
                                          Margin="12,7,28,7"
                                          VerticalAlignment="Center"
                                          HorizontalAlignment="Left"/>
                        <Popup x:Name="Popup"
                               Placement="{Binding Path=(behaviors:PopupPlacement.Placement), RelativeSource={RelativeSource TemplatedParent}}"
                               VerticalOffset="{Binding Path=(behaviors:PopupPlacement.VerticalOffset), RelativeSource={RelativeSource TemplatedParent}}"
                               IsOpen="{TemplateBinding IsDropDownOpen}"
                               AllowsTransparency="True" Focusable="False"
                               PopupAnimation="Slide">
                            <Grid x:Name="DropDown"
                                  SnapsToDevicePixels="True"
                                  MinWidth="{TemplateBinding ActualWidth}"
                                  MaxHeight="{TemplateBinding MaxDropDownHeight}"
                                  TextOptions.TextFormattingMode="Display"
                                  UseLayoutRounding="True">
                                <Border x:Name="DropDownBorder"
                                        Background="{StaticResource BgSurfaceHighestBrush}"
                                        BorderBrush="{StaticResource BorderPrimaryBrush}"
                                        BorderThickness="1" CornerRadius="8"
                                        Margin="0,2,0,0" Padding="4"
                                        Effect="{StaticResource PopupShadow}">
                                    <ScrollViewer SnapsToDevicePixels="True">
                                        <StackPanel IsItemsHost="True"
                                                    KeyboardNavigation.DirectionalNavigation="Contained"/>
                                    </ScrollViewer>
                                </Border>
                            </Grid>
                        </Popup>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.45"/>
                            <Setter Property="Cursor" Value="Arrow"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== ProgressBar 样式 ========== -->
    <Style x:Key="AccentProgressBar" TargetType="ProgressBar">
        <Setter Property="Height" Value="8"/>
        <Setter Property="Background" Value="{StaticResource BgSurfaceBrush}"/>
        <Setter Property="Foreground" Value="{DynamicResource AccentBrush}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ProgressBar">
                    <Border Background="{TemplateBinding Background}" 
                            CornerRadius="4" 
                            ClipToBounds="True">
                        <Grid x:Name="PART_Track">
                            <Border x:Name="PART_Indicator"
                                    HorizontalAlignment="Left"
                                    CornerRadius="4"
                                    Background="{TemplateBinding Foreground}"/>
                        </Grid>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ========== 导航按钮样式 ========== -->
    <Style x:Key="NavButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Foreground" Value="{StaticResource TextSecondaryBrush}"/>
        <Setter Property="FontSize" Value="{StaticResource FontSizeBodyStrong}"/>
        <Setter Property="FontWeight" Value="{StaticResource FontWeightSemiBold}"/>
        <Setter Property="FontFamily" Value="{StaticResource FontFamilyUI}"/>
        <Setter Property="Padding" Value="12,10"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="border"
                            Background="{TemplateBinding Background}"

                            <Setter TargetName="ToggleBorder" Property="Background" Value="{StaticResource BgSurfaceHighestBrush}"/>
                            <Setter TargetName="ToggleBorder" Property="BorderBrush" Value="{StaticResource BorderPrimaryBrush}"/>

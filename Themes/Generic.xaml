                                <Storyboard>
                                    <DoubleAnimation Storyboard.TargetName="ToggleScale"
                                                     Storyboard.TargetProperty="ScaleX"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
                                    <DoubleAnimation Storyboard.TargetName="ToggleScale"
                                                     Storyboard.TargetProperty="ScaleY"
                                                     To="1"
                                                     Duration="{StaticResource MotionDurationFast}"
                                                     EasingFunction="{StaticResource MotionEaseOut}"/>
